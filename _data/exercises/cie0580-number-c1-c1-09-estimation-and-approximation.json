    {
      "id": "C1-09-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "By rounding each number to 1 significant figure, estimate the value of $\\dfrac{38.4 \\times 4.92}{0.195}$.",
      "answerType": "integer",
      "correctAnswer": "1000",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "$38.4 \\approx 40$, $4.92 \\approx 5$, $0.195 \\approx 0.2$" },
        { "mark": "M1", "desc": "$\\dfrac{40 \\times 5}{0.2}$" },
        { "mark": "A1", "desc": "$1000$ cao" }
      ],
      "workingSteps": [
        "$38.4 \\approx 40$ (1 sf)",
        "$4.92 \\approx 5$ (1 sf)",
        "$0.195 \\approx 0.2$ (1 sf)",
        "$\\dfrac{40 \\times 5}{0.2} = \\dfrac{200}{0.2} = 1000$"
      ],
      "explanation": "Round each number to 1 sf first, then compute."
    },
