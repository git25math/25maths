    {
      "id": "H4-06-Q1",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": "A, B and C are points on a circle with centre O. Angle AOB = 124°. D is a point on the minor arc AB.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the angle ACB where C is on the major arc.\nGive a reason for your answer.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "62",
          "tolerance": null,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "Angle at centre = 2 × angle at circumference (same arc)" },
            { "mark": "A1", "desc": "ACB = 124 ÷ 2 = 62°" },
            { "mark": "B1", "desc": "Angle at centre is twice angle at circumference oe" }
          ],
          "workingSteps": [
            "ACB is on the major arc, subtending the same arc AB as angle AOB",
            "Angle ACB = AOB ÷ 2 = 124° ÷ 2 = 62°"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the angle ADB where D is on the minor arc.\nGive a reason.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "118",
          "tolerance": null,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "Reflex angle AOB = 360 − 124 = 236°; ADB = 236/2 = 118°" },
            { "mark": "A1", "desc": "118°" }
          ],
          "workingSteps": [
            "D is on the minor arc, so ADB subtends the major arc (reflex angle at centre)",
            "Reflex AOB = 360° − 124° = 236°",
            "ADB = 236° ÷ 2 = 118°"
          ]
        },
        {
          "label": "c",
          "questionText": "Verify that angles ACB and ADB are supplementary.\nGive a reason.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "show-that",
          "correctAnswer": "62 + 118 = 180°",
          "markScheme": [
            { "mark": "M1", "desc": "62 + 118 = 180°" },
            { "mark": "A1", "desc": "Opposite angles of a cyclic quadrilateral sum to 180° (ACDB is a cyclic quad) oe" }
          ],
          "workingSteps": [
            "ACB + ADB = 62° + 118° = 180° ✓",
            "C and D are on opposite arcs, forming a cyclic quadrilateral ACBD.",
            "Opposite angles of a cyclic quadrilateral sum to 180°."
          ]
        }
      ]
    },
    {
      "id": "H4-06-Q2",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "T is an external point. TA and TB are tangents to a circle with centre O and radius 6 cm. OT = 10 cm.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the length TA.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "8",
          "tolerance": 0,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "Angle OAT = 90° (tangent ⊥ radius)" },
            { "mark": "M1", "desc": "TA² = OT² − OA² = 100 − 36 = 64" },
            { "mark": "A1", "desc": "TA = 8 cm" }
          ],
          "workingSteps": [
            "OA ⊥ TA (tangent perpendicular to radius)",
            "TA² = OT² − OA² = 10² − 6² = 100 − 36 = 64",
            "TA = 8 cm"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out angle OTA.\nGive your answer correct to 1 decimal place.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "36.9",
          "tolerance": 0.2,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "sin(OTA) = OA/OT = 6/10 = 0.6" },
            { "mark": "M1", "desc": "OTA = arcsin(0.6)" },
            { "mark": "A1", "desc": "36.9° (1dp)" }
          ],
          "workingSteps": [
            "sin(OTA) = OA/OT = 6/10 = 0.6",
            "Angle OTA = arcsin(0.6) = 36.87° ≈ 36.9°"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out angle AOB.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "106.3",
          "tolerance": 0.5,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "Angle AOT = arccos(6/10) = 53.13...; by symmetry angle BOT = same" },
            { "mark": "A1", "desc": "AOB = 2 × 53.13 = 106.3° (1dp)" }
          ],
          "workingSteps": [
            "In right triangle OAT: cos(AOT) = OA/OT = 6/10",
            "Angle AOT = arccos(0.6) = 53.13°",
            "By symmetry OBT = OAT, so angle BOT = 53.13°",
            "Angle AOB = 53.13° + 53.13° = 106.26° ≈ 106.3°"
          ]
        }
      ]
    }
  ]
}
