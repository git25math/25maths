    {
      "id": "H1-07-Q1",
      "type": "structured",
      "totalMarks": 4,
      "difficulty": "medium",
      "context": "$y$ is inversely proportional to $x^2$.\nWhen $x = 3$, $y = 4$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the equation connecting $y$ and $x$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$y = \\dfrac{36}{x^2}$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$y = \\dfrac{k}{x^2}$; $4 = \\dfrac{k}{9}$; $k = 36$" },
            { "mark": "A1", "desc": "$y = \\dfrac{36}{x^2}$ cao" }
          ],
          "workingSteps": [
            "$y = \\dfrac{k}{x^2}$ (inverse proportion to $x^2$)",
            "$4 = \\dfrac{k}{3^2} = \\dfrac{k}{9}$",
            "$k = 36$",
            "$y = \\dfrac{36}{x^2}$"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the value of $y$ when $x = 6$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "1",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$y = \\dfrac{36}{6^2} = \\dfrac{36}{36}$" },
            { "mark": "A1", "desc": "$y = 1$ cao" }
          ],
          "workingSteps": [
            "$y = \\dfrac{36}{6^2} = \\dfrac{36}{36} = 1$"
          ]
        }
      ]
    },
    {
