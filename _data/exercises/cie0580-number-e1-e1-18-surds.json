          "questionText": "Rationalise the denominator of $\\dfrac{5}{3 - \\sqrt{2}}$.\nGive your answer in the form $a + b\\sqrt{2}$ where $a$ and $b$ are integers.",
          "marks": 4,
          "commandWord": "simplify",
          "answerType": "expression",
          "correctAnswer": "$\\dfrac{15 + 5\\sqrt{2}}{7}$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Multiply by conjugate: $\\dfrac{5}{3-\\sqrt{2}} \\times \\dfrac{3+\\sqrt{2}}{3+\\sqrt{2}}$" },
            { "mark": "M1", "desc": "Denominator: $(3)^2 - (\\sqrt{2})^2 = 9 - 2 = 7$" },
            { "mark": "M1", "desc": "Numerator: $5(3 + \\sqrt{2}) = 15 + 5\\sqrt{2}$" },
            { "mark": "A1", "desc": "$\\dfrac{15 + 5\\sqrt{2}}{7}$ cao" }
          ],
          "workingSteps": [
            "$\\dfrac{5}{3-\\sqrt{2}} \\times \\dfrac{3+\\sqrt{2}}{3+\\sqrt{2}}$",
            "Denominator: $(3-\\sqrt{2})(3+\\sqrt{2}) = 9 - 2 = 7$",
            "Numerator: $5 \\times (3+\\sqrt{2}) = 15 + 5\\sqrt{2}$",
            "Result: $\\dfrac{15 + 5\\sqrt{2}}{7}$"
          ]
