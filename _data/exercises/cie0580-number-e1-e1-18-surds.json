      "questionText": "Simplify $\\sqrt{48}$.",
      "answerType": "expression",
      "correctAnswer": "$4\\sqrt{3}$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "$\\sqrt{48} = \\sqrt{16 \\times 3} = \\sqrt{16} \\times \\sqrt{3}$" },
        { "mark": "A1", "desc": "$4\\sqrt{3}$ cao" }
      ],
      "workingSteps": [
        "$48 = 16 \\times 3$",
        "$\\sqrt{48} = \\sqrt{16 \\times 3} = \\sqrt{16} \\times \\sqrt{3} = 4\\sqrt{3}$"
      ],
      "explanation": "Find the largest perfect square factor of 48."
    },
    {
