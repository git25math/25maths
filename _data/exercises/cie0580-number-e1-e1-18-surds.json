      "commandWord": "simplify",
      "difficulty": "medium",
      "questionText": "Simplify $(3 + \\sqrt{5})(3 - \\sqrt{5})$.",
      "answerType": "integer",
      "correctAnswer": "4",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Uses difference of squares: $(a+b)(a-b) = a^2 - b^2$" },
        { "mark": "M1", "desc": "$3^2 - (\\sqrt{5})^2 = 9 - 5$" },
        { "mark": "A1", "desc": "$4$ cao" }
      ],
      "workingSteps": [
        "$(3 + \\sqrt{5})(3 - \\sqrt{5}) = 3^2 - (\\sqrt{5})^2$",
        "$= 9 - 5 = 4$"
      ],
      "explanation": "$(a+b)(a-b) = a^2 - b^2$. The surds cancel."
    },
