    {
      "id": "F4-09-Q1",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "easy",
      "context": "A composite shape consists of a rectangle 10 cm by 6 cm with a semicircle of diameter 6 cm attached to one of the shorter ends.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the area of the rectangle.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "60",
          "tolerance": null,
          "unit": "cm²",
          "markScheme": [
            { "mark": "B1", "desc": "10 × 6 = 60 cm²" }
          ],
          "workingSteps": [
            "Area = length × width = 10 × 6 = 60 cm²"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the area of the semicircle.\nGive your answer correct to 2 decimal places.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "14.14",
          "tolerance": 0.01,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "Radius = 3 cm; area of full circle = π × 3²" },
            { "mark": "M1", "desc": "Area of semicircle = (1/2) × π × 9" },
            { "mark": "A1", "desc": "14.14 cm² (2dp)" }
          ],
          "workingSteps": [
            "Diameter = 6 cm, so radius = 3 cm",
            "Area of semicircle = (1/2)πr² = (1/2) × π × 9 = 4.5π = 14.137... ≈ 14.14 cm²"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the total area of the composite shape.\nGive your answer correct to 2 decimal places.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "74.14",
          "tolerance": 0.05,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "60 + their semicircle area" },
            { "mark": "A1", "desc": "74.14 cm² ft" }
          ],
          "workingSteps": [
            "Total area = 60 + 14.14 = 74.14 cm²"
          ]
        }
      ]
    },
    {
      "id": "F4-09-Q2",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "medium",
      "context": "A trapezium has parallel sides of length 8 cm and 14 cm, and a perpendicular height of 5 cm.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the area of the trapezium.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "55",
          "tolerance": null,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "Area = (1/2)(a + b)h" },
            { "mark": "M1", "desc": "(1/2)(8 + 14) × 5 = (1/2) × 22 × 5" },
            { "mark": "A1", "desc": "55 cm²" }
          ],
          "workingSteps": [
            "Area of trapezium = (1/2)(a + b)h",
            "= (1/2)(8 + 14) × 5",
            "= (1/2) × 22 × 5",
            "= 55 cm²"
          ]
        },
        {
          "label": "b",
          "questionText": "The trapezium is the cross-section of a prism of length 12 cm.\nWork out the volume of the prism.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "660",
          "tolerance": null,
          "unit": "cm³",
          "markScheme": [
            { "mark": "M1", "desc": "Volume = cross-sectional area × length = 55 × 12" },
            { "mark": "A1", "desc": "660 cm³" }
          ],
          "workingSteps": [
            "Volume = area of cross-section × length",
            "= 55 × 12 = 660 cm³"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the perimeter of the trapezium if the non-parallel sides are each 5.4 cm.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "32.8",
          "tolerance": 0,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "8 + 14 + 5.4 + 5.4" },
            { "mark": "A1", "desc": "32.8 cm" }
          ],
          "workingSteps": [
            "Perimeter = 8 + 14 + 5.4 + 5.4 = 32.8 cm"
          ]
        }
      ]
    }
  ]
