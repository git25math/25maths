      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "AB and CD are parallel lines.\nA transversal crosses AB at point P and CD at point Q.\nThe angle APQ = 65°.\nCalculate the value of the co-interior angle PQD.",
      "answerType": "integer",
      "correctAnswer": "115",
      "tolerance": null,
      "unit": "°",
      "markScheme": [
        { "mark": "M1", "desc": "Co-interior angles add up to 180°" },
        { "mark": "M1", "desc": "180 − 65" },
        { "mark": "A1", "desc": "115" }
      ],
      "workingSteps": [
        "Co-interior angles (same-side interior angles) sum to 180°",
        "PQD = 180° − 65° = 115°"
      ],
      "explanation": "Co-interior angles between parallel lines add up to 180°."
    },
    {
      "id": "C4-06-Q2",
      "type": "short-answer",
      "totalMarks": 2,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "Calculate the interior angle of a regular octagon.",
      "answerType": "integer",
      "correctAnswer": "135",
      "tolerance": null,
      "unit": "°",
      "markScheme": [
        { "mark": "M1", "desc": "Sum of interior angles = (8 − 2) × 180 = 1080° or exterior angle = 360/8 = 45°" },
        { "mark": "A1", "desc": "1080 ÷ 8 = 135 or 180 − 45 = 135" }
      ],
      "workingSteps": [
        "Sum of interior angles = (8 − 2) × 180° = 6 × 180° = 1080°",
        "Each interior angle = 1080° ÷ 8 = 135°"
      ],
      "explanation": "Sum of interior angles of n-sided polygon = (n − 2) × 180°."
    },
