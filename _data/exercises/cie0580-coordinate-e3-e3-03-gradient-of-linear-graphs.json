      "correctAnswer": "3",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "(a+1−3)/(4−a) = 1"
        },
        {
          "mark": "M1",
          "desc": "a − 2 = 4 − a"
        },
        {
          "mark": "M1",
          "desc": "2a = 6"
        },
        {
          "mark": "A1",
          "desc": "a = 3"
        }
      ],
      "workingSteps": [
        "(a+1−3)/(4−a) = 1",
        "(a−2)/(4−a) = 1",
        "a − 2 = 4 − a",
        "2a = 6, a = 3"
      ],
      "explanation": "Set up gradient formula and solve the resulting equation."
