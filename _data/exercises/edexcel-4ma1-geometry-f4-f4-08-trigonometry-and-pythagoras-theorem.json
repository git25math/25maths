  "questions": [
    {
      "id": "F4-08-Q1",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "easy",
      "context": "A right-angled triangle has legs of length 9 cm and 12 cm.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the length of the hypotenuse.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "15",
          "tolerance": null,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "9² + 12² = 81 + 144 = 225" },
            { "mark": "M1", "desc": "√225" },
            { "mark": "A1", "desc": "15 cm" }
          ],
          "workingSteps": [
            "h² = 9² + 12² = 81 + 144 = 225",
            "h = √225 = 15 cm"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the angle between the hypotenuse and the 12 cm side.\nGive your answer correct to 1 decimal place.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "36.9",
          "tolerance": 0.1,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "sin θ = opposite/hypotenuse = 9/15" },
            { "mark": "M1", "desc": "θ = arcsin(9/15)" },
            { "mark": "A1", "desc": "36.9° (1dp)" }
          ],
          "workingSteps": [
            "The angle θ is between the hypotenuse and the 12 cm side.",
            "The opposite side to θ is 9 cm.",
            "sin θ = 9/15 = 0.6",
            "θ = arcsin(0.6) = 36.87° ≈ 36.9°"
          ]
        }
      ]
    },
    {
      "id": "F4-08-Q2",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "medium",
      "context": "A ladder of length 5 m leans against a vertical wall. The foot of the ladder is 1.5 m from the base of the wall.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out how high up the wall the ladder reaches.\nGive your answer correct to 2 decimal places.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "4.77",
          "tolerance": 0.01,
          "unit": "m",
          "markScheme": [
            { "mark": "M1", "desc": "h² = 5² − 1.5² = 25 − 2.25 = 22.75" },
            { "mark": "M1", "desc": "h = √22.75" },
            { "mark": "A1", "desc": "4.77 m (2dp)" }
          ],
          "workingSteps": [
            "h² = 5² − 1.5² = 25 − 2.25 = 22.75",
            "h = √22.75 = 4.7697... ≈ 4.77 m"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the angle the ladder makes with the ground.\nGive your answer correct to 1 decimal place.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "72.5",
          "tolerance": 0.2,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "cos θ = 1.5/5 = 0.3" },
            { "mark": "M1", "desc": "θ = arccos(0.3)" },
            { "mark": "A1", "desc": "72.5° (1dp)" }
          ],
          "workingSteps": [
            "cos θ = adjacent/hypotenuse = 1.5/5 = 0.3",
            "θ = arccos(0.3) = 72.54...° ≈ 72.5°"
          ]
        },
        {
          "label": "c",
          "questionText": "Give a reason why the wall must be vertical for your Pythagoras calculation to be valid.",
          "marks": 2,
          "commandWord": "explain",
          "answerType": "explain",
          "correctAnswer": "Pythagoras' theorem only applies to right-angled triangles; the right angle is where the vertical wall meets the horizontal ground.",
          "markScheme": [
            { "mark": "B1", "desc": "Pythagoras requires a right angle" },
            { "mark": "B1", "desc": "The right angle is formed at the base of the wall (wall perpendicular to ground) oe" }
          ],
          "workingSteps": [
            "Pythagoras' theorem applies only to right-angled triangles.",
            "The right angle is at the foot of the wall where the vertical wall meets the horizontal ground."
          ]
        }
      ]
    }
  ]
