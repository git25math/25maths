    {
      "id": "E2-10-Q4",
      "type": "short-answer",
      "totalMarks": 8,
      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "The function $g(x) = \\dfrac{3}{x} + 2$ for $x \\neq 0$.\n\n(a) Find the value of $g(-3)$.\n(b) Describe the asymptotes of the graph.\n(c) The graph of $g(x)$ intersects the $x$-axis at one point. Find the $x$-coordinate of this point.",
      "answerType": "expression",
      "correctAnswer": "(a) 1, (b) $x=0$ (vertical) and $y=2$ (horizontal), (c) $-1.5$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "(a) $g(-3) = \\frac{3}{-3}+2 = -1+2 = 1$" },
        { "mark": "B1", "desc": "(b) Vertical asymptote $x=0$" },
        { "mark": "B1", "desc": "(b) Horizontal asymptote $y=2$" },
        { "mark": "M1", "desc": "(c) $\\frac{3}{x}+2=0 \\Rightarrow \\frac{3}{x}=-2$" },
        { "mark": "A1", "desc": "(c) $x=-\\frac{3}{2}=-1.5$" }
      ],
      "workingSteps": [
        "(a) $g(-3)=\\frac{3}{-3}+2=-1+2=1$",
        "(b) As $x\\to0$, $|g(x)|\\to\\infty$: vertical asymptote $x=0$",
        "As $x\\to\\pm\\infty$, $g(x)\\to2$: horizontal asymptote $y=2$",
        "(c) Set $g(x)=0$: $\\frac{3}{x}+2=0 \\Rightarrow \\frac{3}{x}=-2 \\Rightarrow x=-\\frac{3}{2}$"
      ],
      "explanation": "For $y=\\frac{k}{x}+c$: vertical asymptote at $x=0$, horizontal at $y=c$."
    }
  ]
