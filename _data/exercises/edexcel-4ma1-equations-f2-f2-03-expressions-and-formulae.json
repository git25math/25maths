  "questions": [
    {
      "id": "F2-03-Q1",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "easy",
      "context": "The formula for the area of a trapezium is:\n$$A = \\frac{1}{2}(a + b)h$$\nwhere $a$ and $b$ are the parallel sides and $h$ is the height.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the value of $A$ when $a = 5$, $b = 9$ and $h = 4$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "28",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "½ × (5 + 9) × 4 = ½ × 14 × 4" },
            { "mark": "A1", "desc": "28 cao" }
          ],
          "workingSteps": [
            "a + b = 5 + 9 = 14",
            "½ × 14 × 4 = 7 × 4 = 28"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the value of $h$ when $A = 30$, $a = 4$ and $b = 8$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "5",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "30 = ½ × 12 × h → h = 60 ÷ 12" },
            { "mark": "A1", "desc": "5 cao" }
          ],
          "workingSteps": [
            "30 = ½ × (4 + 8) × h = ½ × 12 × h = 6h",
            "h = 30 ÷ 6 = 5"
          ]
        },
        {
          "label": "c",
          "questionText": "Rearrange the formula to make $a$ the subject.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "a = 2A/h - b",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Multiplies both sides by 2 and divides by h: 2A/h = a + b" },
            { "mark": "A1", "desc": "a = 2A/h − b oe" }
          ],
          "workingSteps": [
            "A = ½(a + b)h",
            "2A = (a + b)h",
            "2A/h = a + b",
            "a = 2A/h − b"
          ]
        }
      ]
    },
    {
      "id": "F2-03-Q2",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "A taxi company charges a fixed fee of £2.50 plus £1.20 per mile.\nThe total cost for $m$ miles is given by $C = 2.50 + 1.20m$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the total cost for a 7-mile journey.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "10.90",
          "tolerance": 0.01,
          "unit": "£",
          "markScheme": [
            { "mark": "M1", "desc": "2.50 + 1.20 × 7" },
            { "mark": "A1", "desc": "£10.90 cao" }
          ],
          "workingSteps": [
            "1.20 × 7 = 8.40",
            "C = 2.50 + 8.40 = £10.90"
          ]
        },
        {
          "label": "b",
          "questionText": "Rearrange the formula to make $m$ the subject.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "m = (C - 2.50) / 1.20",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "C − 2.50 = 1.20m" },
            { "mark": "A1", "desc": "m = (C − 2.50) / 1.20 oe" }
          ],
          "workingSteps": [
            "C = 2.50 + 1.20m",
            "C − 2.50 = 1.20m",
            "m = (C − 2.50) / 1.20"
          ]
        },
        {
          "label": "c",
          "questionText": "A passenger pays £16.90.\nUse your rearranged formula to work out the distance of the journey.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "12",
          "tolerance": null,
          "unit": "miles",
          "markScheme": [
            { "mark": "M1", "desc": "(16.90 − 2.50) ÷ 1.20 = 14.40 ÷ 1.20" },
            { "mark": "A1", "desc": "12 cao" }
          ],
          "workingSteps": [
            "m = (16.90 − 2.50) / 1.20",
            "m = 14.40 / 1.20",
            "m = 12 miles"
          ]
        }
      ]
    },
    {
      "id": "F2-03-Q3",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": null,
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "The formula for converting Celsius ($C$) to Fahrenheit ($F$) is:\n$$F = \\frac{9C}{5} + 32$$\nWork out $F$ when $C = 25$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "77",
          "tolerance": null,
          "unit": "°F",
          "markScheme": [
            { "mark": "M1", "desc": "9 × 25 ÷ 5 + 32 = 45 + 32" },
            { "mark": "A1", "desc": "77 cao" }
          ],
          "workingSteps": [
            "9 × 25 = 225",
            "225 ÷ 5 = 45",
            "F = 45 + 32 = 77°F"
          ]
        },
        {
          "label": "b",
          "questionText": "Rearrange the formula $F = \\dfrac{9C}{5} + 32$ to make $C$ the subject.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "C = 5(F - 32) / 9",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "F − 32 = 9C/5 then multiplies by 5 and divides by 9" },
            { "mark": "A1", "desc": "C = 5(F − 32)/9 oe" }
          ],
          "workingSteps": [
            "F − 32 = 9C/5",
            "5(F − 32) = 9C",
            "C = 5(F − 32)/9"
          ]
        },
        {
          "label": "c",
          "questionText": "Use your formula to work out $C$ when $F = 50$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "10",
          "tolerance": null,
          "unit": "°C",
          "markScheme": [
            { "mark": "M1", "desc": "5 × (50 − 32) / 9 = 5 × 18 / 9 = 90 / 9" },
            { "mark": "A1", "desc": "10 cao" }
          ],
          "workingSteps": [
            "C = 5(50 − 32)/9",
            "C = 5 × 18 / 9",
            "C = 90 / 9 = 10°C"
          ]
        }
      ]
    }
  ]
