              "mark": "M1",
              "desc": "¼ × 64π"
            },
            {
              "mark": "A1",
              "desc": "50.3"
            }
          ],
          "workingSteps": [
            "Area = (θ/360) × πr² = (90/360) × π × 64 = 16π = 50.3 cm²"
          ]
        },
        {
          "label": "c",
          "questionText": "Calculate the perimeter of the sector.",
          "marks": 1,
