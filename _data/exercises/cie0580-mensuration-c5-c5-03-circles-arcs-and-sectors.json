            },
            {
              "mark": "A1",
              "desc": "12.6"
            }
          ],
          "workingSteps": [
            "Arc = (θ/360) × 2πr = (90/360) × 2π × 8 = ¼ × 16π = 4π = 12.6 cm"
          ]
        },
        {
          "label": "b",
          "questionText": "Calculate the area of the sector.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "50.3",
          "tolerance": 0.05,
          "unit": "cm²",
          "markScheme": [
