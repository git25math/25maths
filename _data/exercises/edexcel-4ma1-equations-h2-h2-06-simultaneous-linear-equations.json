            { "mark": "A1", "desc": "x = 3 + √3 or x = 3 − √3" },
            { "mark": "A1", "desc": "Corresponding y values found" }
          ],
          "workingSteps": [
            "Set equal: x² − 4x + 5 = 2x − 1",
            "x² − 6x + 6 = 0",
            "x = [6 ± √(36−24)]/2 = (6 ± √12)/2 = 3 ± √3",
            "x₁ = 3 + √3 ≈ 4.73, y₁ = 2(3+√3) − 1 = 5 + 2√3",
            "x₂ = 3 − √3 ≈ 1.27, y₂ = 2(3−√3) − 1 = 5 − 2√3"
          ]
        },
