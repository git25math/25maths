          "workingSteps": [
            "Substitute y = x + 1 into x² + y² = 25:",
            "x² + (x+1)² = 25",
            "x² + x² + 2x + 1 = 25",
            "2x² + 2x − 24 = 0",
            "x² + x − 12 = 0",
            "(x + 4)(x − 3) = 0",
            "x = 3 → y = 4; x = −4 → y = −3",
            "Solutions: (3, 4) and (−4, −3)"
