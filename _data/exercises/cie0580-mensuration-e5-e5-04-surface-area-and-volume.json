    {
      "id": "E5-04-Q3",
      "type": "short-answer",
      "totalMarks": 4,
      "commandWord": "calculate",
      "difficulty": "hard",
      "questionText": "A sphere has surface area 400 cm².\nCalculate the radius of the sphere.\nGive your answer correct to 3 significant figures.",
      "answerType": "numeric",
      "correctAnswer": "5.64",
      "tolerance": 0.01,
      "unit": "cm",
      "markScheme": [
        {
          "mark": "M1",
          "desc": "4πr² = 400"
        },
        {
          "mark": "M1",
          "desc": "r² = 400/(4π) = 100/π"
        },
        {
          "mark": "M1",
          "desc": "r = √(100/π)"
        },
        {
          "mark": "A1",
          "desc": "5.64"
        }
      ],
      "workingSteps": [
        "4πr² = 400",
        "r² = 100/π = 31.83",
        "r = √31.83 = 5.64 cm"
      ],
      "explanation": "Rearrange the surface area formula 4πr² = SA to find r."
