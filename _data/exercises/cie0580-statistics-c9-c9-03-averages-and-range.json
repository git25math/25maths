    {
      "id": "C9-03-Q1",
      "type": "short-answer",
      "totalMarks": 4,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "Eight students scored the following marks in a test:\n12, 15, 9, 18, 15, 11, 14, 10\n\nCalculate\n(a) the mean,\n(b) the median.",
      "answerType": "numeric",
      "correctAnswer": "(a) 13, (b) 13",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "(a) Sum = 104 seen" },
        { "mark": "A1", "desc": "(a) 104 ÷ 8 = 13" },
        { "mark": "M1", "desc": "(b) Ordered list and middle two values identified: 12, 14" },
        { "mark": "A1", "desc": "(b) (12 + 14) ÷ 2 = 13" }
      ],
      "workingSteps": [
        "(a) Sum = 12+15+9+18+15+11+14+10 = 104",
        "(a) Mean = 104 ÷ 8 = 13",
        "(b) Ordered: 9, 10, 11, 12, 14, 15, 15, 18",
        "(b) 8 values → median = average of 4th and 5th = (12 + 14) ÷ 2 = 13"
      ],
      "explanation": "Mean = total ÷ count. For an even number of values, median = mean of the two middle values."
    },
    {
      "id": "C9-03-Q2",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "medium",
      "context": "The frequency table shows the number of pets owned by 20 families.\n\n| Number of pets | Frequency |\n|---------------|----------|\n| 0 | 5 |\n| 1 | 7 |\n| 2 | 4 |\n| 3 | 3 |\n| 4 | 1 |",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write down the mode.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "integer",
          "correctAnswer": "1",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "1 (highest frequency of 7)" }
          ],
          "workingSteps": [
            "Highest frequency = 7, corresponding to 1 pet → mode = 1"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the median number of pets.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "1",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Identifies 10th and 11th values in ordered data" },
            { "mark": "A1", "desc": "Median = 1 (both 10th and 11th values are 1)" }
          ],
          "workingSteps": [
            "Total = 20 families → median is average of 10th and 11th values",
            "Values 1–5: 0 pets (5 families)",
            "Values 6–12: 1 pet (7 families) → 10th and 11th values are both 1",
            "Median = 1"
          ]
        },
        {
          "label": "c",
          "questionText": "Calculate the mean number of pets per family.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "1.4",
          "tolerance": 0.05,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Multiplies number of pets by frequency for at least 3 rows" },
            { "mark": "M1", "desc": "Σfx = 0×5 + 1×7 + 2×4 + 3×3 + 4×1 = 28" },
            { "mark": "A1", "desc": "28 ÷ 20 = 1.4" }
          ],
          "workingSteps": [
            "Σfx = (0×5) + (1×7) + (2×4) + (3×3) + (4×1)",
            "Σfx = 0 + 7 + 8 + 9 + 4 = 28",
            "Mean = 28 ÷ 20 = 1.4"
          ]
        },
        {
          "label": "d",
          "questionText": "Find the range.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "4",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "4 − 0" },
            { "mark": "A1", "desc": "4" }
          ],
          "workingSteps": [
            "Maximum = 4, Minimum = 0",
            "Range = 4 − 0 = 4"
          ]
        }
      ]
    },
    {
      "id": "C9-03-Q3",
      "type": "short-answer",
      "totalMarks": 6,
      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "The mean of five numbers is 12.\nFour of the numbers are 8, 14, 10 and 15.\n\n(a) Find the sum of all five numbers.\n(b) Find the fifth number.",
      "answerType": "integer",
      "correctAnswer": "(a) 60, (b) 13",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "(a) 12 × 5" },
        { "mark": "A1", "desc": "(a) 60" },
        { "mark": "M1", "desc": "(b) 60 − (8 + 14 + 10 + 15)" },
        { "mark": "M1", "desc": "8 + 14 + 10 + 15 = 47" },
        { "mark": "A1", "desc": "(b) 60 − 47 = 13" },
        { "mark": "B1", "desc": "ft: fifth number = their sum − 47" }
      ],
      "workingSteps": [
        "(a) Sum = mean × count = 12 × 5 = 60",
        "(b) Sum of known four = 8 + 14 + 10 + 15 = 47",
        "(b) Fifth number = 60 − 47 = 13"
      ],
      "explanation": "Sum = mean × number of values. Then subtract the known values."
    }
  ]
