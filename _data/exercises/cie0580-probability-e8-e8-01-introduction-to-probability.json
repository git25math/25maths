      "id": "E8-01-Q1",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "A box contains $n$ red sweets, 4 blue sweets and 2 green sweets.\nThe probability of picking a red sweet at random is $\\frac{1}{3}$.\nFind the value of $n$.",
      "answerType": "integer",
      "correctAnswer": "3",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "n / (n + 4 + 2) = 1/3" },
        { "mark": "M1", "desc": "3n = n + 6 leading to 2n = 6" },
        { "mark": "A1", "desc": "n = 3" }
      ],
      "workingSteps": [
        "Total sweets = n + 4 + 2 = n + 6",
        "n / (n + 6) = 1/3",
        "3n = n + 6",
        "2n = 6",
        "n = 3"
      ],
      "explanation": "Set up an equation using the probability formula and solve for n."
    },
    {
      "id": "E8-01-Q2",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "The Venn diagram shows the number of students who study French (F) and German (G) in a class of 30 students.\n12 study French, 15 study German and 5 study both.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the number of students who study neither French nor German.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "8",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "F only = 7, G only = 10, Both = 5 → total in F∪G = 22" },
            { "mark": "A1", "desc": "30 − 22 = 8" }
          ],
          "workingSteps": [
            "F only = 12 − 5 = 7",
            "G only = 15 − 5 = 10",
            "F ∪ G = 7 + 5 + 10 = 22",
            "Neither = 30 − 22 = 8"
          ]
        },
        {
          "label": "b",
          "questionText": "A student is chosen at random.\nFind the probability that the student studies French but not German.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "7/30",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "F only = 12 − 5 = 7 soi" },
            { "mark": "A1", "desc": "7/30" }
          ],
          "workingSteps": [
            "F only = 12 − 5 = 7",
            "P(F but not G) = 7/30"
          ]
        },
        {
          "label": "c",
          "questionText": "Two students are chosen at random.\nFind the probability that both study German.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "7/29",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "P(1st G) = 15/30" },
            { "mark": "M1", "desc": "P(2nd G | 1st G) = 14/29 (without replacement)" },
            { "mark": "M1", "desc": "15/30 × 14/29" },
            { "mark": "A1", "desc": "210/870 = 7/29" }
          ],
          "workingSteps": [
            "P(both G) = 15/30 × 14/29 = 210/870 = 7/29"
          ]
        }
      ]
    },
    {
      "id": "E8-01-Q3",
      "type": "structured",
      "totalMarks": 4,
      "difficulty": "hard",
      "context": "A bag contains 3 red marbles and $n$ blue marbles.\nTwo marbles are taken at random without replacement.\nThe probability that both marbles are blue is $\\frac{5}{14}$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Show that $3n^2 - 13n - 10 = 0$.",
          "marks": 2,
          "commandWord": "show",
          "answerType": "show-that",
          "correctAnswer": "3n² − 13n − 10 = 0",
          "markScheme": [
            { "mark": "M1", "desc": "n/(n+3) × (n−1)/(n+2) = 5/14" },
            { "mark": "A1", "desc": "14n(n−1) = 5(n+3)(n+2) → 14n²−14n = 5n²+25n+30 → 3n²−13n−10 = 0 with no errors" }
          ],
          "workingSteps": [
            "P(BB) = n/(n+3) × (n−1)/(n+2) = 5/14",
            "14n(n−1) = 5(n+3)(n+2)",
            "14n² − 14n = 5n² + 25n + 30",
            "9n² − 39n − 30 = 0",
            "3n² − 13n − 10 = 0"
          ]
        },
        {
          "label": "b",
          "questionText": "Solve $3n^2 - 13n - 10 = 0$ and hence find the number of blue marbles.",
          "marks": 2,
          "commandWord": "solve",
          "answerType": "integer",
          "correctAnswer": "5",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "(3n+2)(n−5) = 0" },
            { "mark": "A1", "desc": "n = 5 (rejecting n = −2/3 as n must be a positive integer)" }
          ],
          "workingSteps": [
            "(3n + 2)(n − 5) = 0",
            "n = −2/3 or n = 5",
            "n must be a positive integer, so n = 5"
          ]
        }
      ]
    },
    {
      "id": "E8-01-Q4",
      "type": "short-answer",
      "totalMarks": 4,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "Events A and B are such that $P(A) = 0.4$, $P(B) = 0.5$ and $P(A \\cup B) = 0.7$.\nCalculate\n(a) $P(A \\cap B)$\n(b) whether A and B are independent.",
      "answerType": "numeric",
      "correctAnswer": "0.2",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "P(A∪B) = P(A) + P(B) − P(A∩B)" },
        { "mark": "A1", "desc": "(a) P(A∩B) = 0.4 + 0.5 − 0.7 = 0.2" },
        { "mark": "M1", "desc": "(b) P(A) × P(B) = 0.4 × 0.5 = 0.2" },
        { "mark": "A1", "desc": "P(A∩B) = P(A)×P(B), so A and B are independent" }
      ],
      "workingSteps": [
        "(a) P(A∩B) = P(A) + P(B) − P(A∪B) = 0.4 + 0.5 − 0.7 = 0.2",
        "(b) P(A) × P(B) = 0.4 × 0.5 = 0.2 = P(A∩B)",
        "Since P(A∩B) = P(A) × P(B), A and B are independent"
      ],
      "explanation": "Use the addition rule, then check the independence condition."
    }
  ]
