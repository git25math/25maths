      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Completing the square: $(x-3)^2-9+8$" },
        { "mark": "A1", "desc": "(a) $(x-3)^2-1$" },
        { "mark": "B1", "desc": "(b) Turning point $(3,-1)$" },
        { "mark": "B1", "desc": "(c) $x=3$" },
        { "mark": "M1", "desc": "(d) $(x-3)^2=1 \\Rightarrow x-3=\\pm1$" },
        { "mark": "A1", "desc": "(d) $x=2$ and $x=4$" }
      ],
      "workingSteps": [
        "(a) $y=x^2-6x+8=(x-3)^2-9+8=(x-3)^2-1$",
        "(b) Turning point at $(3,-1)$ (minimum since coefficient of $x^2$ is positive)",
        "(c) Line of symmetry: $x=3$",
        "(d) $(x-3)^2-1=0 \\Rightarrow (x-3)^2=1 \\Rightarrow x-3=\\pm1$; $x=4$ or $x=2$"
      ],
