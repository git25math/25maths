      "difficulty": "medium",
      "questionText": "Expand and simplify $(2x - 3)^2 - (x + 4)(x - 2)$.",
      "answerType": "expression",
      "correctAnswer": "$3x^2 - 14x + 17$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "$(2x-3)^2 = 4x^2 - 12x + 9$ seen" },
        { "mark": "M1", "desc": "$(x+4)(x-2) = x^2 + 2x - 8$ seen" },
        { "mark": "A1", "desc": "$3x^2 - 14x + 17$ cao" }
      ],
      "workingSteps": [
        "$(2x - 3)^2 = 4x^2 - 12x + 9$",
        "$(x + 4)(x - 2) = x^2 - 2x + 4x - 8 = x^2 + 2x - 8$",
        "$4x^2 - 12x + 9 - (x^2 + 2x - 8) = 4x^2 - 12x + 9 - x^2 - 2x + 8$",
        "$= 3x^2 - 14x + 17$",
        "Check $x=0$: $(0-3)^2-(4)(-2)=9+8=17$; answer: $3(0)-14(0)+17=17$ ✓"
      ],
      "explanation": "Expand each bracket carefully, then subtract the second expression, being careful with sign changes."
    },
