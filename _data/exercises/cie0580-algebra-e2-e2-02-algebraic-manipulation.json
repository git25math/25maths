      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "Common factor of 3 extracted: $3(x^2 - 4x - 12)$" },
        { "mark": "M1", "desc": "Attempt to factorise $x^2 - 4x - 12$: two numbers with product $-12$ and sum $-4$" },
        { "mark": "A1", "desc": "$3(x - 6)(x + 2)$ cao" }
      ],
      "workingSteps": [
        "$3x^2 - 12x - 36 = 3(x^2 - 4x - 12)$",
        "Find two numbers with product $-12$ and sum $-4$: $-6$ and $+2$",
        "$x^2 - 4x - 12 = (x - 6)(x + 2)$",
        "Answer: $3(x - 6)(x + 2)$",
        "Check: $3(x-6)(x+2)=3(x^2-4x-12)=3x^2-12x-36$ ✓"
      ],
      "explanation": "Extract the HCF first, then factorise the quadratic using the product-sum method."
