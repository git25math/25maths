      "id": "E2-02-Q1",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "factorise",
      "difficulty": "medium",
      "questionText": "Factorise completely $3x^2 - 12x - 36$.",
      "answerType": "expression",
      "correctAnswer": "$3(x-6)(x+2)$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "Common factor of 3 extracted: $3(x^2 - 4x - 12)$" },
        { "mark": "M1", "desc": "Attempt to factorise $x^2 - 4x - 12$ into two brackets" },
        { "mark": "A1", "desc": "$3(x - 6)(x + 2)$ cao" }
      ],
      "workingSteps": [
        "3x² − 12x − 36 = 3(x² − 4x − 12)",
        "Find two numbers with product −12 and sum −4: −6 and +2",
        "x² − 4x − 12 = (x − 6)(x + 2)",
        "= 3(x − 6)(x + 2)"
      ],
      "explanation": "Extract the HCF first, then factorise the quadratic."
    },
    {
      "id": "E2-02-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "simplify",
      "difficulty": "medium",
      "questionText": "Simplify $\\dfrac{x^2 - 9}{x^2 + x - 6}$.",
      "answerType": "expression",
      "correctAnswer": "$\\dfrac{x+3}{x+2}$... wait — $\\dfrac{x-3}{x-2}$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Factorise numerator: $(x-3)(x+3)$" },
        { "mark": "M1", "desc": "Factorise denominator: $(x+3)(x-2)$" },
        { "mark": "A1", "desc": "$\\dfrac{x-3}{x-2}$ cao" }
      ],
      "workingSteps": [
        "Numerator: x² − 9 = (x − 3)(x + 3)",
        "Denominator: x² + x − 6; find two numbers with product −6 and sum +1: +3 and −2",
        "x² + x − 6 = (x + 3)(x − 2)",
        "Fraction = (x − 3)(x + 3) / [(x + 3)(x − 2)] = (x − 3)/(x − 2)"
      ],
      "explanation": "Factorise both numerator and denominator, then cancel the common factor (x + 3)."
    },
    {
      "id": "E2-02-Q3",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "expand",
      "difficulty": "medium",
      "questionText": "Expand and simplify $(2x - 3)^2 - (x + 4)(x - 2)$.",
      "answerType": "expression",
      "correctAnswer": "$3x^2 - 15x + 17$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "$(2x-3)^2 = 4x^2 - 12x + 9$ seen" },
        { "mark": "M1", "desc": "$(x+4)(x-2) = x^2 + 2x - 8$ seen" },
        { "mark": "A1", "desc": "$3x^2 - 14x + 17$ cao" }
      ],
      "workingSteps": [
        "(2x − 3)² = 4x² − 12x + 9",
        "(x + 4)(x − 2) = x² − 2x + 4x − 8 = x² + 2x − 8",
        "4x² − 12x + 9 − (x² + 2x − 8)",
        "= 4x² − 12x + 9 − x² − 2x + 8",
        "= 3x² − 14x + 17"
      ],
      "explanation": "Expand each bracket carefully then subtract, taking care with signs."
    },
    {
      "id": "E2-02-Q4",
      "type": "structured",
      "totalMarks": 9,
      "difficulty": "hard",
      "context": null,
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Factorise $2x^2 + 7x + 3$.",
          "marks": 2,
          "commandWord": "factorise",
          "answerType": "expression",
          "correctAnswer": "$(2x + 1)(x + 3)$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Correct method: ac = 6, pair summing to 7 found (1 and 6)" },
            { "mark": "A1", "desc": "$(2x + 1)(x + 3)$ cao" }
          ],
          "workingSteps": [
            "ac = 2 × 3 = 6; find two numbers with product 6 and sum 7: 1 and 6",
            "2x² + x + 6x + 3 = x(2x + 1) + 3(2x + 1)",
            "= (2x + 1)(x + 3)"
          ]
        },
        {
          "label": "b",
          "questionText": "Hence, or otherwise, solve $2x^2 + 7x + 3 = 0$.",
          "marks": 2,
          "commandWord": "solve",
          "answerType": "expression",
          "correctAnswer": "$x = -\\frac{1}{2}$ or $x = -3$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Setting their factors equal to zero" },
            { "mark": "A1", "desc": "$x = -\\frac{1}{2}$ and $x = -3$ cao" }
          ],
          "workingSteps": [
            "(2x + 1)(x + 3) = 0",
            "2x + 1 = 0 → x = −1/2",
            "x + 3 = 0 → x = −3"
          ]
        },
        {
          "label": "c",
          "questionText": "Make $r$ the subject of the formula $A = \\pi r^2 + 2\\pi r h$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$r = \\dfrac{-2\\pi h + \\sqrt{4\\pi^2 h^2 + 4\\pi A}}{2\\pi}$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Rearranged to $\\pi r^2 + 2\\pi h r - A = 0$" },
            { "mark": "M1", "desc": "Quadratic formula applied with $a = \\pi$, $b = 2\\pi h$, $c = -A$" },
            { "mark": "A1", "desc": "$r = \\dfrac{-2\\pi h + \\sqrt{4\\pi^2 h^2 + 4\\pi A}}{2\\pi}$ oe (positive root)" }
          ],
          "workingSteps": [
            "A = πr² + 2πrh",
            "πr² + 2πhr − A = 0",
            "Using quadratic formula: r = [−2πh ± √(4π²h² + 4πA)] / (2π)",
            "Taking positive root: r = [−2πh + √(4π²h² + 4πA)] / (2π)",
            "= [−πh + √(π²h² + πA)] / π"
          ]
        },
        {
          "label": "d",
          "questionText": "Find the value of $r$ when $A = 60$ and $h = 4$.\nGive your answer correct to 2 decimal places.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "2.46",
          "tolerance": 0.01,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Correct substitution into their formula from (c)" },
            { "mark": "A1", "desc": "2.46 (2dp)" }
          ],
          "workingSteps": [
            "πr² + 2π(4)r − 60 = 0",
            "πr² + 8πr − 60 = 0",
            "r = [−8π + √(64π² + 240π)] / (2π)",
            "= [−25.13 + √(1973.9 + 753.98)] / (6.283)",
            "= [−25.13 + √2727.9] / 6.283",
            "= [−25.13 + 52.23] / 6.283",
            "= 27.10 / 6.283 = 4.31"
          ]
        }
      ]
    },
    {
