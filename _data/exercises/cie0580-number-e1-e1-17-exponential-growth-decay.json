      "difficulty": "medium",
      "questionText": "A population of bacteria doubles every 3 hours.\nThe initial population is $500$.\nCalculate the population after 12 hours.",
      "answerType": "integer",
      "correctAnswer": "8000",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Number of doublings $= 12 \\div 3 = 4$" },
        { "mark": "M1", "desc": "Population $= 500 \\times 2^4$" },
        { "mark": "A1", "desc": "$500 \\times 16 = 8000$ cao" }
      ],
      "workingSteps": [
        "Doublings in 12 hours: $12 \\div 3 = 4$",
        "Population $= 500 \\times 2^4 = 500 \\times 16 = 8000$"
      ],
      "explanation": "Exponential growth: $P = P_0 \\times r^t$ where $r$ is the growth factor."
