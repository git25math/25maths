      "type": "short-answer",
      "totalMarks": 2,
      "commandWord": "simplify",
      "difficulty": "easy",
      "questionText": "Simplify $\\dfrac{12x^3 y^2}{4x y^5}$.",
      "answerType": "expression",
      "correctAnswer": "$\\dfrac{3x^2}{y^3}$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "Coefficient $\\frac{12}{4} = 3$ and $x^{3-1} = x^2$ seen" },
        { "mark": "B1", "desc": "$\\dfrac{3x^2}{y^3}$ cao" }
      ],
      "workingSteps": [
        "Coefficient: $12 \\div 4 = 3$",
        "$x$ index: $3 - 1 = 2$, giving $x^2$",
        "$y$ index: $2 - 5 = -3$, giving $y^{-3} = \\dfrac{1}{y^3}$",
        "Answer: $\\dfrac{3x^2}{y^3}$"
      ],
      "explanation": "Apply index laws: divide coefficients and subtract indices for each variable."
    },
    {
      "id": "E2-01-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "expand",
      "difficulty": "medium",
      "questionText": "Expand and simplify $(3x - 2)(x + 5) - x(x - 1)$.",
      "answerType": "expression",
      "correctAnswer": "$2x^2 + 14x - 10$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "$(3x-2)(x+5) = 3x^2 + 13x - 10$ seen" },
        { "mark": "M1", "desc": "Subtracting $x(x-1) = x^2 - x$ correctly" },
        { "mark": "A1", "desc": "$2x^2 + 14x - 10$ cao" }
      ],
      "workingSteps": [
        "$(3x - 2)(x + 5) = 3x^2 + 15x - 2x - 10 = 3x^2 + 13x - 10$",
        "$x(x - 1) = x^2 - x$",
        "$3x^2 + 13x - 10 - (x^2 - x) = 3x^2 + 13x - 10 - x^2 + x = 2x^2 + 14x - 10$",
        "Verify: substitute $x = 1$: LHS $= (1)(-6+5) = (1)(1) - ...$; check: $2(1)+14-10=6$; $(3-2)(6)-1(0)=6$ ✓"
      ],
      "explanation": "Expand each bracket then subtract — note the sign change when removing the second bracket."
    },
    {
      "id": "E2-01-Q3",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "factorise",
      "difficulty": "medium",
      "questionText": "Factorise completely $6x^2 - 54$.",
      "answerType": "expression",
      "correctAnswer": "$6(x - 3)(x + 3)$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "Common factor of 6 extracted: $6(x^2 - 9)$" },
        { "mark": "M1", "desc": "Difference of two squares applied to $x^2 - 9$" },
        { "mark": "A1", "desc": "$6(x - 3)(x + 3)$ cao" }
      ],
      "workingSteps": [
        "$6x^2 - 54 = 6(x^2 - 9)$",
        "$x^2 - 9 = (x - 3)(x + 3)$ (difference of two squares: $9 = 3^2$)",
        "Answer: $6(x - 3)(x + 3)$",
        "Check: $6(x-3)(x+3) = 6(x^2-9) = 6x^2-54$ ✓"
      ],
      "explanation": "Extract the highest common factor first, then recognise the difference of two squares."
    },
