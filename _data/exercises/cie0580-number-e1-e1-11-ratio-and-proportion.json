    {
      "id": "E1-11-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "hard",
      "questionText": "It takes 6 workers 10 days to build a wall.\nHow long would it take 4 workers to build the same wall?\n(Assume all workers work at the same rate.)",
      "answerType": "integer",
      "correctAnswer": "15",
      "tolerance": null,
      "unit": "days",
      "markScheme": [
        { "mark": "M1", "desc": "Inverse proportion: more workers → fewer days" },
        { "mark": "M1", "desc": "Total work $= 6 \\times 10 = 60$ worker-days; time $= 60 \\div 4$" },
        { "mark": "A1", "desc": "$15$ days cao" }
      ],
      "workingSteps": [
        "Total work $= 6 \\times 10 = 60$ worker-days",
        "Time for 4 workers $= 60 \\div 4 = 15$ days"
      ],
      "explanation": "This is inverse proportion: workers × days = constant."
    },
    {
      "id": "E1-11-Q3",
      "type": "structured",
      "totalMarks": 4,
      "difficulty": "hard",
      "context": "The quantities $y$ and $x$ are in direct proportion.\nWhen $x = 4$, $y = 20$.",
