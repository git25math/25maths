      "questionText": "Write these in order from smallest to largest:\n$$\\dfrac{5}{8}, \\quad 0.63, \\quad 60\\%, \\quad \\dfrac{7}{12}$$",
      "answerType": "expression",
      "correctAnswer": "$\\dfrac{7}{12}, \\quad 0.60, \\quad 0.625, \\quad 0.63$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Converts all to decimals: $5/8 = 0.625$; $60\\% = 0.6$; $7/12 = 0.58\\overline{3}$" },
        { "mark": "M1", "desc": "Correct ordering of decimal equivalents" },
        { "mark": "A1", "desc": "$\\dfrac{7}{12}, 60\\%, \\dfrac{5}{8}, 0.63$ cao" }
      ],
      "workingSteps": [
        "$\\dfrac{5}{8} = 0.625$",
        "$0.63 = 0.63$",
        "$60\\% = 0.60$",
        "$\\dfrac{7}{12} = 0.58\\overline{3}$",
        "Order: $0.583... < 0.60 < 0.625 < 0.63$",
        "So: $\\dfrac{7}{12} < 60\\% < \\dfrac{5}{8} < 0.63$"
      ],
      "explanation": "Convert all to the same form (decimals) before comparing."
    },
