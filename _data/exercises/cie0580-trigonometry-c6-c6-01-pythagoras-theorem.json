      "totalMarks": 2,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "A right-angled triangle has shorter sides of length 6 cm and 8 cm.\nCalculate the length of the hypotenuse.",
      "answerType": "integer",
      "correctAnswer": "10",
      "tolerance": null,
      "unit": "cm",
      "markScheme": [
        { "mark": "M1", "desc": "6² + 8² or 36 + 64 soi" },
        { "mark": "A1", "desc": "10" }
      ],
      "workingSteps": [
        "c² = 6² + 8² = 36 + 64 = 100",
        "c = √100 = 10 cm"
      ],
      "explanation": "Use Pythagoras: c² = a² + b²."
    },
    {
      "id": "C6-01-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "A right-angled triangle has hypotenuse 13 cm and one shorter side 5 cm.\nCalculate the length of the other shorter side.",
      "answerType": "integer",
      "correctAnswer": "12",
      "tolerance": null,
      "unit": "cm",
      "markScheme": [
        { "mark": "M1", "desc": "13² − 5² or 169 − 25 soi" },
        { "mark": "M1", "desc": "√144" },
        { "mark": "A1", "desc": "12" }
      ],
      "workingSteps": [
        "a² = 13² − 5² = 169 − 25 = 144",
        "a = √144 = 12 cm"
      ],
      "explanation": "Rearrange Pythagoras to find a shorter side: a² = c² − b²."
    },
    {
      "id": "C6-01-Q3",
