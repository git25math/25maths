      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "A rectangle has length 15 cm and width 8 cm.\nCalculate the length of a diagonal of the rectangle.",
      "answerType": "integer",
      "correctAnswer": "17",
      "tolerance": null,
      "unit": "cm",
      "markScheme": [
        { "mark": "M1", "desc": "15² + 8² soi" },
        { "mark": "M1", "desc": "√(225 + 64) or √289" },
        { "mark": "A1", "desc": "17" }
      ],
      "workingSteps": [
        "d² = 15² + 8² = 225 + 64 = 289",
        "d = √289 = 17 cm"
      ],
      "explanation": "The diagonal of a rectangle forms a right-angled triangle."
