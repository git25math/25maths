      "id": "H3-03-Q1",
      "type": "structured",
      "totalMarks": 10,
      "difficulty": "medium",
      "context": "The graph of $y = f(x)$ passes through the points $(0, 3)$ and $(2, 0)$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Describe the transformation that maps the graph of $y = f(x)$ onto the graph of $y = f(x) + 2$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Translation by vector (0, 2) — the graph moves 2 units upward.",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Translation stated" },
            { "mark": "B1", "desc": "2 units upward (in the positive y-direction) oe" }
          ],
          "workingSteps": [
            "y = f(x) + 2 shifts every y-value up by 2",
            "This is a translation by the vector (0, 2)"
          ]
        },
        {
          "label": "b",
          "questionText": "Write down the coordinates of the point that $(0, 3)$ maps to under the transformation $y = f(x) + 2$.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "coordinate",
          "correctAnswer": "(0, 5)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "(0, 5)" }
          ],
          "workingSteps": [
            "y increases by 2: (0, 3) → (0, 5)"
          ]
        },
        {
          "label": "c",
          "questionText": "Describe the transformation that maps the graph of $y = f(x)$ onto the graph of $y = f(x - 3)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Translation by vector (3, 0) — the graph moves 3 units to the right.",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Translation stated" },
            { "mark": "B1", "desc": "3 units to the right (in the positive x-direction) oe" }
          ],
          "workingSteps": [
            "y = f(x − 3) replaces x with x − 3, shifting the graph 3 units to the right",
            "Translation by vector (3, 0)"
          ]
        },
        {
          "label": "d",
          "questionText": "Write down the coordinates of the point that $(2, 0)$ maps to under the transformation $y = f(x - 3)$.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "coordinate",
          "correctAnswer": "(5, 0)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "(5, 0)" }
          ],
          "workingSteps": [
            "x increases by 3: (2, 0) → (5, 0)"
          ]
        },
        {
          "label": "e",
          "questionText": "Describe the transformation that maps the graph of $y = f(x)$ onto the graph of $y = -f(x)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Reflection in the x-axis.",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Reflection stated" },
            { "mark": "B1", "desc": "In the x-axis oe" }
          ],
          "workingSteps": [
            "y = −f(x) negates all y-values",
            "This is a reflection in the x-axis"
          ]
        },
        {
          "label": "f",
          "questionText": "Describe the transformation that maps $y = f(x)$ onto $y = f(2x)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Stretch parallel to the x-axis, scale factor ½.",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Stretch (horizontal) stated" },
            { "mark": "B1", "desc": "Scale factor ½ in the x-direction oe" }
          ],
          "workingSteps": [
            "y = f(2x) compresses the graph horizontally",
            "Every x-coordinate is halved: stretch parallel to the x-axis, scale factor ½"
          ]
        }
      ]
    },
    {
      "id": "H3-03-Q2",
      "type": "structured",
      "totalMarks": 9,
      "difficulty": "medium",
      "context": "The table below shows some values of $y = x^3 - 4x$ for $-3 \\leq x \\leq 3$.\n\n| $x$ | −3 | −2 | −1 | 0 | 1 | 2 | 3 |\n|---|---|---|---|---|---|---|---|\n| $y$ | −15 | 0 | | 0 | | 0 | 15 |",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Complete the table of values.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "table-fill",
          "correctAnswer": ["3", "-3"],
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "y = 3 when x = −1" },
            { "mark": "B1", "desc": "y = −3 when x = 1" }
          ],
          "workingSteps": [
            "x = −1: y = (−1)³ − 4(−1) = −1 + 4 = 3",
            "x = 1: y = 1³ − 4(1) = 1 − 4 = −3"
          ]
        },
        {
          "label": "b",
          "questionText": "On the grid, draw the graph of $y = x^3 - 4x$ for $-3 \\leq x \\leq 3$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "draw",
          "correctAnswer": "smooth cubic curve through all seven points",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "At least five points correctly plotted" },
            { "mark": "A1", "desc": "Smooth cubic curve through all seven points in the correct domain" }
          ],
          "workingSteps": [
            "Plot all seven points including (−1, 3) and (1, −3)",
            "Draw a smooth S-shaped cubic curve"
          ]
        },
        {
          "label": "c",
          "questionText": "Use your graph to find the solutions of $x^3 - 4x = 2$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x ≈ −2.2, x ≈ −0.5, x ≈ 2.2 (allow ±0.1)",
          "tolerance": 0.15,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Draws line y = 2 on the graph" },
            { "mark": "A1", "desc": "Two correct x-values from intersections (±0.1 tolerance each)" },
            { "mark": "A1", "desc": "All three correct x-values cao (±0.1)" }
          ],
          "workingSteps": [
            "Draw the horizontal line y = 2 on the graph",
            "Find where y = x³ − 4x crosses y = 2",
            "Intersections at approximately x ≈ −2.2, x ≈ −0.5, x ≈ 2.2"
          ]
        },
        {
          "label": "d",
          "questionText": "Write down the coordinates of the local maximum point of the curve.",
          "marks": 2,
          "commandWord": "write-down",
          "answerType": "coordinate",
          "correctAnswer": "(−1.15, 3.08)",
          "tolerance": 0.1,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "x-coordinate between −1.5 and −0.8" },
            { "mark": "B1", "desc": "y-coordinate between 2.5 and 3.5 ft from graph" }
          ],
          "workingSteps": [
            "The local maximum is the peak on the left side of the curve",
            "dy/dx = 3x² − 4 = 0 → x = −√(4/3) ≈ −1.15",
            "y ≈ (−1.15)³ − 4(−1.15) ≈ −1.52 + 4.62 ≈ 3.08"
          ]
        }
      ]
    },
    {
      "id": "H3-03-Q3",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "The equation of a curve is $y = 2x^2 - 5x + 1$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the coordinates of the $y$-intercept.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "coordinate",
          "correctAnswer": "(0, 1)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "(0, 1)" }
          ],
          "workingSteps": [
            "When x = 0: y = 0 − 0 + 1 = 1",
            "y-intercept: (0, 1)"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the $x$-coordinates where the curve crosses the $x$-axis.\nGive your answers correct to 2 decimal places.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x = 0.22 or x = 2.28",
          "tolerance": 0.005,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Sets 2x² − 5x + 1 = 0 and applies quadratic formula" },
            { "mark": "A1", "desc": "x = (5 ± √17)/4" },
            { "mark": "A1", "desc": "x = 0.22 and x = 2.28 (both to 2 d.p.) cao" }
          ],
          "workingSteps": [
            "2x² − 5x + 1 = 0",
            "x = (5 ± √(25 − 8)) / 4 = (5 ± √17) / 4",
            "√17 = 4.123...",
            "x = (5 + 4.123) / 4 = 9.123/4 = 2.28 (2 d.p.)",
            "x = (5 − 4.123) / 4 = 0.877/4 = 0.22 (2 d.p.)"
          ]
        },
        {
          "label": "c",
          "questionText": "Find the equation of the line of symmetry of the curve.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x = 1.25",
          "tolerance": 0.01,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Uses x = −b/(2a) = 5/4 or midpoint of roots" },
            { "mark": "A1", "desc": "x = 5/4 or x = 1.25 cao" }
          ],
          "workingSteps": [
            "Line of symmetry: x = −b/(2a) = −(−5)/(2×2) = 5/4 = 1.25",
            "Or: midpoint of roots = (0.22 + 2.28)/2 = 2.5/2 = 1.25"
          ]
        },
        {
          "label": "d",
          "questionText": "Work out the minimum value of $y$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "-2.125",
          "tolerance": 0.01,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes x = 1.25 into y = 2x² − 5x + 1" },
            { "mark": "A1", "desc": "y = −2.125 or −17/8 cao" }
          ],
          "workingSteps": [
            "x = 1.25 at minimum",
            "y = 2(1.25)² − 5(1.25) + 1 = 2(1.5625) − 6.25 + 1 = 3.125 − 6.25 + 1 = −2.125"
          ]
        }
      ]
    }
  ]
