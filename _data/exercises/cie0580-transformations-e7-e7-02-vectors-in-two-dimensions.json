    {
      "id": "E7-02-Q3",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "$\\mathbf{p} = \\begin{pmatrix} 4 \\\\ -3 \\end{pmatrix}$ and $\\mathbf{q} = \\begin{pmatrix} 1 \\\\ 2 \\end{pmatrix}$.\nFind the vector $\\mathbf{r}$ such that $\\mathbf{p} + 2\\mathbf{r} = \\mathbf{q}$.",
      "answerType": "vector",
      "correctAnswer": "(−3/2, 5/2)",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "2r = q − p = (1−4, 2−(−3)) = (−3, 5)"
        },
        {
          "mark": "M1",
          "desc": "r = (−3/2, 5/2)"
        },
        {
          "mark": "A1",
          "desc": "(−1.5, 2.5)"
        }
      ],
      "workingSteps": [
        "2r = q − p = (−3, 5)",
        "r = (−3/2, 5/2) = (−1.5, 2.5)"
      ],
      "explanation": "Rearrange to isolate r, then divide by 2."
    },
    {
      "id": "E7-02-Q4",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "show",
      "difficulty": "medium",
      "questionText": "$\\mathbf{a} = \\begin{pmatrix} 2 \\\\ 6 \\end{pmatrix}$ and $\\mathbf{b} = \\begin{pmatrix} -3 \\\\ -9 \\end{pmatrix}$.\nShow that $\\mathbf{a}$ and $\\mathbf{b}$ are parallel.",
      "answerType": "show-that",
      "correctAnswer": "b = −3/2 × a",
      "markScheme": [
        {
          "mark": "M1",
          "desc": "b = k × a for some scalar k"
        },
        {
          "mark": "M1",
          "desc": "−3/2 = −3/2 and −9/6 = −3/2"
        },
        {
          "mark": "A1",
          "desc": "b = −3/2 × a, so parallel"
        }
      ],
      "workingSteps": [
        "b = (−3, −9) = −3/2 × (2, 6) = −3/2 × a",
        "Since b is a scalar multiple of a, they are parallel"
      ],
      "explanation": "Two vectors are parallel if one is a scalar multiple of the other."
    }
