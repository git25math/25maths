      "questionText": "$\\mathbf{a} = \\begin{pmatrix} 3 \\\\ -1 \\end{pmatrix}$ and $\\mathbf{b} = \\begin{pmatrix} -2 \\\\ 5 \\end{pmatrix}$.\nFind $2\\mathbf{a} + \\mathbf{b}$.",
      "answerType": "vector",
      "correctAnswer": "(4, 3)",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "2a = (6, −2)"
        },
        {
          "mark": "M1",
          "desc": "(6,−2) + (−2,5)"
        },
        {
          "mark": "A1",
          "desc": "(4, 3)"
        }
      ],
      "workingSteps": [
        "2a = (6, −2)",
        "2a + b = (6−2, −2+5) = (4, 3)"
      ],
      "explanation": "Scalar multiplication then addition, component by component."
    },
    {
      "id": "E7-02-Q2",
