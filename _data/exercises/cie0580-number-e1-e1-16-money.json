        { "mark": "M1", "desc": "Correct division" },
        { "mark": "A1", "desc": "$\\$440$ cao" }
      ],
      "workingSteps": [
        "Price after VAT $=$ original $\\times 1.20 = 528$",
        "Original $= 528 \\div 1.20 = \\$440$"
      ],
      "explanation": "This is a reverse percentage: divide by the multiplier."
    },
