      "id": "E4-03-Q1",
      "type": "short-answer",
      "totalMarks": 2,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "A map has a scale of 1 : 50 000.\nTwo towns are 7.4 cm apart on the map.\nCalculate the actual distance between the towns in kilometres.",
      "answerType": "numeric",
      "correctAnswer": "3.7",
      "tolerance": 0,
      "unit": "km",
      "markScheme": [
        { "mark": "M1", "desc": "7.4 × 50 000 = 370 000 cm soi" },
        { "mark": "A1", "desc": "3.7 km" }
      ],
      "workingSteps": [
        "Actual distance = 7.4 cm × 50 000 = 370 000 cm",
        "Convert: 370 000 cm ÷ 100 000 = 3.7 km"
      ],
      "explanation": "Multiply the map distance by the scale factor, then convert units."
    },
    {
      "id": "E4-03-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "A scale drawing uses a scale of 1 cm : 4 m.\nA room is 6.5 m long and 4.2 m wide.\nCalculate the dimensions of the room on the scale drawing.",
      "answerType": "explain",
      "correctAnswer": "Length = 1.625 cm, Width = 1.05 cm",
      "markScheme": [
        { "mark": "M1", "desc": "Divide actual lengths by 4" },
        { "mark": "A1", "desc": "Length = 6.5 ÷ 4 = 1.625 cm" },
        { "mark": "A1", "desc": "Width = 4.2 ÷ 4 = 1.05 cm" }
      ],
      "workingSteps": [
        "Scale: 1 cm represents 4 m",
        "Length on drawing = 6.5 ÷ 4 = 1.625 cm",
        "Width on drawing = 4.2 ÷ 4 = 1.05 cm"
      ],
      "explanation": "Divide actual lengths by the scale factor to find drawing dimensions."
    },
    {
      "id": "E4-03-Q3",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": "A ship sails 30 km due north from port P to point A, then 40 km due east from A to point B.\nA scale drawing is made with a scale of 1 cm : 10 km.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write down the length PA and the length AB on the scale drawing.",
          "marks": 2,
          "commandWord": "write-down",
          "answerType": "explain",
          "correctAnswer": "PA = 3 cm, AB = 4 cm",
          "markScheme": [
            { "mark": "B1", "desc": "PA = 3 cm" },
            { "mark": "B1", "desc": "AB = 4 cm" }
          ],
          "workingSteps": [
            "PA = 30 ÷ 10 = 3 cm",
            "AB = 40 ÷ 10 = 4 cm"
          ]
        },
        {
          "label": "b",
          "questionText": "Calculate the actual straight-line distance from P to B.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "integer",
          "correctAnswer": "50",
          "tolerance": null,
          "unit": "km",
          "markScheme": [
            { "mark": "M1", "desc": "PB² = 30² + 40²" },
            { "mark": "M1", "desc": "= 900 + 1600 = 2500" },
            { "mark": "A1", "desc": "PB = 50 km" }
          ],
          "workingSteps": [
            "Triangle PAB is right-angled at A",
            "PB² = PA² + AB² = 30² + 40² = 900 + 1600 = 2500",
            "PB = √2500 = 50 km"
          ]
        },
        {
          "label": "c",
          "questionText": "Find the bearing of B from P, giving your answer to the nearest degree.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "053",
          "tolerance": null,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "tan(angle) = 40/30 → angle = 53.13...°" },
            { "mark": "A1", "desc": "Bearing = 053° (nearest degree)" }
          ],
          "workingSteps": [
            "tan(APB) = AB/PA = 40/30",
            "Angle APB = arctan(4/3) = 53.13°",
            "Bearing of B from P = 000° + 53° = 053°"
          ]
        }
      ]
    }
  ]
