      "commandWord": "write-down",
      "difficulty": "easy",
      "questionText": "Write the ratio $24 : 36$ in its simplest form.",
      "answerType": "expression",
      "correctAnswer": "$2 : 3$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Divides both by 12 (HCF)" },
        { "mark": "A1", "desc": "$2 : 3$ cao" }
      ],
      "workingSteps": [
        "HCF of 24 and 36 is 12",
        "$24 \\div 12 = 2$, $36 \\div 12 = 3$",
        "Ratio $= 2 : 3$"
      ],
      "explanation": "Divide both parts of the ratio by their highest common factor."
    },
    {
      "id": "C1-11-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "Share $\\$84$ in the ratio $3 : 4$.\nCalculate each share.",
      "answerType": "table-fill",
      "correctAnswer": ["36", "48"],
      "tolerance": null,
      "unit": "$",
      "markScheme": [
        { "mark": "M1", "desc": "Total parts: $3 + 4 = 7$" },
        { "mark": "M1", "desc": "One part: $84 \\div 7 = 12$" },
        { "mark": "A1", "desc": "Shares: $\\$36$ and $\\$48$" }
      ],
      "workingSteps": [
        "Total parts: $3 + 4 = 7$",
        "Value of 1 part: $84 \\div 7 = \\$12$",
        "First share: $3 \\times 12 = \\$36$",
        "Second share: $4 \\times 12 = \\$48$"
      ],
      "explanation": "Find the value of one part, then multiply by each ratio amount."
    },
    {
      "id": "C1-11-Q3",
      "type": "structured",
      "totalMarks": 5,
