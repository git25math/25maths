      "context": "A map has a scale of $1 : 50000$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "On the map, a road is $6$ cm long.\nCalculate the actual length of the road in km.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "integer",
          "correctAnswer": "3",
          "tolerance": null,
          "unit": "km",
          "markScheme": [
            { "mark": "M1", "desc": "$6 \\times 50000 = 300000$ cm" },
            { "mark": "M1", "desc": "Convert to km: $\\div 100000$" },
            { "mark": "A1", "desc": "$3$ km cao" }
          ],
          "workingSteps": [
            "Actual length $= 6 \\times 50000 = 300000$ cm",
            "$300000 \\div 100000 = 3$ km"
          ]
        },
        {
          "label": "b",
          "questionText": "A lake has actual area $0.8$ km².\nCalculate the area of the lake on the map in cm².",
          "marks": 2,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "3.2",
          "tolerance": 0.01,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "$0.8$ km² $= 0.8 \\times (100000)^2 = 8 \\times 10^9$ cm²; divide by $50000^2 = 2.5 \\times 10^9$" },
            { "mark": "A1", "desc": "$3.2$ cm² cao" }
          ],
          "workingSteps": [
            "Scale factor for area: $50000^2 = 2.5 \\times 10^9$",
            "$0.8$ km² $= 0.8 \\times 10^{10}$ cm² $= 8 \\times 10^9$ cm²",
            "Map area $= 8 \\times 10^9 \\div 2.5 \\times 10^9 = 3.2$ cm²"
          ]
        }
      ]
    }
