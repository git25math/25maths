      "id": "F3-01-Q1",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "easy",
      "context": "Here are the first five terms of an arithmetic sequence.\n$$6, \\ 11, \\ 16, \\ 21, \\ 26$$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write down the next term of the sequence.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "integer",
          "correctAnswer": "31",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "31" }
          ],
          "workingSteps": [
            "Common difference = 11 − 6 = 5",
            "Next term = 26 + 5 = 31"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the $n$th term of the sequence.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "5n + 1",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Common difference = 5 identified; 5n ± k seen" },
            { "mark": "A1", "desc": "5n + 1 cao" }
          ],
          "workingSteps": [
            "Common difference = 5, so nth term starts as 5n",
            "When n = 1: 5(1) = 5, but first term is 6, so adjust by +1",
            "nth term = 5n + 1",
            "Check: n = 1 → 6 ✓, n = 3 → 16 ✓, n = 5 → 26 ✓"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the 30th term of the sequence.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "151",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes n = 30 into their nth term expression" },
            { "mark": "A1", "desc": "151 cao" }
          ],
          "workingSteps": [
            "nth term = 5n + 1",
            "30th term = 5(30) + 1 = 150 + 1 = 151"
          ]
        },
        {
          "label": "d",
          "questionText": "Is 97 a term in this sequence? Give a reason for your answer.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Yes — 5n + 1 = 97 gives n = 19.2, which is not a whole number, so 97 is NOT in the sequence",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Sets 5n + 1 = 97 and attempts to solve" },
            { "mark": "A1", "desc": "n = 96/5 = 19.2, not an integer; concludes No with valid reason" }
          ],
          "workingSteps": [
            "5n + 1 = 97",
            "5n = 96",
            "n = 96/5 = 19.2",
            "n is not a whole number, so 97 is not in the sequence"
          ]
        }
      ]
    },
