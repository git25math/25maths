    {
      "id": "F3-01-Q1",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "easy",
      "context": "Here are the first five terms of a sequence.\n$$3, \\ 7, \\ 11, \\ 15, \\ 19$$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write down the next term of the sequence.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "integer",
          "correctAnswer": "23",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "23" }
          ],
          "workingSteps": [
            "Common difference = 7 − 3 = 4",
            "Next term = 19 + 4 = 23"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the $n$th term of the sequence.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "4n − 1",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Identifies common difference as 4; writes 4n ± k" },
            { "mark": "A1", "desc": "4n − 1 cao" }
          ],
          "workingSteps": [
            "Common difference = 4, so nth term starts as 4n",
            "When n = 1: 4(1) = 4, but first term is 3, so adjust by −1",
            "nth term = 4n − 1",
            "Check: n = 1 → 3 ✓, n = 2 → 7 ✓, n = 5 → 19 ✓"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the 20th term of the sequence.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "79",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes n = 20 into their nth term expression" },
            { "mark": "A1", "desc": "79 cao" }
          ],
          "workingSteps": [
            "nth term = 4n − 1",
            "20th term = 4(20) − 1 = 80 − 1 = 79"
          ]
        },
        {
          "label": "d",
          "questionText": "Is 100 a term in this sequence? Give a reason for your answer.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "No — 4n − 1 = 100 gives n = 25.25, which is not a whole number",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Sets 4n − 1 = 100 and attempts to solve" },
            { "mark": "A1", "desc": "n = 25.25 (or 101/4), concludes No with valid reason" }
          ],
          "workingSteps": [
            "4n − 1 = 100",
            "4n = 101",
            "n = 101/4 = 25.25",
            "n is not a whole number, so 100 is not in the sequence"
          ]
        }
      ]
    },
