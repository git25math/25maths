    {
      "id": "F3-01-Q3",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "medium",
      "context": "A sequence has $n$th term $T(n) = 5n + 3$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the first three terms of the sequence.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "table-fill",
          "correctAnswer": ["8", "13", "18"],
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "T(1) = 8 and T(2) = 13" },
            { "mark": "B1", "desc": "T(3) = 18" }
          ],
          "workingSteps": [
            "T(1) = 5(1) + 3 = 8",
            "T(2) = 5(2) + 3 = 13",
            "T(3) = 5(3) + 3 = 18"
          ]
        },
        {
          "label": "b",
          "questionText": "Write down the common difference of the sequence.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "integer",
          "correctAnswer": "5",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "5" }
          ],
          "workingSteps": [
            "The coefficient of n in 5n + 3 is 5, which is the common difference"
          ]
        },
        {
          "label": "c",
          "questionText": "Find the value of $n$ for which $T(n) = 98$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "19",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "5n + 3 = 98 → 5n = 95" },
            { "mark": "A1", "desc": "n = 19 cao" }
          ],
          "workingSteps": [
            "5n + 3 = 98",
            "5n = 95",
            "n = 19"
          ]
        },
        {
          "label": "d",
          "questionText": "Explain why no term in the sequence is a multiple of 5.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "5n is always a multiple of 5; adding 3 makes it 3 more than a multiple of 5, never divisible by 5",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "States 5n is a multiple of 5 (or T(n) = 5n + 3)" },
            { "mark": "B1", "desc": "5n + 3 always leaves remainder 3 when divided by 5, so never a multiple of 5" }
          ],
          "workingSteps": [
            "T(n) = 5n + 3",
            "5n is divisible by 5 for all integers n",
            "Adding 3 always gives a remainder of 3 when divided by 5",
            "So T(n) is never a multiple of 5"
          ]
        }
      ]
    },
