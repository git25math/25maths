          ],
          "workingSteps": [
            "$y=2x-3$",
            "$y+3=2x$",
            "$x=\\frac{y+3}{2}$",
            "$f^{-1}(x)=\\frac{x+3}{2}$",
            "Check: $f(f^{-1}(x))=2\\cdot\\frac{x+3}{2}-3=x+3-3=x$ ✓"
          ]
        },
        {
          "label": "b",
          "questionText": "Find $g^{-1}(x)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$g^{-1}(x) = \\dfrac{1}{x} - 1$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$y=\\frac{1}{x+1} \\Rightarrow x+1=\\frac{1}{y}$" },
            { "mark": "A1", "desc": "$g^{-1}(x)=\\frac{1}{x}-1$ cao" }
          ],
          "workingSteps": [
            "$y=\\frac{1}{x+1}$",
            "$x+1=\\frac{1}{y}$",
            "$x=\\frac{1}{y}-1$",
            "$g^{-1}(x)=\\frac{1}{x}-1$"
          ]
        },
        {
          "label": "c",
          "questionText": "Find an expression for $fg(x)$, simplifying your answer.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$\\dfrac{1-3x-3}{x+1} = \\dfrac{-1-3x}{x+1}$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$fg(x) = f\\left(\\frac{1}{x+1}\\right)$" },
            { "mark": "M1", "desc": "$= 2\\cdot\\frac{1}{x+1}-3$" },
            { "mark": "A1", "desc": "$= \\dfrac{2}{x+1}-3 = \\dfrac{2-3(x+1)}{x+1} = \\dfrac{-3x-1}{x+1}$ cao" }
          ],
          "workingSteps": [
            "$fg(x) = f\\left(\\frac{1}{x+1}\\right) = 2\\cdot\\frac{1}{x+1}-3$",
            "$= \\frac{2}{x+1}-\\frac{3(x+1)}{x+1} = \\frac{2-3x-3}{x+1} = \\frac{-3x-1}{x+1}$",
            "Check $x=0$: $fg(0)=f(1)=2(1)-3=-1$; $\\frac{-1}{1}=-1$ ✓"
          ]
        },
