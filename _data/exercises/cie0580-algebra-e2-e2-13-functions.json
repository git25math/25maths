      "type": "structured",
      "totalMarks": 14,
      "difficulty": "hard",
      "context": "The functions $f$, $g$ and $h$ are defined as:\n$$f(x) = 2x - 3 \\quad g(x) = \\dfrac{1}{x+1}, \\; x\\neq-1 \\quad h(x) = x^2 - 5$$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find $f^{-1}(x)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$f^{-1}(x) = \\dfrac{x+3}{2}$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$y=2x-3 \\Rightarrow x=\\frac{y+3}{2}$" },
