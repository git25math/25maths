    {
      "id": "F3-03-Q2",
      "type": "structured",
      "totalMarks": 9,
      "difficulty": "medium",
      "context": "The graph below shows the distance, in kilometres, that a cyclist travels over time.\n\nThe cyclist sets off at 09:00.\nAt 09:30 the cyclist has travelled 15 km.\nAt 10:00 the cyclist stops for a rest.\nAt 10:30 the cyclist continues the journey.\nAt 11:30 the cyclist has travelled a total of 45 km.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the average speed of the cyclist between 09:00 and 09:30.\nGive your answer in km/h.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "30",
          "tolerance": 0.1,
          "unit": "km/h",
          "markScheme": [
            { "mark": "M1", "desc": "Distance ÷ time = 15 ÷ 0.5" },
            { "mark": "A1", "desc": "30 km/h cao" }
          ],
          "workingSteps": [
            "Distance = 15 km, time = 0.5 hours",
            "Speed = 15 ÷ 0.5 = 30 km/h"
          ]
        },
        {
          "label": "b",
          "questionText": "How long does the cyclist rest? Give your answer in minutes.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "integer",
          "correctAnswer": "30",
          "tolerance": null,
          "unit": "minutes",
          "markScheme": [
            { "mark": "B1", "desc": "30 minutes" }
          ],
          "workingSteps": [
            "The cyclist stops at 10:00 and continues at 10:30",
            "Rest duration = 30 minutes"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the average speed of the cyclist between 10:30 and 11:30.\nGive your answer in km/h.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "30",
          "tolerance": 0.1,
          "unit": "km/h",
          "markScheme": [
            { "mark": "M1", "desc": "Distance in second leg = 45 − 15 = 30 km" },
            { "mark": "M1", "desc": "Time = 11:30 − 10:30 = 1 hour; Speed = 30 ÷ 1" },
            { "mark": "A1", "desc": "30 km/h cao" }
          ],
          "workingSteps": [
            "Distance at rest = 15 km (no movement)",
            "Distance from 10:30 to 11:30 = 45 − 15 = 30 km",
            "Time = 1 hour",
            "Speed = 30 ÷ 1 = 30 km/h"
          ]
        },
        {
          "label": "d",
          "questionText": "Work out the total distance travelled by the cyclist.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "integer",
          "correctAnswer": "45",
          "tolerance": null,
          "unit": "km",
          "markScheme": [
            { "mark": "B1", "desc": "45 km" }
          ],
          "workingSteps": [
            "Total distance = 45 km (read from graph at 11:30)"
          ]
        },
        {
          "label": "e",
          "questionText": "Work out the average speed for the whole journey from 09:00 to 11:30.\nGive your answer in km/h.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "18",
          "tolerance": 0.1,
          "unit": "km/h",
          "markScheme": [
            { "mark": "M1", "desc": "Total distance = 45 km, total time = 2.5 hours" },
            { "mark": "A1", "desc": "18 km/h cao" }
          ],
          "workingSteps": [
            "Total distance = 45 km",
            "Total time = 09:00 to 11:30 = 2.5 hours",
            "Average speed = 45 ÷ 2.5 = 18 km/h"
          ]
        }
      ]
    },
    {
