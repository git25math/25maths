          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "y = 0 when x = 2" },
            { "mark": "B1", "desc": "y = 2 when x = 3" }
          ],
          "workingSteps": [
            "x = 2: y = 4 − 6 + 2 = 0",
            "x = 3: y = 9 − 9 + 2 = 2"
