      "id": "F3-03-Q1",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "easy",
      "context": "The table below shows some values of $y = 2x + 1$ for $-3 \\leq x \\leq 3$.\n\n| $x$ | −3 | −2 | −1 | 0 | 1 | 2 | 3 |\n|---|---|---|---|---|---|---|---|\n| $y$ | | −3 | | 1 | | 5 | |",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Complete the table of values.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "table-fill",
          "correctAnswer": ["-5", "-1", "3", "7"],
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "y = −5 when x = −3" },
            { "mark": "B1", "desc": "y = −1 when x = −1" },
            { "mark": "B1", "desc": "y = 3 when x = 1 and y = 7 when x = 3 (both needed)" }
          ],
          "workingSteps": [
            "x = −3: y = 2(−3) + 1 = −6 + 1 = −5",
            "x = −1: y = 2(−1) + 1 = −2 + 1 = −1",
            "x = 1: y = 2(1) + 1 = 3",
            "x = 3: y = 2(3) + 1 = 7"
          ]
        },
        {
          "label": "b",
          "questionText": "On the grid, draw the graph of $y = 2x + 1$ for $-3 \\leq x \\leq 3$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "draw",
          "correctAnswer": "straight line through (0, 1) and (1, 3)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "At least two correct points plotted from the table" },
            { "mark": "A1", "desc": "Correct straight line drawn through the full domain" }
          ],
          "workingSteps": [
            "Plot points from the table: (−3, −5), (−2, −3), (−1, −1), (0, 1), (1, 3), (2, 5), (3, 7)",
            "Draw a straight line through all points"
          ]
        },
        {
          "label": "c",
          "questionText": "Use your graph to find the value of $x$ when $y = 4$.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "1.5",
          "tolerance": 0.1,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "x = 1.5 (ft from their graph)" }
          ],
          "workingSteps": [
            "Draw horizontal line at y = 4",
            "Read off x where it crosses the line: x = 1.5"
          ]
        },
        {
          "label": "d",
          "questionText": "Write down the gradient of the line $y = 2x + 1$.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "integer",
          "correctAnswer": "2",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "2" }
          ],
          "workingSteps": [
            "In y = mx + c, the gradient m = 2"
          ]
        },
        {
          "label": "e",
          "questionText": "Write down the coordinates of the $y$-intercept of the line.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "coordinate",
          "correctAnswer": "(0, 1)",
          "tolerance": null,
