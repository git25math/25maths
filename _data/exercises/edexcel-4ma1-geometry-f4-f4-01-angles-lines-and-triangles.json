        {
          "label": "c",
          "questionText": "A triangle has angles in the ratio 2 : 3 : 4.\nWork out the size of the largest angle.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "80",
          "tolerance": null,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "2 + 3 + 4 = 9 parts; 180 ÷ 9 = 20 per part" },
            { "mark": "A1", "desc": "Largest = 4 × 20 = 80°" }
          ],
          "workingSteps": [
            "Total parts = 2 + 3 + 4 = 9",
            "Each part = 180° ÷ 9 = 20°",
            "Largest angle = 4 × 20° = 80°"
          ]
        }
      ]
