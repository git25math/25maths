          "correctAnswer": "66",
          "tolerance": null,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "Base angles of isosceles triangle are equal" },
            { "mark": "M1", "desc": "(180 − 48) ÷ 2" },
            { "mark": "A1", "desc": "66°" }
          ],
          "workingSteps": [
            "AB = AC so angles ABC = ACB (base angles of isosceles triangle)",
            "Angle ABC = (180° − 48°) ÷ 2 = 132° ÷ 2 = 66°"
          ]
