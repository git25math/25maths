        {
          "label": "b",
          "questionText": "Give a reason why a triangle cannot have two obtuse angles.",
          "marks": 2,
          "commandWord": "explain",
          "answerType": "explain",
          "correctAnswer": "Two obtuse angles sum to more than 180°, but angles in a triangle must total 180°.",
          "markScheme": [
            { "mark": "B1", "desc": "Two obtuse angles each > 90°, so their sum > 180°" },
            { "mark": "B1", "desc": "This contradicts the angle sum of a triangle being 180° oe" }
          ],
          "workingSteps": [
            "Each obtuse angle > 90°.",
            "Two obtuse angles: sum > 180°.",
            "Angle sum in a triangle = 180°, so two obtuse angles are impossible."
          ]
        },
