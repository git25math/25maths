      "difficulty": "medium",
      "questionText": "A shopkeeper buys a watch for $\\$45$ and sells it for $\\$63$.\nCalculate the percentage profit.",
      "answerType": "integer",
      "correctAnswer": "40",
      "tolerance": null,
      "unit": "%",
      "markScheme": [
        { "mark": "M1", "desc": "Profit $= 63 - 45 = \\$18$" },
        { "mark": "M1", "desc": "$\\dfrac{18}{45} \\times 100$" },
        { "mark": "A1", "desc": "$40\\%$ cao" }
      ],
      "workingSteps": [
        "Profit $= \\$63 - \\$45 = \\$18$",
        "Percentage profit $= \\dfrac{18}{45} \\times 100 = 40\\%$"
      ],
      "explanation": "Percentage profit = (profit ÷ cost price) × 100."
    },
