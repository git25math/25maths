      "id": "F5-01-Q1",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "easy",
      "context": "$\\mathbf{a} = \\begin{pmatrix} 3 \\\\ 2 \\end{pmatrix}$ and $\\mathbf{b} = \\begin{pmatrix} -1 \\\\ 4 \\end{pmatrix}$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out $\\mathbf{a} + \\mathbf{b}$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "vector",
          "correctAnswer": "(2, 6)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "(3+(−1), 2+4)"
            },
            {
              "mark": "A1",
              "desc": "(2, 6)"
            }
          ],
          "workingSteps": [
            "a + b = (3−1, 2+4) = (2, 6)"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out $2\\mathbf{a} - \\mathbf{b}$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "vector",
          "correctAnswer": "(7, 0)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "2a = (6, 4)"
            },
            {
              "mark": "M1",
              "desc": "(6, 4) − (−1, 4)"
            },
            {
              "mark": "A1",
              "desc": "(7, 0)"
            }
          ],
          "workingSteps": [
            "2a = (6, 4)",
            "2a − b = (6+1, 4−4) = (7, 0)"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the magnitude of $\\mathbf{a}$.\nGive your answer correct to 1 decimal place.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "3.6",
          "tolerance": 0.05,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "√(9+4) = √13"
            },
            {
              "mark": "A1",
              "desc": "3.6"
            }
          ],
          "workingSteps": [
            "| a | = √(3²+2²) = √13 = 3.6"
          ]
        }
      ]
    },
    {
      "id": "F5-01-Q2",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "medium",
      "context": "On a grid, A is at (2, 1) and B is at (6, 4).",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write down $\\overrightarrow{AB}$ as a column vector.",
          "marks": 2,
          "commandWord": "write-down",
          "answerType": "vector",
          "correctAnswer": "(4, 3)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "B1",
              "desc": "x: 6−2=4"
            },
            {
              "mark": "B1",
              "desc": "y: 4−1=3, so (4, 3)"
            }
          ],
          "workingSteps": [
            "AB = B − A = (6−2, 4−1) = (4, 3)"
          ]
        },
        {
          "label": "b",
          "questionText": "C is the point such that $\\overrightarrow{BC} = \\begin{pmatrix} -2 \\\\ 5 \\end{pmatrix}$.\nWork out the coordinates of C.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "coordinate",
          "correctAnswer": "(4, 9)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "C = B + BC = (6, 4) + (−2, 5)"
            },
            {
              "mark": "A1",
              "desc": "(4, 9)"
            }
          ],
          "workingSteps": [
            "C = (6+(−2), 4+5) = (4, 9)"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the magnitude of $\\overrightarrow{AB}$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "5",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "√(16+9) = √25"
            },
            {
              "mark": "A1",
              "desc": "5"
            }
          ],
          "workingSteps": [
            "| AB | = √(4²+3²) = √25 = 5"
          ]
        },
        {
          "label": "d",
          "questionText": "Write down $\\overrightarrow{BA}$ as a column vector.",
          "marks": 1,
          "commandWord": "write-down",
          "answerType": "vector",
          "correctAnswer": "(−4, −3)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "B1",
              "desc": "(−4, −3)"
            }
          ],
          "workingSteps": [
