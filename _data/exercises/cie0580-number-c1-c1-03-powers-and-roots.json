      "difficulty": "easy",
      "questionText": "Calculate\n(a) $\\sqrt{144}$\n(b) $\\sqrt[3]{27}$\n(c) $5^3$",
      "answerType": "integer",
      "correctAnswer": "(a) 12  (b) 3  (c) 125",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "12" },
        { "mark": "B1", "desc": "3" },
        { "mark": "B1", "desc": "125" }
