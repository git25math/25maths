      "questionText": "Without a calculator, calculate the value of $\\sqrt{169} + 2^4 - \\sqrt[3]{8}$.",
      "answerType": "integer",
      "correctAnswer": "27",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "√169 = 13" },
        { "mark": "B1", "desc": "2⁴ = 16" },
        { "mark": "B1", "desc": "∛8 = 2" },
        { "mark": "A1", "desc": "13 + 16 − 2 = 27 cao" }
