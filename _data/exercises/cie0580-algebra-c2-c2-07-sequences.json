        { "mark": "B1", "desc": "23" }
      ],
      "workingSteps": [
        "Common difference: 7 - 3 = 4",
        "Next term: 15 + 4 = 19",
        "Term after: 19 + 4 = 23"
      ],
      "explanation": "This is an arithmetic sequence with common difference 4."
    },
    {
      "id": "C2-07-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "find",
      "difficulty": "easy",
      "questionText": "The $n$th term of a sequence is $4n - 1$.\n\n(a) Find the 5th term of the sequence.\n\n(b) Find the value of $n$ for which the $n$th term equals 31.",
      "answerType": "integer",
      "correctAnswer": "8",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "(a) 4(5) - 1 = 19" },
        { "mark": "M1", "desc": "(b) 4n - 1 = 31 → 4n = 32" },
        { "mark": "A1", "desc": "(b) n = 8 cao" }
      ],
      "workingSteps": [
        "(a) n = 5: 4(5) - 1 = 20 - 1 = 19",
        "(b) 4n - 1 = 31",
        "    4n = 31 + 1 = 32",
        "    n = 32 ÷ 4 = 8",
        "Check: 4(8) - 1 = 32 - 1 = 31 ✓"
      ],
      "explanation": "Substitute n = 5 for part (a); form and solve an equation for part (b)."
    },
    {
      "id": "C2-07-Q3",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "The first four terms of a sequence are $5, \\ 9, \\ 13, \\ 17, \\ \\ldots$\n\nFind an expression for the $n$th term of the sequence.",
      "answerType": "expression",
      "correctAnswer": "$4n + 1$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Common difference = 4 identified" },
        { "mark": "M1", "desc": "nth term = 4n + c, substituting n = 1: 4(1) + c = 5" },
        { "mark": "A1", "desc": "4n + 1 cao" }
      ],
      "workingSteps": [
        "Differences: 9-5=4, 13-9=4, 17-13=4 (constant, so arithmetic)",
        "nth term = 4n + c",
        "When n = 1: 4(1) + c = 5, so c = 1",
        "nth term = 4n + 1",
        "Check: n=2: 4(2)+1=9 ✓, n=3: 4(3)+1=13 ✓"
      ],
      "explanation": "For an arithmetic sequence: nth term = first term + (n-1) × common difference = 4n + 1."
    },
