    {
      "id": "C2-07-Q5",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "explain",
      "difficulty": "medium",
      "questionText": "The $n$th term of a sequence is $5n + 2$.\nExplain why 44 is not a term in this sequence.",
      "answerType": "explain",
      "correctAnswer": "(44 - 2) ÷ 5 = 8.4, which is not an integer, so 44 is not a term.",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Setting 5n + 2 = 44 and attempting to solve" },
        { "mark": "A1", "desc": "5n = 42, so n = 8.4" },
        { "mark": "E1", "desc": "n = 8.4 is not a positive integer, so 44 is not in the sequence" }
      ],
      "workingSteps": [
        "Assume 5n + 2 = 44",
        "5n = 44 - 2 = 42",
        "n = 42 ÷ 5 = 8.4",
        "Since n = 8.4 is not a positive integer, 44 is not a term in the sequence",
        "Check neighbours: 5(8)+2 = 42, 5(9)+2 = 47; neither equals 44 ✓"
      ],
      "explanation": "A number is in the sequence if and only if solving 5n + 2 = (that number) gives a positive integer."
    }
