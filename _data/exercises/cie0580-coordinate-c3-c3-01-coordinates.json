    {
      "id": "C3-01-Q3",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "A triangle has vertices at P(1, 1), Q(7, 1) and R(4, 5).",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the length PQ.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "6",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "B1",
              "desc": "7 − 1 = 6"
            }
          ],
          "workingSteps": [
            "PQ = 7 − 1 = 6 (horizontal line)"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the midpoint of PQ.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "coordinate",
          "correctAnswer": "(4, 1)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "B1",
              "desc": "(4, 1)"
            }
          ],
          "workingSteps": [
            "Midpoint = ((1+7)/2, (1+1)/2) = (4, 1)"
          ]
        },
        {
          "label": "c",
          "questionText": "Show that the triangle is isosceles.",
          "marks": 4,
          "commandWord": "show",
          "answerType": "show-that",
          "correctAnswer": "PR = QR = 5",
          "markScheme": [
            {
              "mark": "M1",
              "desc": "PR² = (4−1)² + (5−1)² = 9+16 = 25"
            },
            {
              "mark": "A1",
              "desc": "PR = 5"
            },
            {
              "mark": "M1",
              "desc": "QR² = (7−4)² + (1−5)² = 9+16 = 25"
            },
            {
              "mark": "A1",
              "desc": "QR = 5, so PR = QR, isosceles"
            }
          ],
          "workingSteps": [
            "PR² = 3² + 4² = 25, PR = 5",
            "QR² = 3² + 4² = 25, QR = 5",
            "PR = QR = 5, so isosceles"
          ]
        }
      ]
    },
    {
      "id": "C3-01-Q4",
      "type": "short-answer",
      "totalMarks": 4,
      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "The points A(−2, 3) and B(4, −1) are the ends of a diameter of a circle.\n(a) Find the coordinates of the centre of the circle.\n(b) Find the radius of the circle.",
      "answerType": "coordinate",
      "correctAnswer": "(1, 1), √13",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "B1",
          "desc": "(a) Centre = ((−2+4)/2, (3−1)/2) = (1, 1)"
        },
        {
          "mark": "M1",
          "desc": "(b) r² = (4−1)² + (−1−1)² = 9+4"
        },
        {
          "mark": "M1",
          "desc": "r² = 13"
        },
        {
          "mark": "A1",
          "desc": "r = √13 = 3.61"
        }
      ],
      "workingSteps": [
        "(a) Centre = midpoint = (1, 1)",
        "(b) r = distance from centre to A = √(3²+2²) = √13 = 3.61"
      ],
      "explanation": "Centre of circle = midpoint of diameter. Radius = half the diameter."
    }
  ]
