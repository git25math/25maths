      "parts": [
        {
          "label": "a",
          "questionText": "Write $x^2 + 6x + 2$ in the form $(x + p)^2 + q$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "(x + 3)^2 - 7",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "(x + 3)² = x² + 6x + 9; subtracts 9 then adds 2" },
            { "mark": "A1", "desc": "(x + 3)² − 7 cao" }
          ],
          "workingSteps": [
            "Complete the square: half of 6 is 3",
            "(x + 3)² = x² + 6x + 9",
            "x² + 6x + 2 = (x + 3)² − 9 + 2 = (x + 3)² − 7"
          ]
        },
        {
          "label": "b",
          "questionText": "Hence solve $x^2 + 6x + 2 = 0$.\nGive your answers in the form $a \\pm b\\sqrt{c}$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x = -3 ± √7",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "(x + 3)² = 7" },
            { "mark": "A1", "desc": "x = −3 ± √7 cao" }
          ],
          "workingSteps": [
            "(x + 3)² − 7 = 0",
            "(x + 3)² = 7",
            "x + 3 = ±√7",
            "x = −3 ± √7"
          ]
        },
        {
          "label": "c",
          "questionText": "Write down the minimum value of $x^2 + 6x + 2$ and state the value of $x$ at which it occurs.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Minimum value is −7, at x = −3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Minimum value = −7" },
            { "mark": "B1", "desc": "Occurs at x = −3" }
          ],
          "workingSteps": [
            "From (x + 3)² − 7: minimum of (x + 3)² is 0, when x = −3",
            "Minimum value = 0 − 7 = −7"
          ]
        },
        {
          "label": "d",
          "questionText": "Use the quadratic formula to solve $2x^2 - 5x - 3 = 0$.\nShow all your working.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x = 3 or x = -0.5",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "x = (5 ± √(25 + 24)) / 4 = (5 ± 7) / 4" },
            { "mark": "A1", "desc": "x = 3 or x = −0.5 cao" }
          ],
          "workingSteps": [
            "a = 2, b = −5, c = −3",
            "x = [5 ± √(25 + 24)] / 4 = (5 ± √49) / 4 = (5 ± 7) / 4",
            "x = 12/4 = 3 or x = −2/4 = −0.5"
          ]
        }
      ]
