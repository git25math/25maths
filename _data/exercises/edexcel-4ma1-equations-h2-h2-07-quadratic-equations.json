      "parts": [
        {
          "label": "a",
          "questionText": "Write $3x^2 - 12x + 7$ in the form $a(x + b)^2 + c$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "3(x - 2)^2 - 5",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Factors out 3: 3(x² − 4x) + 7" },
            { "mark": "M1", "desc": "Completes square inside: 3(x − 2)² − 12 + 7" },
            { "mark": "A1", "desc": "3(x − 2)² − 5 cao" }
          ],
          "workingSteps": [
            "3x² − 12x + 7 = 3(x² − 4x) + 7",
            "x² − 4x = (x − 2)² − 4",
            "= 3[(x − 2)² − 4] + 7",
            "= 3(x − 2)² − 12 + 7",
            "= 3(x − 2)² − 5"
          ]
        },
        {
          "label": "b",
          "questionText": "Hence write down the minimum value of $3x^2 - 12x + 7$ and the value of $x$ where it occurs.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Minimum value is −5, at x = 2",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Minimum value = −5" },
            { "mark": "B1", "desc": "At x = 2" }
          ],
          "workingSteps": [
            "3(x − 2)² ≥ 0; minimum is 0 when x = 2",
            "Minimum of expression = −5 at x = 2"
          ]
        },
        {
          "label": "c",
          "questionText": "Determine the discriminant of $3x^2 - 12x + 7 = 0$ and hence state the number of real solutions.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Discriminant = 60 > 0, so two distinct real solutions",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "b² − 4ac = (−12)² − 4(3)(7) = 144 − 84" },
            { "mark": "A1", "desc": "Discriminant = 60" },
            { "mark": "A1", "desc": "60 > 0, so two distinct real solutions" }
          ],
          "workingSteps": [
            "a = 3, b = −12, c = 7",
            "Δ = (−12)² − 4(3)(7) = 144 − 84 = 60",
            "Δ = 60 > 0 → two distinct real roots"
          ]
        }
      ]
    },
    {
      "id": "H2-07-Q3",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "hard",
      "context": "A ball is thrown vertically upward. Its height $h$ metres above the ground at time $t$ seconds is:\n$$h = 20t - 5t^2$$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the maximum height of the ball.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "20",
          "tolerance": null,
          "unit": "m",
          "markScheme": [
            { "mark": "M1", "desc": "Completes square or uses symmetry: h = −5(t² − 4t) = −5(t − 2)² + 20" },
            { "mark": "M1", "desc": "Maximum when t = 2" },
            { "mark": "A1", "desc": "Maximum height = 20 m cao" }
          ],
          "workingSteps": [
            "h = 20t − 5t² = −5(t² − 4t)",
            "= −5[(t − 2)² − 4]",
            "= −5(t − 2)² + 20",
            "Maximum when (t − 2)² = 0, i.e. t = 2",
            "Maximum height = 20 m"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the times when the ball is at a height of 15 m.\nGive your answers correct to 2 decimal places.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "t = 0.84 or t = 3.16",
          "tolerance": null,
          "unit": "s",
          "markScheme": [
            { "mark": "M1", "desc": "20t − 5t² = 15 → 5t² − 20t + 15 = 0 → t² − 4t + 3 = 0" },
            { "mark": "A1", "desc": "(t−1)(t−3) = 0 → t = 1 or t = 3" },
            { "mark": "A1", "desc": "t = 1.00 s and t = 3.00 s cao" }
          ],
          "workingSteps": [
            "20t − 5t² = 15",
            "5t² − 20t + 15 = 0",
            "t² − 4t + 3 = 0",
            "(t − 1)(t − 3) = 0",
            "t = 1 s or t = 3 s"
          ]
        }
      ]
    }
  ]
