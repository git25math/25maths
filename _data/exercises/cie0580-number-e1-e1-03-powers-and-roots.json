    {
      "type": "multiple-choice",
      "questionText": "Simplify 3² × 3⁴.",
      "options": [
        "3⁸",
        "9⁶",
        "3⁶",
        "9⁸"
      ],
      "correctAnswer": 2,
      "explanation": "When multiplying powers with the same base, you add the indices. So, 3² × 3⁴ = 3²⁺⁴ = 3⁶."
    },
    {
      "type": "multiple-choice",
      "questionText": "Simplify 10⁶ ÷ 10².",
      "options": [
        "10⁸",
        "10³",
        "10⁻⁴",
        "10⁴"
      ],
      "correctAnswer": 3,
      "explanation": "When dividing powers with the same base, you subtract the indices. So, 10⁶ ÷ 10² = 10⁶⁻² = 10⁴."
    },
    {
      "type": "multiple-choice",
      "questionText": "Evaluate (2³)⁴.",
      "options": [
        "2⁷",
        "2¹²",
        "2⁶⁴",
        "8⁴"
      ],
      "correctAnswer": 1,
      "explanation": "When raising a power to another power, you multiply the indices. So, (2³)⁴ = 2³ˣ⁴ = 2¹²."
