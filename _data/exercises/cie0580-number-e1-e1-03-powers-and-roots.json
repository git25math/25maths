  "questions": [
    {
      "type": "multiple-choice",
      "questionText": "Evaluate $2^5$.",
      "options": [
        "10",
        "25",
        "32",
        "16"
      ],
      "correctAnswer": 2,
      "explanation": "$2^5$ means 2 × 2 × 2 × 2 × 2, which equals 32. It is not 2 × 5."
    },
    {
      "type": "multiple-choice",
      "questionText": "Simplify $3^2 \\times 3^4$.",
      "options": [
        "$3^8$",
        "$9^6$",
        "$3^6$",
        "$9^8$"
      ],
      "correctAnswer": 2,
      "explanation": "When multiplying powers with the same base, you add the indices. So, $3^2 \\times 3^4 = 3^{2+4} = 3^6$."
    },
    {
      "type": "multiple-choice",
      "questionText": "Simplify $10^6 \\div 10^2$.",
      "options": [
        "$10^8$",
        "$10^3$",
        "$10^{-4}$",
        "$10^4$"
      ],
      "correctAnswer": 3,
      "explanation": "When dividing powers with the same base, you subtract the indices. So, $10^6 \\div 10^2 = 10^{6-2} = 10^4$."
    },
    {
      "type": "multiple-choice",
      "questionText": "Evaluate $(2^3)^4$.",
      "options": [
        "$2^7$",
        "$2^{12}$",
        "$2^{64}$",
        "$8^4$"
      ],
      "correctAnswer": 1,
      "explanation": "When raising a power to another power, you multiply the indices. So, $(2^3)^4 = 2^3$ˣ⁴ = $2^{12}$."
    },
    {
      "type": "multiple-choice",
      "questionText": "What is the value of $5^0$?",
      "options": [
        "0",
        "1",
        "5",
        "It is undefined."
      ],
      "correctAnswer": 1,
      "explanation": "Any non-zero number raised to the power of 0 is equal to 1."
    },
    {
      "type": "multiple-choice",
      "questionText": "Evaluate $4^{-2}$.",
      "options": [
        "-8",
        "-16",
        "$\\frac{1}{8}$",
        "$\\frac{1}{16}$"
      ],
      "correctAnswer": 3,
      "explanation": "A negative index indicates the reciprocal. So, $4^{-2} = 1/4^2 = \\frac{1}{16}$."
    },
    {
      "type": "multiple-choice",
      "questionText": "Evaluate $9^{1/2}$.",
      "options": [
        "4.5",
        "18",
        "3",
        "81"
      ],
      "correctAnswer": 2,
      "explanation": "An index of $\\frac{1}{2}$ means the square root. So, $9^{1/2} = \\sqrt{9}$ = 3."
    },
    {
      "type": "multiple-choice",
      "questionText": "Evaluate $27^{1/3}$.",
      "options": [
        "9",
        "3",
        "81",
        "2.7"
      ],
      "correctAnswer": 1,
      "explanation": "An index of $\\frac{1}{3}$ means the cube root. So, $27^{1/3} = \\sqrt[3]{27}$ = 3."
    },
    {
      "type": "multiple-choice",
      "questionText": "Simplify $a^6 \\times a^{-2}$.",
      "options": [
        "$a^{-12}$",
        "$a^4$",
        "$a^8$",
        "$a^{-3}$"
      ],
      "correctAnswer": 1,
      "explanation": "When multiplying powers with the same base, add the indices. So, $a^6 \\times a^{-2} = a^{6+(-2)} = a^4$."
    },
    {
      "type": "multiple-choice",
      "questionText": "Write $10^{-3}$ as a decimal.",
      "options": [
        "0.001",
        "-1000",
        "0.01",
        "0.0001"
      ],
      "correctAnswer": 0,
      "explanation": "$10^{-3}$ is equivalent to $1/10^3 = \\frac{1}{1000}$, which is 0.001 as a decimal."
    },
    {
      "type": "multiple-choice",
      "questionText": "Evaluate $16^{3/4}$.",
      "options": [
        "12",
        "6",
        "8",
        "32"
      ],
      "correctAnswer": 2,
      "explanation": "$16^{3/4}$ means $(\\sqrt[4]{16})^3$. The 4th root of 16 is 2. Then, $2^3$ = 8."
    },
    {
      "type": "multiple-choice",
      "questionText": "The area of a square is 49 $\\text{cm}^2$. What is the length of one side?",
      "options": [
        "24.5 cm",
        "7 cm",
        "12.25 cm",
        "9.8 cm"
      ],
      "correctAnswer": 1,
      "explanation": "The area of a square is side length squared. To find the side length, you need to find the square root of the area. $\\sqrt{49}$ = 7 cm."
    }
  ]
