      "totalMarks": 3,
      "commandWord": "simplify",
      "difficulty": "medium",
      "questionText": "Simplify $(2^3)^2 \\div 2^4$, giving your answer as a power of 2.",
      "answerType": "expression",
      "correctAnswer": "$2^2$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "$(2^3)^2 = 2^{3 \\times 2} = 2^6$" },
        { "mark": "M1", "desc": "$2^6 \\div 2^4 = 2^{6-4}$" },
        { "mark": "A1", "desc": "$2^2$ cao" }
      ],
      "workingSteps": [
        "$(2^3)^2 = 2^{3 \\times 2} = 2^6$",
        "$2^6 \\div 2^4 = 2^{6-4} = 2^2$"
      ],
      "explanation": "Power of a power: multiply indices. Dividing: subtract indices."
    },
