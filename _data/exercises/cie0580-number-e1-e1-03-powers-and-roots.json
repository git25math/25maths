      "questionText": "Calculate $\\sqrt[3]{-125}$.",
      "answerType": "integer",
      "correctAnswer": "-5",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Recognises $(-5)^3 = -125$" },
        { "mark": "A1", "desc": "$-5$ cao" }
      ],
      "workingSteps": [
        "$(-5)^3 = (-5) \\times (-5) \\times (-5) = -125$",
        "So $\\sqrt[3]{-125} = -5$"
      ],
      "explanation": "The cube root of a negative number is negative."
    },
    {
      "id": "E1-03-Q2",
