      "context": null,
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out $(4.5 \\times 10^3) + (6.7 \\times 10^2)$.\nGive your answer in standard form.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$5.17 \\times 10^3$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Converts to same power: $4500 + 670$" },
            { "mark": "M1", "desc": "$= 5170$" },
            { "mark": "A1", "desc": "$5.17 \\times 10^3$ cao" }
          ],
          "workingSteps": [
            "$4.5 \\times 10^3 = 4500$",
            "$6.7 \\times 10^2 = 670$",
            "$4500 + 670 = 5170$",
            "$= 5.17 \\times 10^3$"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out $\\dfrac{(3.2 \\times 10^7)^2}{4 \\times 10^5}$.\nGive your answer in standard form.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$2.56 \\times 10^9$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$(3.2)^2 \\times (10^7)^2 = 10.24 \\times 10^{14}$; then $\\div (4 \\times 10^5)$" },
            { "mark": "A1", "desc": "$\\dfrac{10.24}{4} \\times 10^{14-5} = 2.56 \\times 10^9$ cao" }
          ],
          "workingSteps": [
            "$(3.2 \\times 10^7)^2 = 3.2^2 \\times 10^{14} = 10.24 \\times 10^{14}$",
            "$\\dfrac{10.24 \\times 10^{14}}{4 \\times 10^5} = \\dfrac{10.24}{4} \\times 10^{14-5} = 2.56 \\times 10^9$"
          ]
        }
      ]
    },
    {
      "id": "H1-09-Q2",
      "type": "structured",
      "totalMarks": 5,
      "difficulty": "hard",
      "context": "The number of atoms in $1$ gram of hydrogen is approximately $6.02 \\times 10^{23}$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the number of atoms in $0.05$ grams of hydrogen.\nGive your answer in standard form.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$3.01 \\times 10^{22}$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$6.02 \\times 10^{23} \\times 0.05 = 6.02 \\times 10^{23} \\times 5 \\times 10^{-2}$" },
            { "mark": "A1", "desc": "$30.1 \\times 10^{21} = 3.01 \\times 10^{22}$ cao" }
          ],
          "workingSteps": [
            "$6.02 \\times 10^{23} \\times 0.05 = 6.02 \\times 5 \\times 10^{23-2} \\times 10^{-1}$",
            "$= 30.1 \\times 10^{21} = 3.01 \\times 10^{22}$"
          ]
        },
        {
          "label": "b",
          "questionText": "Each hydrogen atom has mass approximately $1.67 \\times 10^{-27}$ kg.\nWork out the mass of $1$ gram of hydrogen in kg, using the given data.\nComment on your answer.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "$6.02 \\times 10^{23} \\times 1.67 \\times 10^{-27} \\approx 1.005 \\times 10^{-3}$ kg, approximately 1 g",
          "tolerance": null,
          "unit": "kg",
          "markScheme": [
            { "mark": "M1", "desc": "$6.02 \\times 1.67 = 10.0534$; $10^{23} \\times 10^{-27} = 10^{-4}$" },
            { "mark": "A1", "desc": "$1.00534 \\times 10^{-3}$ kg" },
            { "mark": "B1", "desc": "This is approximately $1$ gram (since $1$ g $= 10^{-3}$ kg), consistent with the given $1$ gram of hydrogen" }
          ],
          "workingSteps": [
            "$6.02 \\times 10^{23} \\times 1.67 \\times 10^{-27}$",
            "$= (6.02 \\times 1.67) \\times 10^{23+(-27)}$",
            "$= 10.0534 \\times 10^{-4}$",
            "$= 1.00534 \\times 10^{-3}$ kg",
            "$= 1.005$ g ≈ 1 g ✓ (consistent)"
          ]
        }
      ]
    }
  ]
}
