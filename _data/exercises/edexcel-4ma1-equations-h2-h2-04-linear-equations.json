    {
      "id": "H2-04-Q2",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": "A school sells adult tickets for a concert at $£(3n + 2)$ and child tickets at $£(n + 1)$.\nThey sell 4 adult tickets and 6 child tickets.\nThe total ticket revenue is £68.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Show that $18n + 14 = 68$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "show-that",
          "correctAnswer": "4(3n+2) + 6(n+1) = 68 → 12n + 8 + 6n + 6 = 68 → 18n + 14 = 68",
          "markScheme": [
            { "mark": "M1", "desc": "4(3n+2) + 6(n+1) = 68 set up and expanded" },
            { "mark": "A1", "desc": "18n + 14 = 68 shown with all working" }
          ],
          "workingSteps": [
            "Revenue = 4 × (3n+2) + 6 × (n+1)",
            "= 12n + 8 + 6n + 6",
            "= 18n + 14 = 68"
          ]
        },
        {
          "label": "b",
          "questionText": "Solve $18n + 14 = 68$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "18n = 54" },
            { "mark": "A1", "desc": "n = 3 cao" }
          ],
          "workingSteps": [
            "18n = 68 − 14 = 54",
            "n = 54 ÷ 18 = 3"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the price of an adult ticket and the price of a child ticket.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Adult: £11, Child: £4",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Adult = 3(3) + 2 = £11 ft their n" },
            { "mark": "B1", "desc": "Child = 3 + 1 = £4 ft their n" }
          ],
          "workingSteps": [
            "Adult = 3(3) + 2 = 9 + 2 = £11",
            "Child = 3 + 1 = £4",
            "Check: 4 × 11 + 6 × 4 = 44 + 24 = £68 ✓"
          ]
        },
        {
          "label": "d",
          "questionText": "Hence work out the ratio of the adult ticket price to the child ticket price.\nGive your answer in its simplest form.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "11:4",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "11 : 4 cao (cannot be simplified further)" }
          ],
          "workingSteps": [
            "Adult : Child = 11 : 4",
            "HCF(11, 4) = 1, already in simplest form"
          ]
        }
      ]
    },
