          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "2.6",
          "tolerance": 0.05,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Multiplies through by 12: 3(3x+1) − 4(x−2) = 24" },
            { "mark": "M1", "desc": "Expands: 9x + 3 − 4x + 8 = 24" },
            { "mark": "M1", "desc": "5x + 11 = 24 → 5x = 13" },
            { "mark": "A1", "desc": "x = 13/5 = 2.6 cao" }
          ],
          "workingSteps": [
            "Multiply through by 12 (LCM of 4 and 3):",
            "3(3x+1) − 4(x−2) = 24",
            "9x + 3 − 4x + 8 = 24",
            "5x + 11 = 24",
            "5x = 13",
            "x = 13/5 = 2.6"
          ]
        },
        {
          "label": "b",
          "questionText": "Solve $\\dfrac{5}{2x - 1} = \\dfrac{3}{x + 2}$.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "13",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Cross-multiplies: 5(x+2) = 3(2x−1)" },
            { "mark": "M1", "desc": "5x + 10 = 6x − 3" },
            { "mark": "M1", "desc": "Collects: 13 = x" },
            { "mark": "A1", "desc": "x = 13 cao" }
          ],
          "workingSteps": [
            "Cross-multiply: 5(x+2) = 3(2x−1)",
            "5x + 10 = 6x − 3",
            "10 + 3 = 6x − 5x",
            "x = 13",
            "Check: 5/(26−1) = 5/25 = 1/5; 3/(13+2) = 3/15 = 1/5 ✓"
          ]
        }
      ]
