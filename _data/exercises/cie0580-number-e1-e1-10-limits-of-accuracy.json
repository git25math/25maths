        { "mark": "A1", "desc": "$4.40$ cm cao" }
      ],
      "workingSteps": [
        "Lower bound of $l$: $6.3 - 0.05 = 6.25$ cm",
        "Upper bound of $w$: $1.8 + 0.05 = 1.85$ cm",
        "Lower bound of $(l - w) = 6.25 - 1.85 = 4.40$ cm"
      ],
      "explanation": "To minimise a difference: use lower bound of the larger minus upper bound of the smaller."
