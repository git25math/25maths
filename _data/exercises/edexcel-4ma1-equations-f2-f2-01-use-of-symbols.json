            "20 − 3 = 17"
          ]
        },
        {
          "label": "b",
          "questionText": "Write down the value of $2y^2 + 1$ when $y = 3$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "19",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "2 × 9 + 1 = 18 + 1" },
            { "mark": "A1", "desc": "19 cao" }
          ],
          "workingSteps": [
            "y² = 3² = 9",
            "2 × 9 + 1 = 18 + 1 = 19"
          ]
        },
        {
          "label": "c",
          "questionText": "Write down the value of $\\dfrac{3m + n}{2}$ when $m = 5$ and $n = 1$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "8",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "(3 × 5 + 1) ÷ 2 = 16 ÷ 2" },
            { "mark": "A1", "desc": "8 cao" }
          ],
          "workingSteps": [
            "3m + n = 3 × 5 + 1 = 15 + 1 = 16",
            "16 ÷ 2 = 8"
          ]
        }
      ]
