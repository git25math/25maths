    {
      "id": "F2-01-Q1",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "easy",
      "context": "A shop sells apples and bananas. An apple costs $a$ pence and a banana costs $b$ pence.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write an expression for the total cost, in pence, of 3 apples and 5 bananas.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "3a + 5b",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "3a seen" },
            { "mark": "B1", "desc": "3a + 5b cao" }
          ],
          "workingSteps": [
            "3 apples = 3 × a = 3a pence",
            "5 bananas = 5 × b = 5b pence",
            "Total = 3a + 5b"
          ]
        },
        {
          "label": "b",
          "questionText": "An apple costs 25 pence and a banana costs 18 pence.\nWork out the total cost of 3 apples and 5 bananas.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "165",
          "tolerance": null,
          "unit": "pence",
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes a = 25, b = 18 into their expression or works numerically" },
            { "mark": "A1", "desc": "165 cao" }
          ],
          "workingSteps": [
            "3 × 25 = 75",
            "5 × 18 = 90",
            "Total = 75 + 90 = 165 pence"
          ]
        },
        {
          "label": "c",
          "questionText": "The total cost of 4 apples and some bananas is $4a + 7b$ pence.\nHow many bananas are there?\nGive a reason for your answer.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "7 bananas, because the coefficient of b is 7",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "7 bananas" },
            { "mark": "B1", "desc": "Give a reason: the coefficient of b in 4a + 7b is 7, so there are 7 bananas" }
          ],
          "workingSteps": [
            "The expression is 4a + 7b",
            "The number of bananas is the coefficient of b = 7"
          ]
        }
      ]
    },
    {
