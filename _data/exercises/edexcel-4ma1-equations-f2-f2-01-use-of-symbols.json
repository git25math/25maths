    {
      "id": "F2-01-Q3",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "In a car park, the cost $C$ (in pounds) for parking $h$ hours is given by:\n$$C = 1.50 + 0.80h$$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the cost of parking for 3 hours.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "3.90",
          "tolerance": 0.01,
          "unit": "£",
          "markScheme": [
            { "mark": "M1", "desc": "1.50 + 0.80 × 3" },
            { "mark": "A1", "desc": "£3.90 cao" }
          ],
          "workingSteps": [
            "0.80 × 3 = 2.40",
            "C = 1.50 + 2.40 = £3.90"
          ]
        },
        {
          "label": "b",
          "questionText": "Aziz pays £6.30 to park.\nWork out how many hours Aziz parked.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "6",
          "tolerance": null,
          "unit": "hours",
          "markScheme": [
            { "mark": "M1", "desc": "6.30 − 1.50 = 4.80, then 4.80 ÷ 0.80" },
            { "mark": "A1", "desc": "6 cao" }
          ],
          "workingSteps": [
            "6.30 − 1.50 = 4.80",
            "4.80 ÷ 0.80 = 6 hours"
          ]
        },
        {
          "label": "c",
          "questionText": "The car park changes its formula to $C = 2.00 + 0.75h$.\nIs parking for 4 hours cheaper or more expensive with the new formula?\nGive a reason for your answer.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "More expensive with new formula: new = £5.00, old = £4.70",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Calculates both: old = 1.50 + 3.20 = 4.70, new = 2.00 + 3.00 = 5.00" },
            { "mark": "A1", "desc": "New formula is more expensive (£5.00 > £4.70) with correct values seen" }
          ],
          "workingSteps": [
            "Old formula: C = 1.50 + 0.80 × 4 = 1.50 + 3.20 = £4.70",
            "New formula: C = 2.00 + 0.75 × 4 = 2.00 + 3.00 = £5.00",
            "£5.00 > £4.70, so the new formula is more expensive"
          ]
        }
      ]
    }
