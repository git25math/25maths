      "id": "F2-05-Q1",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "easy",
      "context": "A recipe for 4 people requires 300 g of flour, 2 eggs and 150 ml of milk.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the amount of flour needed for 6 people.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "450",
          "tolerance": null,
          "unit": "g",
          "markScheme": [
            { "mark": "M1", "desc": "300 ÷ 4 × 6 or equivalent scaling" },
            { "mark": "A1", "desc": "450 g cao" }
          ],
          "workingSteps": [
            "Per person: 300 ÷ 4 = 75 g",
            "For 6 people: 75 × 6 = 450 g"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the number of eggs and amount of milk needed for 10 people.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "5 eggs and 375 ml",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "5 eggs (2 ÷ 4 × 10 = 5)" },
            { "mark": "B1", "desc": "375 ml (150 ÷ 4 × 10 = 375)" }
          ],
          "workingSteps": [
            "Scale factor = 10 ÷ 4 = 2.5",
            "Eggs: 2 × 2.5 = 5 eggs",
            "Milk: 150 × 2.5 = 375 ml"
          ]
        },
        {
          "label": "c",
          "questionText": "Maria has 500 g of flour. She wants to make the recipe for as many people as possible.\nWhat is the maximum number of people she can make the recipe for?",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "6",
          "tolerance": null,
          "unit": "people",
          "markScheme": [
            { "mark": "M1", "desc": "500 ÷ 75 = 6.67..." },
            { "mark": "A1", "desc": "6 people (rounds down) cao" }
          ],
          "workingSteps": [
            "Per person = 75 g flour",
            "500 ÷ 75 = 6.67...",
            "Maximum whole number = 6 people"
          ]
        }
      ]
    },
