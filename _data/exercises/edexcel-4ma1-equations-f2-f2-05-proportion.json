    {
      "id": "F2-05-Q3",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "The number of pages $P$ a printer prints is directly proportional to the time $t$ (in minutes).\nWhen $t = 4$, $P = 60$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the value of $P$ when $t = 7$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "105",
          "tolerance": null,
          "unit": "pages",
          "markScheme": [
            { "mark": "M1", "desc": "Rate = 60 ÷ 4 = 15 pages per minute; P = 15 × 7" },
            { "mark": "A1", "desc": "105 cao" }
          ],
          "workingSteps": [
            "Rate = 60 ÷ 4 = 15 pages per minute",
            "P = 15 × 7 = 105 pages"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the time needed to print 225 pages.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "15",
          "tolerance": null,
          "unit": "minutes",
          "markScheme": [
            { "mark": "M1", "desc": "225 ÷ 15 = t" },
            { "mark": "A1", "desc": "15 minutes cao" }
          ],
          "workingSteps": [
            "t = 225 ÷ 15 = 15 minutes"
          ]
        },
        {
          "label": "c",
          "questionText": "Write a formula for $P$ in terms of $t$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "P = 15t",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "P ∝ t stated or k = 15 found" },
            { "mark": "B1", "desc": "P = 15t cao" }
          ],
          "workingSteps": [
            "P ∝ t means P = kt",
            "k = P ÷ t = 60 ÷ 4 = 15",
            "Formula: P = 15t"
          ]
        }
      ]
    }
  ]
