    {
      "id": "H6-03-Q1",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "medium",
      "context": "A bag contains 5 red balls and 3 blue balls.\nTwo balls are selected at random, without replacement.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Complete the tree diagram.\nFirst selection branches: P(red) = 5/8, P(blue) = 3/8.\nSecond selection branches depend on the first.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "table-fill",
          "correctAnswer": "After red: P(red)=4/7, P(blue)=3/7. After blue: P(red)=5/7, P(blue)=2/7.",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "After red: P(red)=4/7 and P(blue)=3/7" },
            { "mark": "B1", "desc": "After blue: P(red)=5/7 and P(blue)=2/7" }
          ],
          "workingSteps": [
            "After red: 4 red and 3 blue remain → P(red)=4/7, P(blue)=3/7",
            "After blue: 5 red and 2 blue remain → P(red)=5/7, P(blue)=2/7"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the probability that both balls are red.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "20/56",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "5/8 × 4/7" },
            { "mark": "A1", "desc": "20/56 = 5/14" }
          ],
          "workingSteps": [
            "P(red, red) = 5/8 × 4/7 = 20/56 = 5/14"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the probability that the two balls are different colours.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "30/56",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "P(red then blue) = 5/8 × 3/7 = 15/56" },
            { "mark": "M1", "desc": "P(blue then red) = 3/8 × 5/7 = 15/56" },
            { "mark": "A1", "desc": "15/56 + 15/56 = 30/56 = 15/28" }
          ],
          "workingSteps": [
            "P(red then blue) = 5/8 × 3/7 = 15/56",
            "P(blue then red) = 3/8 × 5/7 = 15/56",
            "P(different) = 15/56 + 15/56 = 30/56 = 15/28"
          ]
        },
        {
          "label": "d",
          "questionText": "Show that P(both same colour) + P(different colours) = 1.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "show-that",
          "correctAnswer": "1",
          "markScheme": [
            { "mark": "B1", "desc": "P(both red) + P(both blue) = 20/56 + 6/56 = 26/56; 26/56 + 30/56 = 56/56 = 1 ✓" }
          ],
          "workingSteps": [
            "P(both blue) = 3/8 × 2/7 = 6/56",
            "P(same colour) = 20/56 + 6/56 = 26/56",
            "P(same) + P(different) = 26/56 + 30/56 = 56/56 = 1 ✓"
          ]
        }
      ]
    },
    {
      "id": "H6-03-Q2",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "A company tests electronic components. From past data:\n- P(component passes test) = 0.92\n- If a component fails, it is retested once.\n- P(passes retest | failed first test) = 0.6",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the probability that a component fails both the test and the retest.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.032",
          "tolerance": 0.001,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "P(fails first) = 1 − 0.92 = 0.08" },
            { "mark": "M1", "desc": "P(fails retest | failed) = 1 − 0.6 = 0.4" },
            { "mark": "A1", "desc": "0.08 × 0.4 = 0.032" }
          ],
          "workingSteps": [
            "P(fails first test) = 1 − 0.92 = 0.08",
            "P(fails retest | failed) = 1 − 0.6 = 0.4",
            "P(fails both) = 0.08 × 0.4 = 0.032"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the probability that a component is accepted (passes first test OR passes retest).",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.968",
          "tolerance": 0.001,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "P(passes retest) = 0.08 × 0.6 = 0.048" },
            { "mark": "M1", "desc": "P(accepted) = P(passes 1st) + P(passes retest)" },
            { "mark": "A1", "desc": "0.92 + 0.048 = 0.968 or 1 − 0.032 = 0.968" }
          ],
          "workingSteps": [
            "P(passes retest) = 0.08 × 0.6 = 0.048",
            "P(accepted) = 0.92 + 0.048 = 0.968",
            "Check: 0.968 + 0.032 = 1 ✓"
          ]
        },
        {
          "label": "c",
          "questionText": "In a batch of 500 components, work out the expected number that will be rejected.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "16",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "500 × 0.032" },
            { "mark": "A1", "desc": "16" }
          ],
          "workingSteps": [
            "Expected rejected = 500 × 0.032 = 16"
          ]
        }
      ]
    },
