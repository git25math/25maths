    {
      "id": "E3-01-Q1",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "A(0, 0), B(6, 0) and C(0, 8) are vertices of a triangle.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Calculate the length of BC.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "integer",
          "correctAnswer": "10",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "BC² = 6² + 8² = 100"
            },
            {
              "mark": "M1",
              "desc": "√100"
            },
            {
              "mark": "A1",
              "desc": "10"
            }
          ],
          "workingSteps": [
            "BC² = (6-0)² + (0-8)² = 36 + 64 = 100",
            "BC = 10"
          ]
        },
        {
          "label": "b",
          "questionText": "Show that angle BAC = 90°.",
          "marks": 2,
          "commandWord": "show",
          "answerType": "show-that",
          "correctAnswer": "AB² + AC² = BC²",
          "markScheme": [
            {
              "mark": "M1",
              "desc": "AB² + AC² = 36 + 64 = 100"
            },
            {
              "mark": "A1",
              "desc": "= BC² = 100, so right angle at A"
            }
          ],
          "workingSteps": [
            "AB = 6, AC = 8, BC = 10",
            "AB² + AC² = 36 + 64 = 100 = BC²",
            "By converse of Pythagoras, angle A = 90°"
          ]
        },
        {
          "label": "c",
          "questionText": "Find the equation of the line BC.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "y = −4x/3 + 8",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "m = (0−8)/(6−0) = −4/3"
            },
            {
              "mark": "M1",
              "desc": "c = 8 (passes through (0,8))"
            },
            {
              "mark": "A1",
              "desc": "y = −4x/3 + 8"
            }
          ],
          "workingSteps": [
            "m = (0−8)/(6−0) = −8/6 = −4/3",
            "Passes through C(0,8) so c = 8",
            "y = −4x/3 + 8"
          ]
        }
      ]
    },
    {
      "id": "E3-01-Q2",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "P(1, 5) and Q(7, −3) are the ends of a diameter of a circle.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the centre and radius of the circle.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "coordinate",
          "correctAnswer": "(4, 1), r = 5",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "B1",
              "desc": "Centre = (4, 1)"
            },
            {
              "mark": "M1",
              "desc": "r² = (7−4)² + (−3−1)² = 9 + 16"
            },
            {
              "mark": "M1",
              "desc": "r² = 25"
            },
            {
              "mark": "A1",
              "desc": "r = 5"
            }
          ],
          "workingSteps": [
            "Centre = midpoint = ((1+7)/2, (5−3)/2) = (4, 1)",
            "r² = 3² + 4² = 25",
            "r = 5"
          ]
        },
        {
          "label": "b",
          "questionText": "Show that the point R(6, 5) does not lie on the circle.",
          "marks": 2,
          "commandWord": "show",
          "answerType": "show-that",
          "correctAnswer": "Distance from centre ≠ radius",
          "markScheme": [
            {
              "mark": "M1",
              "desc": "dist(centre, R)² = (6−4)² + (5−1)² = 4+16 = 20"
            },
            {
              "mark": "A1",
              "desc": "√20 ≈ 4.47 ≠ 5, so R is not on the circle"
            }
          ],
          "workingSteps": [
            "Distance from (4,1) to (6,5) = √(4+16) = √20 = 4.47",
            "4.47 ≠ 5 (radius), so R is not on the circle"
          ]
        },
        {
          "label": "c",
          "questionText": "Find the equation of the tangent to the circle at P.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "y = 3x/4 + 17/4",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "Gradient CP = (5−1)/(1−4) = −4/3, tangent gradient = 3/4"
            },
            {
              "mark": "A1",
              "desc": "y − 5 = 3/4(x − 1) → y = 3x/4 + 17/4"
            }
          ],
          "workingSteps": [
            "Gradient of radius CP = (5−1)/(1−4) = 4/(−3) = −4/3",
            "Tangent ⊥ radius, so tangent gradient = 3/4",
            "y − 5 = ¾(x − 1) → y = ¾x + 17/4"
          ]
        }
      ]
    }
  ]
}