    {
      "id": "E6-02-Q1",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "A vertical flagpole is 12 m tall.\nA wire runs from the top of the flagpole to a point on the ground 9 m from the base.\nCalculate the angle the wire makes with the ground.",
      "answerType": "numeric",
      "correctAnswer": "53.1",
      "tolerance": 0.1,
      "unit": "°",
      "markScheme": [
        { "mark": "M1", "desc": "tan θ = 12/9 oe" },
        { "mark": "M1", "desc": "tan⁻¹(12/9)" },
        { "mark": "A1", "desc": "53.1° or 53.13°" }
      ],
      "workingSteps": [
        "tan θ = opposite/adjacent = 12/9",
        "θ = tan⁻¹(4/3) = 53.1°"
      ],
      "explanation": "Use tan and inverse tan for angle from opposite and adjacent."
    },
    {
      "id": "E6-02-Q2",
      "type": "structured",
      "totalMarks": 10,
      "difficulty": "hard",
      "context": "The diagram shows a trapezium ABCD where AB is parallel to DC.\nAB = 14 cm, DC = 8 cm, angle DAB = 90° and angle ABC = 65°.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Show that the height AD of the trapezium is 12.9 cm, correct to 3 significant figures.",
          "marks": 3,
          "commandWord": "show",
          "answerType": "show-that",
          "correctAnswer": "12.9",
          "markScheme": [
            { "mark": "M1", "desc": "Drops perpendicular from C or D, identifies the 6 cm base" },
            { "mark": "M1", "desc": "AD = (14−8) × tan65 or 6 × tan65" },
            { "mark": "A1", "desc": "12.86... → 12.9 (3sf) with no errors" }
          ],
          "workingSteps": [
            "Drop perpendicular from C to AB at point E, then BE = DC = 8 cm",
            "AE = AB − DC = 14 − 8 = 6 cm",
            "AD = AE × tan65° = 6 × 2.145 = 12.87 cm ≈ 12.9 cm (3sf)"
          ]
        },
        {
          "label": "b",
          "questionText": "Calculate the length of BC.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "14.2",
          "tolerance": 0.1,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "cos65 = 6/BC or sin65 = 12.9/BC oe" },
            { "mark": "M1", "desc": "BC = 6/cos65 or BC = 12.9/sin65" },
            { "mark": "A1", "desc": "14.2 or 14.19 to 14.20" }
          ],
          "workingSteps": [
            "cos65° = 6/BC",
            "BC = 6 / cos65° = 6 / 0.4226 = 14.2 cm"
          ]
        },
        {
          "label": "c",
          "questionText": "Calculate the area of the trapezium.",
          "marks": 2,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "142",
          "tolerance": 1,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "½ × (14 + 8) × their 12.9" },
            { "mark": "A1", "desc": "141 to 142" }
          ],
          "workingSteps": [
            "Area = ½ × (AB + DC) × AD = ½ × (14 + 8) × 12.9",
            "= ½ × 22 × 12.9 = 141.9 cm²"
          ]
        },
        {
          "label": "d",
          "questionText": "Calculate angle ACD.",
          "marks": 2,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "58.2",
          "tolerance": 0.1,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "tan(ACD) = 12.9/8 oe" },
            { "mark": "A1", "desc": "58.2° or 58.17° to 58.18°" }
          ],
          "workingSteps": [
            "In triangle ACD: AD = 12.9, DC = 8, angle ADC = 90°",
            "tan(ACD) = AD/DC = 12.9/8 = 1.6125",
            "Angle ACD = tan⁻¹(1.6125) = 58.2°"
          ]
        }
      ]
    },
    {
      "id": "E6-02-Q3",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "From the top of a cliff 45 m high, the angle of depression to a boat at sea is 28°.\nCalculate the horizontal distance from the base of the cliff to the boat.",
      "answerType": "numeric",
      "correctAnswer": "84.6",
      "tolerance": 0.1,
      "unit": "m",
      "markScheme": [
        { "mark": "M1", "desc": "tan28 = 45/d oe" },
        { "mark": "M1", "desc": "d = 45/tan28" },
        { "mark": "A1", "desc": "84.6 or 84.63" }
      ],
      "workingSteps": [
        "tan28° = 45/d (angle of depression = angle of elevation)",
        "d = 45 / tan28° = 45 / 0.5317 = 84.6 m"
      ],
      "explanation": "Angle of depression from top = angle of elevation from boat (alternate angles)."
    },
    {
      "id": "E6-02-Q4",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": "Two buildings P and Q are on level ground, 50 m apart.\nBuilding P is 35 m tall and building Q is 20 m tall.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Calculate the angle of elevation from the top of building Q to the top of building P.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "16.7",
          "tolerance": 0.1,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "Height difference = 35 − 20 = 15 soi" },
            { "mark": "M1", "desc": "tan θ = 15/50" },
            { "mark": "A1", "desc": "16.7° or 16.70°" }
          ],
          "workingSteps": [
            "Height difference = 35 − 20 = 15 m",
            "tan θ = 15/50 = 0.3",
            "θ = tan⁻¹(0.3) = 16.7°"
          ]
        },
        {
          "label": "b",
          "questionText": "A tightrope is stretched from the top of P to the top of Q.\nCalculate the length of the tightrope.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "52.2",
          "tolerance": 0.1,
          "unit": "m",
          "markScheme": [
            { "mark": "M1", "desc": "15² + 50² soi" },
            { "mark": "M1", "desc": "√(225 + 2500) or √2725" },
            { "mark": "A1", "desc": "52.2 or 52.20" }
          ],
          "workingSteps": [
            "L² = 15² + 50² = 225 + 2500 = 2725",
            "L = √2725 = 52.2 m"
          ]
        },
        {
          "label": "c",
          "questionText": "Give a reason why the actual tightrope would need to be longer than your answer to part (b).",
          "marks": 1,
          "commandWord": "explain",
          "answerType": "explain",
          "correctAnswer": "The tightrope would sag under its own weight",
          "markScheme": [
            { "mark": "B1", "desc": "Sag / not taut / weight oe" }
          ],
          "workingSteps": []
        }
      ]
    }
