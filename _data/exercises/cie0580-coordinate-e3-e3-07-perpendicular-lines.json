    {
      "id": "E3-07-Q3",
      "type": "short-answer",
      "totalMarks": 6,
      "commandWord": "show",
      "difficulty": "hard",
      "questionText": "The lines $y = 2x$, $y = -\\frac{x}{2} + 5$ and $y = 3$ form a triangle.\n(a) Show that one angle of the triangle is 90°.\n(b) Find the area of the triangle.",
      "answerType": "show-that",
      "correctAnswer": "Area = 1.25",
      "markScheme": [
        {
          "mark": "M1",
          "desc": "Gradients: 2 and −1/2"
        },
        {
          "mark": "A1",
          "desc": "Product = 2 × (−1/2) = −1, so perpendicular at their intersection"
        },
        {
          "mark": "M1",
          "desc": "Intersection of y=2x and y=3: (1.5, 3)"
        },
        {
          "mark": "M1",
          "desc": "Intersection of y=−x/2+5 and y=3: (4, 3)"
        },
        {
          "mark": "M1",
          "desc": "Base = 4 − 1.5 = 2.5, height = 4 − 3 = 1"
        },
        {
          "mark": "A1",
          "desc": "Area = ½ × 2.5 × 1 = 1.25"
        }
      ],
      "workingSteps": [
        "Gradients of y=2x and y=−x/2+5: 2 × (−1/2) = −1 → perpendicular → right angle",
        "Intersection of y=2x and y=−x/2+5: 2x = −x/2+5, 5x/2=5, x=2, y=4 → (2,4)",
        "Intersection of y=2x and y=3: x=1.5 → (1.5, 3)",
        "Intersection of y=−x/2+5 and y=3: x=4 → (4, 3)",
        "Base on y=3: 4−1.5=2.5, height from (2,4) to y=3: 1",
        "Area = ½ × 2.5 × 1 = 1.25"
      ],
      "explanation": "Two lines are perpendicular if product of gradients = −1."
    }
