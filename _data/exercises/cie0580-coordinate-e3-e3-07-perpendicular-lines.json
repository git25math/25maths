      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "Line L has equation $y = 2x + 1$.\nFind the equation of the line perpendicular to L that passes through (4, 3).",
      "answerType": "expression",
      "correctAnswer": "y = −x/2 + 5",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "Perpendicular gradient = −1/2"
        },
        {
          "mark": "M1",
          "desc": "3 = −½(4) + c → c = 5"
        },
        {
          "mark": "A1",
          "desc": "y = −x/2 + 5"
        }
      ],
      "workingSteps": [
        "L gradient = 2, perpendicular gradient = −1/2",
        "y = −x/2 + c, (4,3): 3 = −2 + c, c = 5",
        "y = −x/2 + 5"
      ],
      "explanation": "Perpendicular gradients multiply to −1."
    },
