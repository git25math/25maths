    {
      "id": "F2-08-Q2",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "A train can carry at most 250 passengers.\nThere are $a$ adults and $c$ children on the train.\nThere are at least 30 more adults than children.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write down two inequalities to represent this situation.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "a + c <= 250 and a >= c + 30",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "a + c ≤ 250 oe" },
            { "mark": "B1", "desc": "a ≥ c + 30 oe (or a − c ≥ 30)" }
          ],
          "workingSteps": [
            "Total passengers ≤ 250: a + c ≤ 250",
            "Adults at least 30 more than children: a ≥ c + 30"
          ]
        },
        {
          "label": "b",
          "questionText": "There are 80 children on the train.\nWork out the minimum number of adults.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "110",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "a ≥ 80 + 30 = 110" },
            { "mark": "A1", "desc": "110 cao" }
          ],
          "workingSteps": [
            "a ≥ c + 30 = 80 + 30 = 110",
            "Minimum number of adults = 110"
          ]
        },
        {
          "label": "c",
          "questionText": "With 80 children on the train, work out the maximum number of adults.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "170",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "a + 80 ≤ 250 → a ≤ 170" },
            { "mark": "A1", "desc": "170 cao" }
          ],
          "workingSteps": [
            "a + c ≤ 250 → a + 80 ≤ 250",
            "a ≤ 170",
            "Maximum number of adults = 170"
          ]
        }
      ]
    },
