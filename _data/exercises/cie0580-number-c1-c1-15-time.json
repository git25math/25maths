      "correctAnswer": "21:40",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "$7\\text{:}45$ pm $= 19\\text{:}45$" },
        { "mark": "M1", "desc": "$19\\text{:}45 + 1\\text{h }55\\text{min}$" },
        { "mark": "A1", "desc": "$21\\text{:}40$ cao" }
