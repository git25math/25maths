      "difficulty": "easy",
      "questionText": "Find the gradient of the line passing through (1, 3) and (5, 11).",
      "answerType": "integer",
      "correctAnswer": "2",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "(11−3)/(5−1) = 8/4"
        },
        {
          "mark": "A1",
          "desc": "2"
        }
      ],
      "workingSteps": [
        "Gradient = (y₂−y₁)/(x₂−x₁) = (11−3)/(5−1) = 8/4 = 2"
      ],
      "explanation": "Gradient = rise/run."
    },
    {
      "id": "C3-03-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "A line has equation $y = 3x - 7$.\n(a) Write down the gradient.\n(b) Write down the y-intercept.\n(c) Does the point (4, 5) lie on this line?",
      "answerType": "numeric",
      "correctAnswer": "3, −7, yes",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "B1",
          "desc": "(a) 3"
        },
        {
          "mark": "B1",
          "desc": "(b) −7"
        },
        {
          "mark": "B1",
          "desc": "(c) Yes: 3(4)−7 = 5 ✓"
        }
      ],
      "workingSteps": [
        "(a) gradient = 3 (coefficient of x)",
        "(b) y-intercept = −7",
        "(c) When x=4: y = 12−7 = 5. Yes, (4,5) lies on the line."
      ],
      "explanation": "For y = mx + c: m is gradient, c is y-intercept."
    },
