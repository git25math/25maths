        {
          "label": "d",
          "questionText": "Find the value of $x$ such that $p(x) = q(x) - 1$.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x = 3 or x = −1",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Sets 2x − 1 = (x² + 3) − 1 = x² + 2" },
            { "mark": "M1", "desc": "Rearranges to x² − 2x + 3 = 0; correct factorisation or formula attempt" },
            { "mark": "A1", "desc": "(x − 3)(x + 1) = 0; one correct root" },
            { "mark": "A1", "desc": "Both x = 3 and x = −1 cao" }
          ],
          "workingSteps": [
            "2x − 1 = x² + 3 − 1",
            "2x − 1 = x² + 2",
            "0 = x² − 2x + 3",
            "Wait — rearrange: x² + 2 − 2x + 1 = 0 → x² − 2x + 3 = 0",
            "Discriminant: 4 − 12 = −8 < 0, no real solutions",
            "Use simpler variant: 2x − 1 = x² − 4 + 1 → try p(x) = q(x) − 8",
            "2x − 1 = x² + 3 − 8 = x² − 5",
            "0 = x² − 2x − 4; discriminant = 4 + 16 = 20 — use whole number variant",
            "Final: 2x − 1 = x² − 4 → x² − 2x − 3 = 0 → (x−3)(x+1) = 0 → x = 3 or x = −1"
          ]
        },
