      "context": "$f(x) = 3x + 2$ and $g(x) = x^2 - 5$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out $f(0)$.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "2",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "2 cao" }
          ],
          "workingSteps": [
            "f(0) = 3(0) + 2 = 2"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out $g(-4)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "11",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes x = −4 into x² − 5; (−4)² = 16" },
            { "mark": "A1", "desc": "11 cao" }
          ],
          "workingSteps": [
            "g(−4) = (−4)² − 5 = 16 − 5 = 11"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out $f(g(3))$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "14",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Works out g(3) = 9 − 5 = 4" },
            { "mark": "M1", "desc": "Substitutes their g(3) into f: f(4) = 3(4) + 2" },
            { "mark": "A1", "desc": "14 cao" }
          ],
          "workingSteps": [
            "g(3) = 3² − 5 = 9 − 5 = 4",
            "f(g(3)) = f(4) = 3(4) + 2 = 12 + 2 = 14"
          ]
        },
        {
          "label": "d",
          "questionText": "Find the value of $x$ for which $f(x) = g(x) + 3$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x = 4 or x = −1",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Sets 3x + 2 = (x² − 5) + 3, i.e. 3x + 2 = x² − 2" },
            { "mark": "M1", "desc": "Rearranges to x² − 3x − 4 = 0; attempts factorisation" },
            { "mark": "A1", "desc": "(x − 4)(x + 1) = 0; both x = 4 and x = −1 cao" }
          ],
          "workingSteps": [
            "3x + 2 = x² − 5 + 3",
            "3x + 2 = x² − 2",
            "0 = x² − 3x − 4",
            "(x − 4)(x + 1) = 0",
            "x = 4 or x = −1",
            "Check x = 4: f(4) = 14, g(4) + 3 = 11 + 3 = 14 ✓",
            "Check x = −1: f(−1) = −1, g(−1) + 3 = (1 − 5) + 3 = −1 ✓"
          ]
        }
      ]
    }
