        {
          "label": "c",
          "questionText": "Solve $\\dfrac{x+1}{x-2} - \\dfrac{x-1}{x+2} = 1$. Give your answers correct to 2 decimal places.",
          "marks": 4,
          "commandWord": "solve",
          "answerType": "expression",
          "correctAnswer": "$x = 6.61$ or $x = -0.61$",
          "tolerance": 0.01,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Common denominator $(x-2)(x+2)$ used" },
            { "mark": "M1", "desc": "Numerator simplified to $6x$; equation becomes $6x = x^2-4$" },
            { "mark": "A1", "desc": "$x^2-6x-4 = 0$" },
            { "mark": "A1", "desc": "$x = 3 \\pm \\sqrt{13} = 6.61$ or $-0.61$ (2dp)" }
          ],
          "workingSteps": [
            "$\\dfrac{(x+1)(x+2)-(x-1)(x-2)}{(x-2)(x+2)} = 1$",
            "$(x+1)(x+2) = x^2+3x+2$",
            "$(x-1)(x-2) = x^2-3x+2$",
            "Numerator: $(x^2+3x+2)-(x^2-3x+2) = 6x$",
            "$\\dfrac{6x}{x^2-4}=1 \\Rightarrow 6x = x^2-4$",
            "$x^2-6x-4=0$",
            "$x = \\dfrac{6 \\pm \\sqrt{36+16}}{2} = \\dfrac{6 \\pm \\sqrt{52}}{2} = 3 \\pm \\sqrt{13}$",
            "$x = 3+3.606=6.61$ or $x=3-3.606=-0.61$ (2dp)"
          ]
        }
      ]
