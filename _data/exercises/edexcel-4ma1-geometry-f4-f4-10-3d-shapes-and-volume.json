        {
          "label": "b",
          "questionText": "Work out the total surface area of the cuboid.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "158",
          "tolerance": null,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "3 pairs of faces: 2(8×5) + 2(8×3) + 2(5×3)" },
            { "mark": "M1", "desc": "= 80 + 48 + 30" },
            { "mark": "A1", "desc": "158 cm²" }
          ],
          "workingSteps": [
            "Top & bottom: 2 × (8 × 5) = 80 cm²",
            "Front & back: 2 × (8 × 3) = 48 cm²",
            "Left & right: 2 × (5 × 3) = 30 cm²",
            "Total = 80 + 48 + 30 = 158 cm²"
          ]
        },
