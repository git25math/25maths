        { "mark": "A1", "desc": "6/36 = 1/6" }
      ],
      "workingSteps": [
        "Total outcomes = 6 × 6 = 36",
        "(a) Sum = 7: (1,6),(2,5),(3,4),(4,3),(5,2),(6,1) → 6/36 = 1/6",
        "(b) Sum ≥ 10: (4,6),(5,5),(5,6),(6,4),(6,5),(6,6) → 6/36 = 1/6"
