      "parts": [
        {
          "label": "a",
          "questionText": "it rains on all 3 days.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.027",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "0.3 × 0.3 × 0.3" },
            { "mark": "A1", "desc": "0.027" }
          ],
          "workingSteps": ["P(RRR) = 0.3³ = 0.027"]
        },
        {
          "label": "b",
          "questionText": "it rains on exactly one day.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.441",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "P(one rain day) = 0.3 × 0.7 × 0.7 = 0.147" },
            { "mark": "M1", "desc": "3 arrangements (RDD, DRD, DDR)" },
            { "mark": "A1", "desc": "3 × 0.147 = 0.441" }
          ],
          "workingSteps": [
            "P(rain exactly 1 day) = 3 × 0.3 × 0.7² = 3 × 0.147 = 0.441"
          ]
        },
        {
          "label": "c",
          "questionText": "it does not rain at all.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.343",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "0.7³ = 0.343" }
          ],
          "workingSteps": ["P(no rain) = 0.7³ = 0.343"]
        },
        {
          "label": "d",
          "questionText": "it rains on at least 2 days.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.216",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "1 − P(0 days) − P(1 day) = 1 − 0.343 − 0.441" },
