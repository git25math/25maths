    {
      "id": "E8-03-Q1",
      "type": "structured",
      "totalMarks": 10,
      "difficulty": "hard",
      "context": "A bag contains 5 red balls and 3 blue balls.\nTwo balls are taken at random without replacement.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Complete the tree diagram showing the probabilities.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "table-fill",
          "correctAnswer": ["5/8", "3/8", "4/7", "3/7", "5/7", "2/7"],
          "markScheme": [
            { "mark": "B1", "desc": "First pick: 5/8 (R), 3/8 (B)" },
            { "mark": "B1", "desc": "Second pick: R→R 4/7, R→B 3/7; B→R 5/7, B→B 2/7" }
          ],
          "workingSteps": [
            "Without replacement: after picking R, 4R and 3B remain (7 total)",
            "After picking B, 5R and 2B remain (7 total)"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the probability that both balls are the same colour.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "13/28",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "P(RR) = 5/8 × 4/7 = 20/56" },
            { "mark": "M1", "desc": "P(BB) = 3/8 × 2/7 = 6/56" },
            { "mark": "M1", "desc": "P(same) = 20/56 + 6/56" },
            { "mark": "A1", "desc": "26/56 = 13/28" }
          ],
          "workingSteps": [
            "P(RR) = 5/8 × 4/7 = 20/56",
            "P(BB) = 3/8 × 2/7 = 6/56",
            "P(same) = 20/56 + 6/56 = 26/56 = 13/28"
          ]
        },
        {
          "label": "c",
          "questionText": "Find the probability that at least one ball is red.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "25/28",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "P(at least one R) = 1 − P(BB)" },
            { "mark": "M1", "desc": "P(BB) = 3/8 × 2/7 = 6/56 = 3/28" },
            { "mark": "M1", "desc": "1 − 3/28" },
            { "mark": "A1", "desc": "25/28" }
          ],
          "workingSteps": [
            "P(no red) = P(BB) = 3/8 × 2/7 = 6/56 = 3/28",
            "P(at least one red) = 1 − 3/28 = 25/28"
          ]
        }
      ]
    },
    {
