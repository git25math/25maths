              "desc": "5/12 × 144π"
            },
            {
              "mark": "A1",
              "desc": "60π = 188"
            }
          ],
          "workingSteps": [
            "Area = (150/360) × π × 12² = (5/12) × 144π = 60π = 188 cm²"
          ]
        },
        {
          "label": "c",
          "questionText": "Calculate the area of the triangle OAB.",
          "marks": 2,
