              "mark": "M1",
              "desc": "5/12 × 24π"
            },
            {
              "mark": "A1",
              "desc": "31.4"
            }
          ],
          "workingSteps": [
            "Arc = (150/360) × 2π × 12 = (5/12) × 24π = 10π = 31.4 cm"
          ]
        },
        {
          "label": "b",
          "questionText": "Calculate the area of the sector.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "188",
          "tolerance": 1,
          "unit": "cm²",
          "markScheme": [
