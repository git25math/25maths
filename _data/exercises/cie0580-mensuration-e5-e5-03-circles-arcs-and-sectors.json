            },
            {
              "mark": "A1",
              "desc": "½ × 144 × 0.5 = 36"
            }
          ],
          "workingSteps": [
            "Area = ½r²sinθ = ½ × 12² × sin150° = ½ × 144 × 0.5 = 36 cm²"
          ]
        },
        {
          "label": "d",
          "questionText": "Hence calculate the area of the segment (the region between the chord AB and the arc AB).",
