          "questionText": "Calculate the arc length AB.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "31.4",
          "tolerance": 0.1,
          "unit": "cm",
          "markScheme": [
            {
              "mark": "M1",
              "desc": "150/360 × 2π × 12"
            },
