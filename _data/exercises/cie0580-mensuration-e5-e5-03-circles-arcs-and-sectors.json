      "commandWord": "show",
      "difficulty": "hard",
      "questionText": "A sector has perimeter 20 cm and radius $r$ cm.\nThe angle of the sector is $\\theta$ degrees.\nShow that $\\theta = \\frac{360(20 - 2r)}{2\\pi r}$.",
      "answerType": "show-that",
      "correctAnswer": "θ = 360(20 − 2r)/(2πr)",
      "markScheme": [
        {
          "mark": "M1",
          "desc": "Perimeter = 2r + arc = 20"
        },
        {
          "mark": "M1",
          "desc": "Arc = 20 − 2r"
        },
        {
          "mark": "M1",
          "desc": "(θ/360) × 2πr = 20 − 2r"
        },
        {
          "mark": "A1",
          "desc": "θ = 360(20 − 2r)/(2πr) with no errors"
        }
      ],
      "workingSteps": [
        "Perimeter = 2r + arc length",
        "20 = 2r + (θ/360) × 2πr",
        "(θ/360) × 2πr = 20 − 2r",
        "θ = 360(20 − 2r) / (2πr)"
      ],
      "explanation": "Express arc in terms of θ and r, then rearrange."
