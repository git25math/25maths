      "id": "E3-06-Q1",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "The line $3x + 4y = 20$ is parallel to the line $3x + 4y = k$.\nThe second line passes through the point (2, −1).\nFind the value of $k$.",
      "answerType": "integer",
      "correctAnswer": "2",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "Parallel lines have form 3x + 4y = k (same coefficients)"
        },
        {
          "mark": "M1",
          "desc": "Sub (2,−1): 3(2) + 4(−1) = 6 − 4 = 2"
        },
        {
          "mark": "A1",
          "desc": "k = 2"
        }
      ],
      "workingSteps": [
        "Lines are already in parallel form (same x,y coefficients)",
        "k = 3(2) + 4(−1) = 6 − 4 = 2"
      ],
      "explanation": "Parallel lines: ax + by = c₁ and ax + by = c₂ (same a, b, different c)."
    },
    {
      "id": "E3-06-Q2",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": "ABCD is a parallelogram where A(1, 2), B(5, 4) and C(7, 1).",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the gradient of AB.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "1/2",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "(4−2)/(5−1)"
            },
            {
              "mark": "A1",
              "desc": "1/2"
            }
          ],
          "workingSteps": [
            "m_AB = (4−2)/(5−1) = 2/4 = 1/2"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the coordinates of D.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "coordinate",
          "correctAnswer": "(3, −1)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "D = A + C − B (parallelogram vector rule)"
            },
            {
              "mark": "M1",
              "desc": "D = (1+7−5, 2+1−4)"
            },
            {
              "mark": "A1",
              "desc": "(3, −1)"
            }
          ],
          "workingSteps": [
            "In parallelogram: AD = BC",
            "D = A + (C − B) = (1, 2) + (2, −3) = (3, −1)"
          ]
        },
        {
          "label": "c",
          "questionText": "Verify that DC is parallel to AB.",
          "marks": 2,
          "commandWord": "show",
          "answerType": "show-that",
          "correctAnswer": "Gradient DC = 1/2 = gradient AB",
          "markScheme": [
            {
              "mark": "M1",
              "desc": "m_DC = (1−(−1))/(7−3) = 2/4 = 1/2"
            },
            {
              "mark": "A1",
              "desc": "= m_AB, so parallel"
            }
          ],
          "workingSteps": [
            "Gradient DC = (1−(−1))/(7−3) = 2/4 = 1/2",
            "Gradient AB = 1/2",
            "Equal gradients → parallel"
          ]
        }
      ]
    },
    {
      "id": "E3-06-Q3",
      "type": "short-answer",
      "totalMarks": 4,
      "commandWord": "find",
      "difficulty": "hard",
      "questionText": "Line L has equation $2y − x = 6$.\nFind the equation of the line parallel to L that passes through (4, −1).\nGive your answer in the form $y = mx + c$.",
      "answerType": "expression",
      "correctAnswer": "y = x/2 − 3",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "L: 2y = x + 6, y = x/2 + 3, gradient = 1/2"
        },
        {
          "mark": "M1",
          "desc": "Parallel → m = 1/2"
        },
        {
          "mark": "M1",
          "desc": "−1 = ½(4) + c → c = −3"
        },
        {
          "mark": "A1",
          "desc": "y = x/2 − 3"
        }
      ],
      "workingSteps": [
        "L: y = x/2 + 3, gradient = 1/2",
        "Parallel line: y = x/2 + c",
        "Sub (4,−1): −1 = 2 + c, c = −3",
        "y = x/2 − 3"
      ],
      "explanation": "Parallel = same gradient, find c from the given point."
    }
  ]
