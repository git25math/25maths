      "id": "C1-02-Q1",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "write-down",
      "difficulty": "easy",
      "questionText": "$A = \\{1, 2, 3, 4, 5, 6\\}$ and $B = \\{2, 4, 6, 8, 10\\}$.\n\nWrite down the elements of\n(a) $A \\cap B$\n(b) $A \\cup B$",
      "answerType": "set-notation",
      "correctAnswer": "(a) {2, 4, 6}  (b) {1, 2, 3, 4, 5, 6, 8, 10}",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "$A \\cap B = \\{2, 4, 6\\}$" },
        { "mark": "B1", "desc": "$A \\cup B = \\{1, 2, 3, 4, 5, 6, 8, 10\\}$" },
        { "mark": "B1", "desc": "Both correct and no extra elements listed" }
      ],
      "workingSteps": [
        "Intersection: elements in BOTH sets → 2, 4, 6",
        "Union: elements in EITHER set → 1, 2, 3, 4, 5, 6, 8, 10"
      ],
      "explanation": "∩ means 'and' (in both); ∪ means 'or' (in at least one)."
    },
    {
      "id": "C1-02-Q2",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "medium",
      "context": "In a class of 30 students, 18 study French (F) and 14 study Spanish (S). 5 students study both subjects.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Complete a Venn diagram to represent this information.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "French only = 13, Both = 5, Spanish only = 9, Neither = 3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Both = 5 placed correctly" },
            { "mark": "B1", "desc": "French only = 13" },
            { "mark": "B1", "desc": "Spanish only = 9" }
          ],
          "workingSteps": [
            "French only = 18 − 5 = 13",
            "Spanish only = 14 − 5 = 9",
            "Neither = 30 − 13 − 5 − 9 = 3"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the number of students who study neither French nor Spanish.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "30 − (13 + 5 + 9) or 30 − 27" },
            { "mark": "A1", "desc": "3 cao" }
          ],
          "workingSteps": [
            "Total accounted for = 13 + 5 + 9 = 27",
            "Neither = 30 − 27 = 3"
          ]
        },
        {
          "label": "c",
          "questionText": "A student is chosen at random.\nWrite down the probability that this student studies French but not Spanish.",
          "marks": 2,
          "commandWord": "write-down",
          "answerType": "fraction",
          "correctAnswer": "13/30",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Numerator = 13 (French only)" },
            { "mark": "B1", "desc": "$\\frac{13}{30}$ cao" }
          ],
          "workingSteps": [
