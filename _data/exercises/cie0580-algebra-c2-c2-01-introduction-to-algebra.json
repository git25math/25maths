            { "mark": "B1", "desc": "Correct formula with C as subject" }
          ],
          "workingSteps": [
            "Fixed fee: £8",
            "Cost per hour: £3, for h hours = 3h",
            "Total: C = 8 + 3h"
          ]
        },
        {
          "label": "b",
          "questionText": "Calculate the cost to hire the bicycle for 5 hours.",
          "marks": 2,
          "commandWord": "calculate",
          "answerType": "integer",
          "correctAnswer": "23",
          "tolerance": null,
          "unit": "£",
          "markScheme": [
