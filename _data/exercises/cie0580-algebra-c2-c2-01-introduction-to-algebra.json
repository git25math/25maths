            "Cost = £23"
          ]
        },
        {
          "label": "c",
          "questionText": "Tom pays £32 to hire the bicycle.\nFind the number of hours Tom hired the bicycle.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "8",
          "tolerance": null,
          "unit": "hours",
          "markScheme": [
            { "mark": "M1", "desc": "32 = 8 + 3h oe" },
            { "mark": "M1", "desc": "3h = 24" },
            { "mark": "A1", "desc": "h = 8" }
          ],
          "workingSteps": [
            "32 = 8 + 3h",
            "3h = 32 − 8 = 24",
            "h = 24 ÷ 3 = 8 hours",
            "Check: 8 + 3(8) = 8 + 24 = 32 ✓"
          ]
        }
      ]
