      "correctAnswer": "10",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "B1", "desc": "(a) 2(3) + 4 = 10" },
        { "mark": "B1", "desc": "(b) 3 × 4 − 5 = 7" }
