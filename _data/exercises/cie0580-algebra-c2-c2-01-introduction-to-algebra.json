      "workingSteps": [
        "(a) 2a + b = 2(3) + 4 = 6 + 4 = 10",
        "(b) ab − 5 = 3 × 4 − 5 = 12 − 5 = 7"
      ],
      "explanation": "Substitute the given values directly into each expression."
    },
