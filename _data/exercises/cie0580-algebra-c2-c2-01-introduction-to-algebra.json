      "commandWord": "simplify",
      "difficulty": "easy",
      "questionText": "Simplify $5x + 3y - 2x + y$.",
      "answerType": "expression",
      "correctAnswer": "$3x + 4y$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Collecting x terms: 5x − 2x = 3x" },
        { "mark": "A1", "desc": "$3x + 4y$ cao" }
      ],
      "workingSteps": [
        "x terms: 5x − 2x = 3x",
        "y terms: 3y + y = 4y",
        "Answer: 3x + 4y"
      ],
      "explanation": "Group like terms: collect x terms and y terms separately."
    },
    {
      "id": "C2-01-Q3",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "find",
      "difficulty": "easy",
      "questionText": "Find the value of $3p^2 - q$ when $p = 2$ and $q = 7$.",
      "answerType": "integer",
      "correctAnswer": "5",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Substituting p = 2: 3(2²) = 3 × 4 = 12" },
        { "mark": "M1", "desc": "Subtracting q = 7: 12 − 7" },
        { "mark": "A1", "desc": "5 cao" }
      ],
      "workingSteps": [
        "p² = 2² = 4",
        "3p² = 3 × 4 = 12",
        "3p² − q = 12 − 7 = 5"
      ],
      "explanation": "Evaluate the power first (p² = 4), multiply by 3, then subtract q."
    },
    {
