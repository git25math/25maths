    {
      "id": "F2-04-Q2",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "A supermarket sells bags of flour in two sizes.\nA small bag costs £$(2x - 1)$ and a large bag costs £$(3x + 2)$.\nThe large bag costs £6 more than the small bag.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write down an equation in $x$.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "3x + 2 = 2x - 1 + 6",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "3x + 2 = (2x − 1) + 6 oe" }
          ],
          "workingSteps": [
            "Large − Small = 6",
            "(3x + 2) − (2x − 1) = 6",
            "or equivalently: 3x + 2 = (2x − 1) + 6"
          ]
        },
        {
          "label": "b",
          "questionText": "Solve your equation to find the value of $x$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "3x + 2 = 2x + 5 → x = 3" },
            { "mark": "A1", "desc": "x = 3 cao" }
          ],
          "workingSteps": [
            "3x + 2 = 2x + 5",
            "3x − 2x = 5 − 2",
            "x = 3"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the cost of the large bag of flour.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "11",
          "tolerance": null,
          "unit": "£",
          "markScheme": [
            { "mark": "B1", "desc": "3 × 3 + 2 = 11 ft their x" }
          ],
          "workingSteps": [
            "Large bag = 3x + 2 = 3 × 3 + 2 = 9 + 2 = £11"
          ]
        },
        {
          "label": "d",
          "questionText": "Check: does the large bag cost £6 more than the small bag?\nGive a reason for your answer.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Yes: small = £5, large = £11, difference = £6",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Small bag = 2 × 3 − 1 = 5; checks 11 − 5 = 6" },
            { "mark": "A1", "desc": "Yes, with correct values £5 and £11 shown" }
          ],
          "workingSteps": [
            "Small bag = 2x − 1 = 2 × 3 − 1 = 6 − 1 = £5",
            "Large bag = £11",
            "Difference = 11 − 5 = £6 ✓"
          ]
        }
      ]
