    {
      "id": "F1-05-Q2",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "In a class of 30 students:\n- 18 play football ($F$)\n- 14 play basketball ($B$)\n- 5 play neither sport",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the number of students who play both football and basketball.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "7",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Students who play at least one sport: $30 - 5 = 25$" },
            { "mark": "M1", "desc": "$n(F \\cup B) = n(F) + n(B) - n(F \\cap B)$; $25 = 18 + 14 - n(F \\cap B)$" },
            { "mark": "A1", "desc": "$n(F \\cap B) = 32 - 25 = 7$ cao" }
          ],
          "workingSteps": [
            "Students playing at least one sport: $30 - 5 = 25$",
            "$n(F \\cup B) = n(F) + n(B) - n(F \\cap B)$",
            "$25 = 18 + 14 - n(F \\cap B)$",
            "$n(F \\cap B) = 32 - 25 = 7$"
          ]
        },
        {
          "label": "b",
          "questionText": "A student is chosen at random.\nWork out the probability that this student plays football only.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "11/30",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Football only $= 18 - 7 = 11$" },
            { "mark": "M1", "desc": "$P = \\dfrac{11}{30}$" },
            { "mark": "A1", "desc": "$\\dfrac{11}{30}$ cao" }
          ],
          "workingSteps": [
            "Football only (not basketball): $18 - 7 = 11$",
            "$P(\\text{football only}) = \\dfrac{11}{30}$"
          ]
        }
      ]
