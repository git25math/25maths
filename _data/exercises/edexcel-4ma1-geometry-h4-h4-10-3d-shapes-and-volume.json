    {
      "id": "H4-10-Q1",
      "type": "structured",
      "totalMarks": 9,
      "difficulty": "hard",
      "context": "A solid cone has base radius 6 cm and slant height 10 cm.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the perpendicular height of the cone.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "8",
          "tolerance": 0,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "h² = l² − r² = 10² − 6²" },
            { "mark": "M1", "desc": "= 100 − 36 = 64" },
            { "mark": "A1", "desc": "h = 8 cm" }
          ],
          "workingSteps": [
            "h² = l² − r² = 10² − 6² = 100 − 36 = 64",
            "h = 8 cm"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the volume of the cone.\nGive your answer correct to 3 significant figures.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "302",
          "tolerance": 2,
          "unit": "cm³",
          "markScheme": [
            { "mark": "M1", "desc": "V = (1/3)πr²h" },
            { "mark": "M1", "desc": "= (1/3) × π × 36 × 8 = 96π" },
            { "mark": "A1", "desc": "= 301.59... ≈ 302 cm³" }
          ],
          "workingSteps": [
            "V = (1/3)πr²h = (1/3) × π × 6² × 8",
            "= (1/3) × π × 36 × 8 = 96π = 301.59... ≈ 302 cm³"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the total surface area of the cone.\nGive your answer correct to 3 significant figures.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "302",
          "tolerance": 2,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "Curved surface area = πrl = π × 6 × 10 = 60π" },
            { "mark": "M1", "desc": "Base area = πr² = 36π" },
            { "mark": "A1", "desc": "Total = 60π + 36π = 96π = 301.59... ≈ 302 cm²" }
          ],
          "workingSteps": [
            "Curved surface area = πrl = π × 6 × 10 = 60π",
            "Base area = πr² = π × 36 = 36π",
            "Total surface area = 60π + 36π = 96π = 301.59... ≈ 302 cm²"
          ]
        }
      ]
    },
    {
      "id": "H4-10-Q2",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": "A sphere has radius r. A hemisphere of the same radius is placed on top of a cylinder of radius r and height 2r.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write down the volume of the combined solid (cylinder + hemisphere) in terms of r.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "πr²(2r) + (2/3)πr³ = (8/3)πr³",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Volume of cylinder = πr²h = πr² × 2r = 2πr³" },
            { "mark": "M1", "desc": "Volume of hemisphere = (2/3)πr³" },
            { "mark": "A1", "desc": "Total = 2πr³ + (2/3)πr³ = (6/3 + 2/3)πr³ = (8/3)πr³" }
          ],
          "workingSteps": [
            "Volume of cylinder = πr²h = πr² × 2r = 2πr³",
            "Volume of hemisphere = (1/2) × (4/3)πr³ = (2/3)πr³",
            "Total = 2πr³ + (2/3)πr³ = (6πr³ + 2πr³)/3 = (8/3)πr³"
          ]
        },
        {
          "label": "b",
          "questionText": "The radius r = 5 cm.\nWork out the total surface area of the combined solid (the base of the cylinder, the curved surface of the cylinder, and the curved surface of the hemisphere).\nGive your answer correct to 3 significant figures.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "550",
          "tolerance": 3,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "Base of cylinder: πr² = 25π" },
            { "mark": "M1", "desc": "Curved surface of cylinder: 2πrh = 2π(5)(10) = 100π" },
            { "mark": "M1", "desc": "Curved surface of hemisphere: 2πr² = 2π(25) = 50π" },
            { "mark": "A1", "desc": "Total = 25π + 100π + 50π = 175π = 549.8... ≈ 550 cm²" }
          ],
          "workingSteps": [
            "r = 5 cm, h = 2r = 10 cm",
            "Base circle: πr² = 25π",
            "Cylinder curved surface: 2πrh = 2π(5)(10) = 100π",
            "Hemisphere curved surface: 2πr² = 2π(25) = 50π",
            "Total = (25 + 100 + 50)π = 175π = 549.78... ≈ 550 cm²"
          ]
        }
      ]
    }
  ]
