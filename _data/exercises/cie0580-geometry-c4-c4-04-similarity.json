          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Perimeter ratio equals length scale factor oe" },
            { "mark": "B1", "desc": "2 : 5 oe" }
          ],
          "workingSteps": [
            "Perimeter ratio = length scale factor = 4/10 = 2/5",
            "Ratio ABC : DEF = 2 : 5"
          ]
        }
      ]
