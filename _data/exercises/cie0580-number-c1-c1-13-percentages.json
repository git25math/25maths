    {
      "id": "C1-13-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "A jacket costs $\\$80$. It is reduced by $15\\%$ in a sale.\nCalculate the sale price.",
      "answerType": "integer",
      "correctAnswer": "68",
      "tolerance": null,
      "unit": "$",
      "markScheme": [
        { "mark": "M1", "desc": "$15\\%$ of $80 = 0.15 \\times 80 = 12$" },
        { "mark": "M1", "desc": "$80 - 12$" },
        { "mark": "A1", "desc": "$\\$68$ cao" }
      ],
      "workingSteps": [
        "Reduction $= 15\\% \\times 80 = 0.15 \\times 80 = \\$12$",
        "Sale price $= 80 - 12 = \\$68$"
      ],
      "explanation": "Or use multiplier: $80 \\times 0.85 = \\$68$."
    },
    {
      "id": "C1-13-Q3",
      "type": "structured",
