    {
      "id": "H2-01-Q1",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "medium",
      "context": "A mobile phone plan charges a monthly fee of £$f$ plus $p$ pence per minute for calls.\nJade uses the plan for $m$ minutes one month.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write an expression, in pence, for Jade's total bill for the month.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "100f + pm",
          "tolerance": null,
          "unit": "pence",
          "markScheme": [
            { "mark": "B1", "desc": "100f seen (converts £f to pence)" },
            { "mark": "B1", "desc": "100f + pm cao" }
          ],
          "workingSteps": [
            "Monthly fee = £f = 100f pence",
            "Call charge = p × m pence",
            "Total = 100f + pm pence"
          ]
        },
        {
          "label": "b",
          "questionText": "The monthly fee is £12, the cost per minute is 8 pence, and Jade makes 45 minutes of calls.\nWork out Jade's total bill. Give your answer in pounds.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "15.60",
          "tolerance": 0.01,
          "unit": "£",
          "markScheme": [
            { "mark": "M1", "desc": "1200 + 8 × 45 = 1200 + 360" },
            { "mark": "A1", "desc": "1560 pence = £15.60 cao" }
          ],
          "workingSteps": [
            "Total = 100 × 12 + 8 × 45 = 1200 + 360 = 1560 pence",
            "£15.60"
          ]
        },
        {
          "label": "c",
          "questionText": "Jade's bill one month is £18.40.\nShe made 80 minutes of calls.\nWork out the monthly fee $f$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "12",
          "tolerance": 0.01,
          "unit": "£",
          "markScheme": [
            { "mark": "M1", "desc": "1840 = 100f + 8 × 80 → 100f = 1840 − 640 = 1200" },
            { "mark": "A1", "desc": "f = 12, so £12 cao" }
          ],
          "workingSteps": [
            "1840 = 100f + 8 × 80",
            "1840 = 100f + 640",
            "100f = 1200",
            "f = 12"
          ]
        },
        {
          "label": "d",
          "questionText": "A second plan charges 15 pence per minute with no monthly fee.\nFor what number of minutes is the cost the same on both plans?\nSet up and solve an equation.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "171",
          "tolerance": null,
          "unit": "minutes",
          "markScheme": [
            { "mark": "M1", "desc": "1200 + 8m = 15m → 7m = 1200" },
            { "mark": "A1", "desc": "m = 171 (rounded down from 171.4) or 1200/7 oe" }
          ],
          "workingSteps": [
            "Plan 1: 1200 + 8m pence",
            "Plan 2: 15m pence",
            "Set equal: 1200 + 8m = 15m",
            "1200 = 7m",
            "m = 1200/7 ≈ 171.4 minutes"
          ]
        }
      ]
    },
    {
      "id": "H2-01-Q2",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": null,
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the value of $\\dfrac{4a^2 - b}{3b + 1}$ when $a = 3$ and $b = -2$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "-7.6",
          "tolerance": 0.05,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Numerator: 4 × 9 − (−2) = 36 + 2 = 38" },
            { "mark": "M1", "desc": "Denominator: 3 × (−2) + 1 = −6 + 1 = −5" },
            { "mark": "A1", "desc": "38 ÷ (−5) = −7.6 cao" }
          ],
          "workingSteps": [
            "Numerator: 4(3)² − (−2) = 4 × 9 + 2 = 36 + 2 = 38",
            "Denominator: 3(−2) + 1 = −6 + 1 = −5",
            "Result: 38 ÷ (−5) = −7.6"
          ]
        },
        {
          "label": "b",
          "questionText": "Given that $p = 2q - r$ and $q = 3$, $r = -4$, find the value of $p^2 - 2p$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "80",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "p = 2(3) − (−4) = 6 + 4 = 10" },
            { "mark": "A1", "desc": "p² − 2p = 100 − 20 = 80 cao" }
          ],
          "workingSteps": [
            "p = 2q − r = 2(3) − (−4) = 6 + 4 = 10",
            "p² − 2p = 10² − 2(10) = 100 − 20 = 80"
          ]
        },
        {
          "label": "c",
          "questionText": "The expression $n^2 + n + 41$ gives a prime number for certain integer values of $n$.\nWork out the value of this expression when $n = 3$ and when $n = 5$.\nIs either answer composite (not prime)? Give a reason.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "n=3: 53 (prime); n=5: 71 (prime); both prime for these values",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "n = 3: 9 + 3 + 41 = 53 (prime); n = 5: 25 + 5 + 41 = 71 (prime)" },
            { "mark": "B1", "desc": "Both are prime for these values; formula does not always give primes (e.g. n = 40 gives 40² + 40 + 41 = 41² which is composite)" }
          ],
          "workingSteps": [
            "n = 3: 9 + 3 + 41 = 53 (prime)",
            "n = 5: 25 + 5 + 41 = 71 (prime)",
            "Counter-example: n = 40 → 1600 + 40 + 41 = 1681 = 41² (composite)"
          ]
        }
      ]
    },
    {
      "id": "H2-01-Q3",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": "A water tank is being filled and drained simultaneously.\nThe volume of water $V$ (litres) at time $t$ (minutes) is modelled by:\n$$V = 200 + 15t - 2t^2$$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the volume of water when $t = 4$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "228",
          "tolerance": null,
          "unit": "litres",
          "markScheme": [
            { "mark": "M1", "desc": "200 + 15(4) − 2(16) = 200 + 60 − 32" },
            { "mark": "A1", "desc": "228 litres cao" }
          ],
          "workingSteps": [
            "V = 200 + 15(4) − 2(4²)",
            "V = 200 + 60 − 32 = 228 litres"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the two values of $t$ when $V = 200$.\nGive a reason why only one is relevant in this context.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "t = 0 or t = 7.5; t = 0 is start, t = 7.5 is when tank returns to 200 L",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "200 + 15t − 2t² = 200 → 15t − 2t² = 0 → t(15 − 2t) = 0" },
            { "mark": "A1", "desc": "t = 0 or t = 7.5" },
            { "mark": "A1", "desc": "t = 0 is the start (initial condition); t = 7.5 is when it returns to 200 L" }
          ],
          "workingSteps": [
            "Set V = 200: 15t − 2t² = 0",
            "t(15 − 2t) = 0",
            "t = 0 or t = 7.5 minutes",
            "t = 0 is the initial moment; t = 7.5 min is when volume returns to 200 L"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the rate of change of volume, $\\dfrac{dV}{dt}$, when $t = 3$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "3",
          "tolerance": null,
          "unit": "litres/min",
          "markScheme": [
            { "mark": "M1", "desc": "dV/dt = 15 − 4t; substitutes t = 3" },
            { "mark": "A1", "desc": "15 − 12 = 3 litres/min cao" }
          ],
          "workingSteps": [
            "V = 200 + 15t − 2t²",
            "dV/dt = 15 − 4t",
            "At t = 3: dV/dt = 15 − 12 = 3 litres/min"
          ]
        }
      ]
    }
  ]
