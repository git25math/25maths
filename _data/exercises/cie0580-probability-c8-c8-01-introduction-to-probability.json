      "commandWord": "write-down",
      "difficulty": "easy",
      "questionText": "A fair six-sided dice is rolled once.\nWrite down the probability of rolling a 4.",
      "answerType": "fraction",
      "correctAnswer": "1/6",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "B1",
          "desc": "1/6"
        }
      ],
      "workingSteps": [
        "P(4) = 1/6"
      ],
      "explanation": "One favourable outcome out of six equally likely outcomes."
    },
    {
      "id": "C8-01-Q2",
      "type": "short-answer",
      "totalMarks": 2,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "A bag contains 3 red balls, 5 blue balls and 2 green balls.\nA ball is picked at random.\nFind the probability that the ball is blue.",
      "answerType": "fraction",
      "correctAnswer": "1/2",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "5/10 or 5/(3+5+2)"
        },
        {
          "mark": "A1",
          "desc": "1/2 or 0.5"
        }
      ],
      "workingSteps": [
        "Total = 3 + 5 + 2 = 10",
        "P(blue) = 5/10 = 1/2"
      ],
      "explanation": "P(event) = favourable outcomes / total outcomes."
    },
    {
      "id": "C8-01-Q3",
      "type": "short-answer",
      "totalMarks": 2,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "The probability that it rains tomorrow is 0.3.\nFind the probability that it does not rain tomorrow.",
      "answerType": "numeric",
      "correctAnswer": "0.7",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "1 − 0.3"
        },
        {
          "mark": "A1",
          "desc": "0.7"
        }
      ],
      "workingSteps": [
        "P(not rain) = 1 − P(rain) = 1 − 0.3 = 0.7"
      ],
      "explanation": "P(not A) = 1 − P(A)."
    },
