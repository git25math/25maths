      "correctAnswer": "0.65",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "1 − 0.35"
        },
        {
          "mark": "A1",
          "desc": "0.65"
        }
      ],
      "workingSteps": [
