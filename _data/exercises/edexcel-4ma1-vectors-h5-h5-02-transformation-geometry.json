      "type": "structured",
      "totalMarks": 10,
      "difficulty": "hard",
      "context": "Triangle P has vertices A(1, 1), B(3, 1) and C(3, 4).",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Enlarge triangle P by scale factor −1.5 with centre (1, 1).\nWork out the coordinates of the image.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "coordinate",
          "correctAnswer": "(1,1),(−2,1),(−2,−3.5)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "Centre A(1,1), SF = −1.5"
            },
            {
              "mark": "M1",
              "desc": "B→A + (−1.5)(B−A) = (1,1) + (−1.5)(2,0) = (−2,1)"
            },
            {
              "mark": "M1",
              "desc": "C→(1,1) + (−1.5)(2,3) = (−2, −3.5)"
            },
            {
              "mark": "A1",
              "desc": "A'(1,1), B'(−2,1), C'(−2,−3.5)"
            }
          ],
          "workingSteps": [
            "Centre = A(1,1)",
            "B': (1,1) + (−1.5)(3−1, 1−1) = (1,1)+(−3,0) = (−2,1)",
            "C': (1,1) + (−1.5)(3−1, 4−1) = (1,1)+(−3,−4.5) = (−2,−3.5)"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the ratio of the area of triangle P to the area of its image.",
