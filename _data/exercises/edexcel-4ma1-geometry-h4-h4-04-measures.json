          "workingSteps": [
            "Map measurement: 6.35 ≤ d < 6.45 cm (1dp rounding)",
            "Lower bound: 6.35 × 25 000 = 158 750 cm = 1.5875 km",
            "Upper bound: 6.45 × 25 000 = 161 250 cm = 1.6125 km"
          ]
        }
      ]
