          "correctAnswer": "1.15",
          "tolerance": 0.005,
          "unit": "km",
          "markScheme": [
            { "mark": "M1", "desc": "4.6 × 25 000 = 115 000 cm" },
            { "mark": "A1", "desc": "115 000 ÷ 100 000 = 1.15 km" }
          ],
          "workingSteps": [
            "Actual distance = 4.6 × 25 000 = 115 000 cm",
            "= 115 000 ÷ 100 000 = 1.15 km"
          ]
        },
        {
          "label": "b",
          "questionText": "A lake has an area of 3 cm² on the map.\nWork out the actual area of the lake in km².",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.1875",
          "tolerance": 0.001,
          "unit": "km²",
          "markScheme": [
            { "mark": "M1", "desc": "Area scale factor = 25 000² = 6.25 × 10⁸" },
            { "mark": "M1", "desc": "Actual area = 3 × 6.25 × 10⁸ cm² = 18.75 × 10⁸ cm²" },
            { "mark": "A1", "desc": "18.75 × 10⁸ ÷ 10¹⁰ = 0.1875 km²" }
          ],
          "workingSteps": [
            "1 km = 100 000 cm, so 1 km² = (10⁵)² = 10¹⁰ cm²",
            "Actual area = 3 × 25 000² = 3 × 6.25 × 10⁸ = 18.75 × 10⁸ cm²",
            "= 18.75 × 10⁸ ÷ 10¹⁰ km² = 0.1875 km²"
          ]
        },
        {
          "label": "c",
          "questionText": "A measurement on a map is given as 6.4 cm, correct to 1 decimal place.\nWork out the upper and lower bounds for the actual distance.",
