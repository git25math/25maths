    {
      "id": "H2-05-Q1",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "medium",
      "context": "The stopping distance $d$ metres of a car is directly proportional to the square of its speed $v$ km/h.\nWhen $v = 40$, $d = 32$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the value of the constant $k$ in the formula $d = kv^2$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.02",
          "tolerance": 0.001,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "32 = k × 1600" },
            { "mark": "A1", "desc": "k = 32/1600 = 0.02 cao" }
          ],
          "workingSteps": [
            "d ∝ v² → d = kv²",
            "Substitute: 32 = k × 40²",
            "32 = 1600k",
            "k = 32/1600 = 0.02"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the stopping distance when $v = 60$ km/h.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "72",
          "tolerance": null,
          "unit": "m",
          "markScheme": [
            { "mark": "M1", "desc": "d = 0.02 × 3600" },
            { "mark": "A1", "desc": "72 m cao" }
          ],
          "workingSteps": [
            "d = 0.02 × 60² = 0.02 × 3600 = 72 m"
          ]
        },
        {
          "label": "c",
          "questionText": "The stopping distance is 50 m.\nWork out the speed of the car. Give your answer to 1 decimal place.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "50.0",
          "tolerance": 0.1,
          "unit": "km/h",
          "markScheme": [
            { "mark": "M1", "desc": "v² = 50/0.02 = 2500" },
            { "mark": "A1", "desc": "v = 50.0 km/h cao" }
          ],
          "workingSteps": [
            "50 = 0.02v²",
            "v² = 50/0.02 = 2500",
            "v = √2500 = 50.0 km/h"
          ]
        },
        {
          "label": "d",
          "questionText": "The speed increases by 50%. Work out the percentage increase in stopping distance.\nGive a reason for your answer.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "125% increase in stopping distance",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "New v = 1.5v₀; new d = k(1.5v₀)² = 2.25kv₀² = 2.25 × old d" },
            { "mark": "A1", "desc": "Increase = 125%; give a reason: d ∝ v², so 1.5² = 2.25 times the original" }
          ],
          "workingSteps": [
            "New speed = 1.5v, so new d = k(1.5v)² = 2.25kv² = 2.25d",
            "Increase = (2.25 − 1) × 100% = 125%",
            "Reason: since d ∝ v², multiplying speed by 1.5 multiplies d by 1.5² = 2.25"
          ]
        }
      ]
    },
    {
      "id": "H2-05-Q2",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "The resistance $R$ ohms of a wire is inversely proportional to the square of its radius $r$ mm.\nWhen $r = 2$, $R = 5$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the formula for $R$ in terms of $r$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "R = 20 / r^2",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "R ∝ 1/r² → R = k/r²" },
            { "mark": "M1", "desc": "5 = k/4 → k = 20" },
            { "mark": "A1", "desc": "R = 20/r² cao" }
          ],
          "workingSteps": [
            "R ∝ 1/r² → R = k/r²",
            "When r = 2: 5 = k/4",
            "k = 20",
            "Formula: R = 20/r²"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out $R$ when $r = 4$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "1.25",
          "tolerance": 0.01,
          "unit": "ohms",
          "markScheme": [
            { "mark": "M1", "desc": "R = 20/16" },
            { "mark": "A1", "desc": "1.25 ohms cao" }
          ],
          "workingSteps": [
            "R = 20/4² = 20/16 = 1.25 ohms"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the radius when $R = 0.8$ ohms.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "5",
          "tolerance": null,
          "unit": "mm",
          "markScheme": [
            { "mark": "M1", "desc": "0.8 = 20/r²" },
            { "mark": "M1", "desc": "r² = 20/0.8 = 25" },
            { "mark": "A1", "desc": "r = 5 mm cao" }
          ],
          "workingSteps": [
            "0.8 = 20/r²",
            "r² = 20/0.8 = 25",
            "r = 5 mm"
          ]
        }
      ]
    },
    {
      "id": "H2-05-Q3",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "hard",
      "context": "The variable $y$ is partly proportional to $x$ and partly proportional to $x^2$.\nWhen $x = 2$, $y = 14$ and when $x = 3$, $y = 27$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Write down an equation of the form $y = ax + bx^2$ and use both conditions to find $a$ and $b$.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "a = 4, b = 3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Sets up: 2a + 4b = 14 and 3a + 9b = 27" },
            { "mark": "M1", "desc": "Solves simultaneously: from eq1: a + 2b = 7; from eq2: a + 3b = 9" },
            { "mark": "A1", "desc": "b = 2; a = 3 ... check: 3(2) + 2(4) = 6 + 8 = 14 ✓" },
            { "mark": "A1", "desc": "a = 3, b = 2 cao" }
          ],
          "workingSteps": [
            "y = ax + bx²",
            "x = 2: 2a + 4b = 14 → a + 2b = 7  ...(1)",
            "x = 3: 3a + 9b = 27 → a + 3b = 9  ...(2)",
            "Subtract (1) from (2): b = 2",
            "Substitute: a + 4 = 7 → a = 3",
            "Check x = 2: 3(2) + 2(4) = 6 + 8 = 14 ✓",
            "Check x = 3: 3(3) + 2(9) = 9 + 18 = 27 ✓"
          ]
        },
        {
          "label": "b",
          "questionText": "Hence find the value of $y$ when $x = 5$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "65",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "y = 3(5) + 2(25)" },
            { "mark": "A1", "desc": "y = 15 + 50 = 65 cao" }
          ],
          "workingSteps": [
            "y = 3(5) + 2(5²) = 15 + 50 = 65"
          ]
        }
      ]
    }
  ]
