        {
          "label": "b",
          "questionText": "Work out the value of $32^{-3/5}$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "1/8",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$32^{1/5} = 2$" },
            { "mark": "M1", "desc": "$32^{3/5} = 2^3 = 8$" },
            { "mark": "A1", "desc": "$32^{-3/5} = \\dfrac{1}{8}$ cao" }
          ],
          "workingSteps": [
            "$32^{1/5} = \\sqrt[5]{32} = 2$ (since $2^5 = 32$)",
            "$32^{3/5} = (32^{1/5})^3 = 2^3 = 8$",
            "$32^{-3/5} = \\dfrac{1}{8}$"
          ]
        }
      ]
    },
