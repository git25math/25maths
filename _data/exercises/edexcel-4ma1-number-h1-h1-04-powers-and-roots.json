        {
          "label": "a",
          "questionText": "Simplify $\\dfrac{x^{5/2} \\times x^{-1/2}}{x^2}$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$x^0 = 1$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Numerator: $x^{5/2} \\times x^{-1/2} = x^{5/2 - 1/2} = x^2$" },
            { "mark": "M1", "desc": "$x^2 \\div x^2 = x^{2-2}$" },
            { "mark": "A1", "desc": "$x^0 = 1$ cao" }
          ],
          "workingSteps": [
            "$x^{5/2} \\times x^{-1/2} = x^{5/2 + (-1/2)} = x^{4/2} = x^2$",
            "$\\dfrac{x^2}{x^2} = x^0 = 1$"
          ]
        },
        {
          "label": "b",
          "questionText": "Show that $(9a^4)^{3/2} = 27a^6$.",
          "marks": 2,
          "commandWord": "show",
          "answerType": "show-that",
          "correctAnswer": "27a^6",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$(9)^{3/2} = (\\sqrt{9})^3 = 3^3 = 27$; $(a^4)^{3/2} = a^{4 \\times 3/2} = a^6$" },
            { "mark": "A1", "desc": "$(9a^4)^{3/2} = 27a^6$ ✓" }
          ],
          "workingSteps": [
            "$(9a^4)^{3/2} = 9^{3/2} \\times (a^4)^{3/2}$",
            "$9^{3/2} = (\\sqrt{9})^3 = 3^3 = 27$",
            "$(a^4)^{3/2} = a^{4 \\times 3/2} = a^6$",
            "$(9a^4)^{3/2} = 27a^6$ ✓"
          ]
        }
      ]
    }
