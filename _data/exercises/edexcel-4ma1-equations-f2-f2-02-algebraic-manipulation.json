          "questionText": "Simplify $\\dfrac{x^2 - 9}{x + 3}$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x - 3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Factorises numerator: (x + 3)(x − 3)" },
            { "mark": "A1", "desc": "x − 3 cao (with x ≠ −3)" }
          ],
          "workingSteps": [
            "x² − 9 = (x + 3)(x − 3)  [difference of two squares]",
            "(x + 3)(x − 3) ÷ (x + 3) = x − 3"
          ]
        },
        {
          "label": "c",
          "questionText": "Write $\\dfrac{2}{x} + \\dfrac{3}{x+1}$ as a single fraction.\nSimplify your answer.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "(5x + 2) / (x(x+1))",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Common denominator x(x+1) used: 2(x+1) + 3x" },
            { "mark": "A1", "desc": "(5x + 2) / (x(x + 1)) cao" }
          ],
          "workingSteps": [
            "Common denominator: x(x + 1)",
            "2/x = 2(x+1) / [x(x+1)]",
            "3/(x+1) = 3x / [x(x+1)]",
            "Sum = (2x + 2 + 3x) / [x(x+1)] = (5x + 2) / [x(x+1)]"
          ]
        }
      ]
    }
