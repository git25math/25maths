          "correctAnswer": "x^2 + 8x + 15",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Four terms seen from correct expansion: x² + 5x + 3x + 15" },
            { "mark": "A1", "desc": "x² + 8x seen" },
            { "mark": "A1", "desc": "x² + 8x + 15 cao" }
          ],
          "workingSteps": [
            "x × x = x²",
            "x × 5 = 5x",
            "3 × x = 3x",
            "3 × 5 = 15",
            "x² + 5x + 3x + 15 = x² + 8x + 15"
          ]
