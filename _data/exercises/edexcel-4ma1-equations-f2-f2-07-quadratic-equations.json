      "parts": [
        {
          "label": "a",
          "questionText": "Solve $2x^2 + 7x + 3 = 0$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x = -1/2 or x = -3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Attempt to factorise: (2x + 1)(x + 3)" },
            { "mark": "A1", "desc": "x = −½ or x = −3" },
            { "mark": "A1", "desc": "Both values correct cao" }
          ],
          "workingSteps": [
            "2x² + 7x + 3 = 0",
            "Look for (2x + a)(x + b) where ab = 3 and 2b + a = 7",
            "Try a = 1, b = 3: (2x + 1)(x + 3) = 2x² + 6x + x + 3 = 2x² + 7x + 3 ✓",
            "2x + 1 = 0 → x = −½",
            "x + 3 = 0 → x = −3"
          ]
        },
        {
          "label": "b",
          "questionText": "Use the quadratic formula to solve $x^2 + 4x - 7 = 0$.\nGive your answers correct to 2 decimal places.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x = 1.32 or x = -5.32",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Correct substitution into formula: x = (−4 ± √(16 + 28)) / 2" },
            { "mark": "A1", "desc": "x = (−4 ± √44) / 2" },
            { "mark": "A1", "desc": "x = 1.32 or x = −5.32 (both, 2 dp)" }
          ],
          "workingSteps": [
            "a = 1, b = 4, c = −7",
            "x = (−4 ± √(16 − 4×1×(−7))) / (2×1)",
            "x = (−4 ± √(16 + 28)) / 2",
            "x = (−4 ± √44) / 2",
            "x = (−4 + 6.633) / 2 = 1.316... ≈ 1.32",
            "x = (−4 − 6.633) / 2 = −5.316... ≈ −5.32"
          ]
        }
      ]
    }
