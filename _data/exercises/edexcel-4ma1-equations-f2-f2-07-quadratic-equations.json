      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "A rectangular garden has length $(x + 5)$ metres and width $(x + 2)$ metres.\nThe area of the garden is 40 m².",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Show that $x^2 + 7x - 30 = 0$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "show-that",
          "correctAnswer": "(x+5)(x+2) = 40 → x² + 7x + 10 = 40 → x² + 7x − 30 = 0",
          "markScheme": [
            { "mark": "M1", "desc": "(x + 5)(x + 2) = 40 expanded to x² + 7x + 10 = 40" },
            { "mark": "A1", "desc": "x² + 7x − 30 = 0 with all working shown" }
          ],
          "workingSteps": [
            "Area = (x + 5)(x + 2) = 40",
            "x² + 2x + 5x + 10 = 40",
            "x² + 7x + 10 = 40",
            "x² + 7x − 30 = 0"
          ]
        },
        {
          "label": "b",
          "questionText": "Solve $x^2 + 7x - 30 = 0$ to find the value of $x$.\nState why one solution is not valid.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "x = 3 (x = −10 rejected as length must be positive)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Factorises: (x + 10)(x − 3) = 0" },
            { "mark": "A1", "desc": "x = 3 and x = −10" },
            { "mark": "A1", "desc": "x = −10 rejected because length must be positive" }
          ],
          "workingSteps": [
            "Need two numbers: product = −30, sum = 7",
            "10 and −3: 10 × (−3) = −30, 10 + (−3) = 7 ✓",
            "(x + 10)(x − 3) = 0",
            "x = −10 or x = 3",
            "x = −10 is rejected (width = −10 + 2 = −8 m, impossible)"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the perimeter of the garden.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "26",
          "tolerance": null,
          "unit": "m",
          "markScheme": [
            { "mark": "B1", "desc": "2(8 + 5) = 26 m ft their x = 3" }
          ],
          "workingSteps": [
            "Length = 3 + 5 = 8 m, Width = 3 + 2 = 5 m",
            "Perimeter = 2 × (8 + 5) = 2 × 13 = 26 m"
          ]
        }
      ]
