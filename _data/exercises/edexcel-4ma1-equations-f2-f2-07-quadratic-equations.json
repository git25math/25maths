            { "mark": "A1", "desc": "x = −2 or x = −3 cao" }
          ],
          "workingSteps": [
            "(x + 2)(x + 3) = 0",
            "x + 2 = 0 → x = −2",
            "x + 3 = 0 → x = −3"
          ]
        },
