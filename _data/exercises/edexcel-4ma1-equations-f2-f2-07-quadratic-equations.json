          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Two numbers with product 6 and sum 5: 2 and 3" },
            { "mark": "A1", "desc": "(x + 2)(x + 3) cao" }
          ],
          "workingSteps": [
            "Need two numbers: product = 6, sum = 5",
            "2 × 3 = 6, 2 + 3 = 5 ✓",
            "x² + 5x + 6 = (x + 2)(x + 3)"
