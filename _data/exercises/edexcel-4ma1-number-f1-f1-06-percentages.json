          "label": "b",
          "questionText": "A coat costs $\\$120$ and is reduced by $25\\%$ in a sale.\nWork out the sale price.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "90",
          "tolerance": null,
          "unit": "$",
          "markScheme": [
            { "mark": "M1", "desc": "$120 \\times 0.75$ or $120 - 0.25 \\times 120$" },
            { "mark": "A1", "desc": "$\\$90$ cao" }
          ],
          "workingSteps": [
            "Sale price $= 120 \\times (1 - 0.25) = 120 \\times 0.75 = \\$90$"
