    {
      "id": "F1-06-Q2",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "A charity collected $\\$4800$ last year.\nThis year, the amount collected increased by $12.5\\%$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the amount collected this year.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "5400",
          "tolerance": null,
          "unit": "$",
          "markScheme": [
            { "mark": "M1", "desc": "$12.5\\%$ of $4800 = 0.125 \\times 4800 = 600$" },
            { "mark": "M1", "desc": "$4800 + 600$" },
            { "mark": "A1", "desc": "$\\$5400$ cao" }
          ],
          "workingSteps": [
            "Increase $= 12.5\\% \\times 4800 = 0.125 \\times 4800 = \\$600$",
            "Total $= \\$4800 + \\$600 = \\$5400$"
          ]
        },
        {
          "label": "b",
          "questionText": "What percentage of the amount collected this year was from online donations?\nOnline donations totalled $\\$2160$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "40",
          "tolerance": null,
          "unit": "%",
          "markScheme": [
            { "mark": "M1", "desc": "$\\dfrac{2160}{5400} \\times 100$" },
            { "mark": "M1", "desc": "Correct division" },
            { "mark": "A1", "desc": "$40\\%$ cao" }
          ],
          "workingSteps": [
            "$\\dfrac{2160}{5400} \\times 100 = 0.4 \\times 100 = 40\\%$"
          ]
        }
      ]
    }
  ]
