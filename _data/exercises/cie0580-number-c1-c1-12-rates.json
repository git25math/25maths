      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "A car travels $180$ km in $2.5$ hours.\nCalculate the average speed in km/h.",
      "answerType": "integer",
      "correctAnswer": "72",
      "tolerance": null,
      "unit": "km/h",
      "markScheme": [
        { "mark": "M1", "desc": "Speed $= \\dfrac{\\text{distance}}{\\text{time}}$" },
        { "mark": "M1", "desc": "$180 \\div 2.5$" },
        { "mark": "A1", "desc": "$72$ km/h cao" }
      ],
      "workingSteps": [
        "Speed $= \\dfrac{\\text{distance}}{\\text{time}} = \\dfrac{180}{2.5} = 72$ km/h"
      ],
      "explanation": "Speed = Distance ÷ Time."
    },
    {
      "id": "C1-12-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "A tap fills a 45-litre tank at a rate of $3$ litres per minute.\nHow long does it take to fill the tank? Give your answer in minutes.",
      "answerType": "integer",
      "correctAnswer": "15",
      "tolerance": null,
      "unit": "minutes",
      "markScheme": [
        { "mark": "M1", "desc": "Time $= \\dfrac{\\text{volume}}{\\text{rate}}$" },
        { "mark": "M1", "desc": "$45 \\div 3$" },
        { "mark": "A1", "desc": "$15$ minutes cao" }
      ],
      "workingSteps": [
        "Time $= \\dfrac{45}{3} = 15$ minutes"
      ],
      "explanation": "Rate = Amount ÷ Time, so Time = Amount ÷ Rate."
    },
