          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "(−1+x)/2 = 3 → x = 7"
            },
            {
              "mark": "M1",
              "desc": "(2+y)/2 = 5 → y = 8"
            },
            {
              "mark": "A1",
              "desc": "Q = (7, 8)"
            }
          ],
          "workingSteps": [
            "(−1 + x)/2 = 3 → x = 7",
            "(2 + y)/2 = 5 → y = 8",
            "Q = (7, 8)"
          ]
        },
        {
          "label": "b",
          "questionText": "Calculate the length PQ.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "10",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "PQ² = (7−(−1))² + (8−2)² = 64 + 36"
            },
            {
              "mark": "M1",
              "desc": "√100"
            },
            {
              "mark": "A1",
              "desc": "10"
            }
          ],
          "workingSteps": [
            "PQ² = 8² + 6² = 64 + 36 = 100",
            "PQ = 10"
          ]
