      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": "M(3, 5) is the midpoint of line segment PQ where P is (−1, 2).",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the coordinates of Q.",
          "marks": 3,
          "commandWord": "find",
