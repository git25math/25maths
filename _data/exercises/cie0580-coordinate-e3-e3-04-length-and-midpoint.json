      "commandWord": "show",
      "difficulty": "hard",
      "questionText": "Show that the triangle with vertices A(1, 1), B(4, 5) and C(8, 2) is isosceles.\nState which two sides are equal.",
      "answerType": "show-that",
      "correctAnswer": "AB = BC = 5",
      "markScheme": [
        {
          "mark": "M1",
          "desc": "AB² = 3² + 4² = 25, AB = 5"
        },
        {
          "mark": "M1",
          "desc": "BC² = 4² + 3² = 25, BC = 5"
        },
        {
          "mark": "M1",
          "desc": "AC² = 7² + 1² = 50, AC = √50"
        },
        {
          "mark": "A1",
          "desc": "AB = BC = 5"
        },
        {
          "mark": "A1",
          "desc": "AB and BC are equal"
        },
        {
          "mark": "B1",
          "desc": "Therefore isosceles"
        }
      ],
      "workingSteps": [
        "AB² = (4−1)² + (5−1)² = 9 + 16 = 25, AB = 5",
        "BC² = (8−4)² + (2−5)² = 16 + 9 = 25, BC = 5",
        "AC² = (8−1)² + (2−1)² = 49 + 1 = 50, AC = √50 ≈ 7.07",
        "AB = BC = 5, so triangle is isosceles"
      ],
      "explanation": "Calculate all three side lengths and identify which two are equal."
    }
