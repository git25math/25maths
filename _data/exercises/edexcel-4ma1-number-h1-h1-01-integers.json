        {
          "label": "a",
          "questionText": "Express $360$ as a product of its prime factors.\nWrite your answer in index form.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$2^3 \\times 3^2 \\times 5$",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Systematic factor tree or division" },
            { "mark": "M1", "desc": "At least three distinct prime factors identified" },
            { "mark": "A1", "desc": "$2^3 \\times 3^2 \\times 5$ cao" }
          ],
          "workingSteps": [
            "$360 \\div 2 = 180$",
            "$180 \\div 2 = 90$",
            "$90 \\div 2 = 45$",
            "$45 \\div 3 = 15$",
            "$15 \\div 3 = 5$",
            "$360 = 2^3 \\times 3^2 \\times 5$"
          ]
        },
        {
          "label": "b",
          "questionText": "Use your answer to find the HCF of $360$ and $252$.\nShow your working.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "36",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "$252 = 2^2 \\times 3^2 \\times 7$; HCF $= 2^2 \\times 3^2 = 36$" }
          ],
          "workingSteps": [
            "$252 = 2^2 \\times 3^2 \\times 7$",
            "Common factors: $2^2$ and $3^2$",
            "HCF $= 2^2 \\times 3^2 = 4 \\times 9 = 36$"
          ]
        }
      ]
    },
