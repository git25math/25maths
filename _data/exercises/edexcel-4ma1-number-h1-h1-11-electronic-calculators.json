      "parts": [
        {
          "label": "a",
          "questionText": "Use your calculator to work out $\\dfrac{\\sqrt{3.7^2 + 5.1^2}}{\\tan(38°)}$.\nGive your answer correct to 4 significant figures.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "8.065",
          "tolerance": 0.001,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$3.7^2 + 5.1^2 = 13.69 + 26.01 = 39.70$; $\\sqrt{39.70} = 6.3007...$" },
            { "mark": "M1", "desc": "$\\tan(38°) = 0.78129...$; $6.3007/0.78129$" },
            { "mark": "A1", "desc": "$= 8.0647...$ ≈ $8.065$ (4 sf)" }
          ],
          "workingSteps": [
            "$3.7^2 = 13.69$; $5.1^2 = 26.01$",
            "$3.7^2 + 5.1^2 = 39.70$",
            "$\\sqrt{39.70} = 6.30079...$",
            "$\\tan(38°) = 0.78129...$",
            "$6.30079 \\div 0.78129 = 8.0647...$",
            "$\\approx 8.065$ (4 sf)"
          ]
        },
        {
          "label": "b",
          "questionText": "Write down all the figures on your calculator display before rounding.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "8.065",
          "tolerance": 0.001,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Display shows $8.0647...$ (accept first 5+ digits)" },
            { "mark": "B1", "desc": "Correctly rounds to $8.065$ (4 sf)" }
          ],
          "workingSteps": [
            "Full display: $8.06472...$",
            "Rounded to 4 sf: $8.065$"
          ]
        }
      ]
    },
    {
      "id": "H1-11-Q2",
      "type": "structured",
      "totalMarks": 5,
      "difficulty": "hard",
      "context": "The formula for the volume of a cone is $V = \\dfrac{1}{3}\\pi r^2 h$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "A cone has volume $V = 250$ cm³ and height $h = 9.6$ cm.\nUse your calculator to find $r$.\nGive your answer correct to 3 significant figures.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "4.99",
          "tolerance": 0.01,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "$r^2 = \\dfrac{3V}{\\pi h} = \\dfrac{3 \\times 250}{\\pi \\times 9.6}$" },
            { "mark": "M1", "desc": "$r^2 = \\dfrac{750}{30.159...} = 24.867...$" },
            { "mark": "A1", "desc": "$r = \\sqrt{24.867...} = 4.9867... \\approx 4.99$ cm (3 sf)" }
          ],
          "workingSteps": [
            "$r^2 = \\dfrac{3 \\times 250}{\\pi \\times 9.6} = \\dfrac{750}{30.1593...} = 24.867...$",
            "$r = \\sqrt{24.867} = 4.9867...$",
            "$r \\approx 4.99$ cm (3 sf)"
          ]
        },
        {
          "label": "b",
          "questionText": "Use your unrounded answer to find the slant height $l = \\sqrt{r^2 + h^2}$.\nGive your answer correct to 3 significant figures.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "10.8",
          "tolerance": 0.05,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "$l = \\sqrt{24.867... + 9.6^2} = \\sqrt{24.867 + 92.16} = \\sqrt{117.027}$" },
            { "mark": "A1", "desc": "$l = 10.818... \\approx 10.8$ cm (3 sf)" }
          ],
          "workingSteps": [
            "$h^2 = 9.6^2 = 92.16$",
            "$r^2 = 24.867...$",
            "$l = \\sqrt{24.867 + 92.16} = \\sqrt{117.027} = 10.818...$",
            "$l \\approx 10.8$ cm (3 sf)"
          ]
        }
      ]
    }
  ]
