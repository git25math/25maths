    {
      "id": "H4-11-Q1",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "In triangle PQR, a line XY is drawn parallel to QR with X on PQ and Y on PR. PX = 5 cm, XQ = 3 cm and QR = 12 cm.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Show that triangles PXY and PQR are similar.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "show-that",
          "correctAnswer": "AA similarity: shared angle P; XY ∥ QR gives equal corresponding angles.",
          "markScheme": [
            { "mark": "M1", "desc": "Angle P is common to both triangles" },
            { "mark": "A1", "desc": "XY ∥ QR gives angle PXY = angle PQR and angle PYX = angle PRQ (corresponding angles); AA similarity" }
          ],
          "workingSteps": [
            "Angle XPY = angle QPR (common angle at P)",
            "Angle PXY = angle PQR (corresponding angles, XY ∥ QR)",
            "By AA: triangles PXY and PQR are similar"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the length XY.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "7.5",
          "tolerance": 0,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "PQ = PX + XQ = 5 + 3 = 8; scale factor = PX/PQ = 5/8" },
            { "mark": "A1", "desc": "XY = QR × 5/8 = 12 × 5/8 = 7.5 cm" }
          ],
          "workingSteps": [
            "PQ = PX + XQ = 5 + 3 = 8 cm",
            "Scale factor PXY to PQR = PQ/PX = 8/5",
            "Scale factor PXY from PQR: PX/PQ = 5/8",
            "XY = QR × (5/8) = 12 × 5/8 = 7.5 cm"
          ]
        },
        {
          "label": "c",
          "questionText": "The area of triangle PXY is 25 cm².\nWork out the area of trapezium XYRQ.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "39",
          "tolerance": 0.5,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "Area scale factor = (PQ/PX)² = (8/5)² = 64/25" },
            { "mark": "M1", "desc": "Area of PQR = 25 × 64/25 = 64 cm²" },
            { "mark": "M1", "desc": "Area of trapezium = Area PQR − Area PXY" },
            { "mark": "A1", "desc": "= 64 − 25 = 39 cm²" }
          ],
          "workingSteps": [
            "Area scale factor (PXY to PQR) = (PQ/PX)² = (8/5)² = 64/25",
            "Area of PQR = 25 × 64/25 = 64 cm²",
            "Area of trapezium XYRQ = Area of PQR − Area of PXY = 64 − 25 = 39 cm²"
          ]
        }
      ]
    },
    {
