      "type": "structured",
      "totalMarks": 6,
      "difficulty": "easy",
      "context": "Ten students each recorded the number of text messages they sent one day.\n\n3, 7, 12, 5, 9, 7, 14, 7, 10, 6",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the mode.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "7",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "7 (appears 3 times)" }
          ],
          "workingSteps": [
            "7 appears three times — the most frequent value → mode = 7"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the median.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "7",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Ordered list: 3,5,6,7,7,7,9,10,12,14; identifies 5th and 6th values" },
            { "mark": "A1", "desc": "(7+7)/2 = 7" }
          ],
          "workingSteps": [
            "Ordered: 3, 5, 6, 7, 7, 7, 9, 10, 12, 14",
            "10 values → median = (5th + 6th)/2 = (7 + 7)/2 = 7"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the mean.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "8",
          "tolerance": 0.05,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Sum = 3+7+12+5+9+7+14+7+10+6 = 80" },
            { "mark": "A1", "desc": "80 ÷ 10 = 8" }
          ],
          "workingSteps": [
            "Sum = 3+7+12+5+9+7+14+7+10+6 = 80",
            "Mean = 80 ÷ 10 = 8"
          ]
        },
        {
          "label": "d",
          "questionText": "Give a reason why the mode might be the most useful average to use here.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "The mode is the most common value and represents the most typical number of messages sent",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "Mode is the most commonly occurring value / most typical oe" }
          ],
          "workingSteps": []
        }
      ]
