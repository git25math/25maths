    {
      "id": "F6-02-Q2",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "medium",
      "context": "The frequency table shows the number of goals scored by a football team in each of 20 matches.\n\n| Goals | Frequency |\n|-------|-----------|\n| 0     | 3         |\n| 1     | 5         |\n| 2     | 6         |\n| 3     | 4         |\n| 4     | 2         |",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the mode.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "2",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "2 (highest frequency = 6)" }
          ],
          "workingSteps": [
            "Highest frequency = 6 for 2 goals → mode = 2"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the median number of goals.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "2",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Identifies 10th and 11th values" },
            { "mark": "A1", "desc": "Cumulative: 3,8,14 → 10th and 11th are both in '2 goals' → median = 2" }
          ],
          "workingSteps": [
            "20 matches → median between 10th and 11th values",
            "Cumulative: ≤0: 3, ≤1: 8, ≤2: 14",
            "10th and 11th values are both 2 → median = 2"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the mean number of goals per match.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "1.85",
          "tolerance": 0.05,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Σfx = 0×3+1×5+2×6+3×4+4×2 attempted" },
            { "mark": "M1", "desc": "Σfx = 0+5+12+12+8 = 37" },
            { "mark": "A1", "desc": "37 ÷ 20 = 1.85" }
          ],
          "workingSteps": [
            "Σfx = 0×3 + 1×5 + 2×6 + 3×4 + 4×2",
            "Σfx = 0 + 5 + 12 + 12 + 8 = 37",
            "Mean = 37 ÷ 20 = 1.85 goals"
          ]
        },
        {
          "label": "d",
          "questionText": "Work out the range of goals scored.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "4",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "4 − 0 = 4" }
          ],
          "workingSteps": [
            "Range = 4 − 0 = 4"
          ]
        }
      ]
    },
