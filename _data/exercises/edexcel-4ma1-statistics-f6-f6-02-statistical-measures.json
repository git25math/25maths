            { "mark": "A1", "desc": "7" }
          ],
          "workingSteps": [
            "Sum of known four = 6+11+8+13 = 38",
            "Fifth number = 45 − 38 = 7"
          ]
        },
        {
          "label": "c",
          "questionText": "A sixth number, 14, is added to the list.\nWork out the new mean.",
