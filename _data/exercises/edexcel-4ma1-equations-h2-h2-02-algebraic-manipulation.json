        {
          "label": "a",
          "questionText": "Express $\\dfrac{3}{x+2} - \\dfrac{2}{x-1}$ as a single fraction in its simplest form.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "(x - 7) / ((x+2)(x-1))",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Common denominator (x+2)(x−1)" },
            { "mark": "M1", "desc": "Numerator: 3(x−1) − 2(x+2) = 3x − 3 − 2x − 4" },
            { "mark": "A1", "desc": "(x − 7) / [(x+2)(x−1)] cao" }
          ],
          "workingSteps": [
            "LCD = (x+2)(x−1)",
            "3/(x+2) = 3(x−1)/[(x+2)(x−1)]",
            "2/(x−1) = 2(x+2)/[(x+2)(x−1)]",
            "Difference = [3(x−1) − 2(x+2)] / [(x+2)(x−1)]",
            "= (3x − 3 − 2x − 4) / [(x+2)(x−1)]",
            "= (x − 7) / [(x+2)(x−1)]"
          ]
        },
        {
          "label": "b",
          "questionText": "Simplify $\\dfrac{2x^2 + 5x - 3}{x^2 - 9}$.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "(2x - 1) / (x - 3)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Factorises numerator: (2x − 1)(x + 3)" },
            { "mark": "M1", "desc": "Factorises denominator: (x + 3)(x − 3)" },
            { "mark": "A1", "desc": "Cancels (x+3)" },
            { "mark": "A1", "desc": "(2x−1)/(x−3) cao" }
          ],
          "workingSteps": [
            "Numerator: 2x² + 5x − 3; try (2x−1)(x+3) = 2x²+6x−x−3 = 2x²+5x−3 ✓",
            "Denominator: x² − 9 = (x+3)(x−3)",
            "Simplify: (2x−1)(x+3) / [(x+3)(x−3)] = (2x−1)/(x−3)"
          ]
        }
      ]
    },
    {
