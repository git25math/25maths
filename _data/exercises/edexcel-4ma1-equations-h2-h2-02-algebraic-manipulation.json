        {
          "label": "a",
          "questionText": "Expand and simplify $(2x + 3)^2 - (x - 1)^2$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "3x^2 + 14x + 8",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Expands (2x+3)² = 4x² + 12x + 9" },
            { "mark": "M1", "desc": "Expands (x−1)² = x² − 2x + 1; subtracts" },
            { "mark": "A1", "desc": "3x² + 14x + 8 cao" }
          ],
          "workingSteps": [
            "(2x+3)² = 4x² + 12x + 9",
            "(x−1)² = x² − 2x + 1",
            "Difference = (4x² + 12x + 9) − (x² − 2x + 1)",
            "= 3x² + 14x + 8"
          ]
        },
        {
          "label": "b",
          "questionText": "Factorise fully $6x^2 y - 9xy^2$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "3xy(2x - 3y)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Identifies HCF as 3xy" },
            { "mark": "A1", "desc": "3xy(2x − 3y) cao" }
          ],
          "workingSteps": [
            "HCF of 6x²y and 9xy² = 3xy",
            "6x²y ÷ 3xy = 2x, 9xy² ÷ 3xy = 3y",
            "Answer: 3xy(2x − 3y)"
          ]
        },
        {
          "label": "c",
          "questionText": "Simplify $\\dfrac{x^2 - 4}{x^2 + 4x + 4}$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "(x - 2) / (x + 2)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Factorises numerator: (x+2)(x−2)" },
            { "mark": "M1", "desc": "Factorises denominator: (x+2)²" },
            { "mark": "A1", "desc": "(x−2)/(x+2) cao" }
          ],
          "workingSteps": [
            "Numerator: x² − 4 = (x+2)(x−2)",
            "Denominator: x² + 4x + 4 = (x+2)²",
            "Simplify: (x+2)(x−2) / (x+2)² = (x−2)/(x+2)"
          ]
        }
      ]
    },
    {
