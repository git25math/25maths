        {
          "label": "a",
          "questionText": "Expand and simplify $(x + y)^3$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x^3 + 3x^2y + 3xy^2 + y^3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "(x+y)² = x² + 2xy + y² used" },
            { "mark": "M1", "desc": "Multiplies by (x+y): x³ + 2x²y + xy² + x²y + 2xy² + y³" },
            { "mark": "A1", "desc": "x³ + 3x²y + 3xy² + y³ cao" }
          ],
          "workingSteps": [
            "(x+y)³ = (x+y)² × (x+y)",
            "= (x² + 2xy + y²)(x+y)",
            "= x³ + x²y + 2x²y + 2xy² + xy² + y³",
            "= x³ + 3x²y + 3xy² + y³"
          ]
        },
        {
          "label": "b",
          "questionText": "Hence work out $11^3$ without a calculator, using $x = 10$ and $y = 1$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "1331",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "10³ + 3(10²)(1) + 3(10)(1²) + 1³" },
            { "mark": "A1", "desc": "1000 + 300 + 30 + 1 = 1331 cao" }
          ],
          "workingSteps": [
            "11³ = (10+1)³ = 10³ + 3(10²)(1) + 3(10)(1²) + 1³",
            "= 1000 + 300 + 30 + 1 = 1331"
          ]
        },
        {
          "label": "c",
          "questionText": "Show that $(a - b)(a^2 + ab + b^2) = a^3 - b^3$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "show-that",
          "correctAnswer": "a³ + a²b + ab² − a²b − ab² − b³ = a³ − b³",
          "markScheme": [
            { "mark": "M1", "desc": "Expands: a³ + a²b + ab² − a²b − ab² − b³" },
            { "mark": "A1", "desc": "Middle terms cancel to give a³ − b³ with full working shown" }
          ],
          "workingSteps": [
            "(a−b)(a²+ab+b²)",
            "= a(a²+ab+b²) − b(a²+ab+b²)",
            "= a³ + a²b + ab² − a²b − ab² − b³",
            "= a³ − b³ ✓ (middle terms cancel)"
          ]
        }
      ]
    }
