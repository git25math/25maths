      "totalMarks": 6,
      "difficulty": "medium",
      "context": "A shape is made by joining a rectangle and a semicircle.\nThe rectangle has length 10 cm and width 6 cm.\nThe semicircle has the same diameter as the width of the rectangle.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Calculate the area of the shape.",
          "marks": 4,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "74.1",
          "tolerance": 0.1,
          "unit": "cm²",
          "markScheme": [
            {
              "mark": "M1",
              "desc": "Rectangle area = 10 × 6 = 60"
            },
            {
              "mark": "M1",
              "desc": "Semicircle area = ½π × 3²"
            },
            {
              "mark": "M1",
              "desc": "60 + 14.14"
            },
            {
              "mark": "A1",
              "desc": "74.1"
            }
          ],
          "workingSteps": [
            "Rectangle = 10 × 6 = 60 cm²",
            "Semicircle: r = 3, area = ½π × 9 = 14.14 cm²",
            "Total = 60 + 14.14 = 74.1 cm²"
          ]
        },
        {
          "label": "b",
          "questionText": "Calculate the perimeter of the shape.",
          "marks": 2,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "35.4",
          "tolerance": 0.1,
          "unit": "cm",
          "markScheme": [
            {
              "mark": "M1",
              "desc": "10 + 6 + 10 + πr (semicircle arc)"
            },
            {
              "mark": "A1",
              "desc": "10 + 6 + 10 + 3π = 35.4"
            }
          ],
          "workingSteps": [
            "Perimeter = 10 + 6 + 10 + π × 3 = 26 + 9.42 = 35.4 cm"
          ]
        }
      ]
    },
