      "commandWord": "find",
      "difficulty": "hard",
      "questionText": "The vector $\\begin{pmatrix} 3k \\\\ 4k \\end{pmatrix}$ has magnitude 10.\nFind the positive value of $k$.",
      "answerType": "integer",
      "correctAnswer": "2",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        {
          "mark": "M1",
          "desc": "√(9k² + 16k²) = 10"
        },
        {
          "mark": "M1",
          "desc": "5k = 10"
        },
        {
          "mark": "A1",
          "desc": "k = 2"
        }
      ],
      "workingSteps": [
        "√((3k)² + (4k)²) = √(9k² + 16k²) = √(25k²) = 5k",
        "5k = 10, k = 2"
      ],
      "explanation": "Factor out k from under the square root."
