    {
      "id": "F1-09-Q2",
      "type": "structured",
      "totalMarks": 5,
      "difficulty": "medium",
      "context": "The distance from Earth to the Moon is approximately $3.84 \\times 10^5$ km.\nThe distance from Earth to the Sun is approximately $1.50 \\times 10^8$ km.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the difference between these two distances.\nGive your answer in standard form.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "$1.49616 \\times 10^8$",
          "tolerance": null,
          "unit": "km",
          "markScheme": [
            { "mark": "M1", "desc": "Converts to same power: $1.50 \\times 10^8 - 0.00384 \\times 10^8$" },
            { "mark": "M1", "desc": "$= (1.50 - 0.00384) \\times 10^8$" },
            { "mark": "A1", "desc": "$1.49616 \\times 10^8$ km cao" }
          ],
          "workingSteps": [
            "$1.50 \\times 10^8 - 3.84 \\times 10^5$",
            "$= 1.50 \\times 10^8 - 0.00384 \\times 10^8$",
            "$= 1.49616 \\times 10^8$ km"
          ]
        },
        {
          "label": "b",
          "questionText": "Light travels at $3 \\times 10^5$ km/s.\nWork out the time, in seconds, for light to travel from Earth to the Moon.\nGive your answer in standard form.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "1.28",
          "tolerance": 0.01,
          "unit": "s",
          "markScheme": [
            { "mark": "M1", "desc": "$\\dfrac{3.84 \\times 10^5}{3 \\times 10^5}$" },
            { "mark": "A1", "desc": "$1.28$ s (or $1.28 \\times 10^0$)" }
          ],
          "workingSteps": [
            "Time $= \\dfrac{3.84 \\times 10^5}{3 \\times 10^5} = \\dfrac{3.84}{3} = 1.28$ s"
          ]
        }
      ]
    }
