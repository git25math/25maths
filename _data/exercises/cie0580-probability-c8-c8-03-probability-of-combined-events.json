              "mark": "M1",
              "desc": "0.4 × 0.4 or 4/10 × 4/10"
            },
            {
              "mark": "A1",
              "desc": "0.16 or 4/25"
            }
          ],
          "workingSteps": [
            "P(RR) = 4/10 × 4/10 = 16/100 = 4/25"
          ]
        },
        {
          "label": "c",
          "questionText": "Find the probability that the two balls are different colours.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "12/25",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "P(RB) = 0.4 × 0.6 = 0.24"
            },
            {
              "mark": "M1",
              "desc": "P(BR) = 0.6 × 0.4 = 0.24"
            },
            {
              "mark": "M1",
              "desc": "P(different) = P(RB) + P(BR)"
            },
            {
              "mark": "A1",
              "desc": "0.48 or 12/25"
            }
          ],
          "workingSteps": [
            "P(RB) = 4/10 × 6/10 = 24/100",
            "P(BR) = 6/10 × 4/10 = 24/100",
            "P(different) = 24/100 + 24/100 = 48/100 = 12/25"
          ]
        }
