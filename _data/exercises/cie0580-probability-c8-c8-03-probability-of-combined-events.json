          "markScheme": [
            {
              "mark": "B1",
              "desc": "First pick: 4/10 (R), 6/10 (B)"
            },
            {
              "mark": "B1",
              "desc": "Second pick: same probabilities (with replacement)"
            }
          ],
          "workingSteps": [
            "P(R) = 4/10 = 0.4, P(B) = 6/10 = 0.6 for both picks (replacement)"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the probability that both balls are red.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "4/25",
          "tolerance": null,
          "unit": null,
          "markScheme": [
