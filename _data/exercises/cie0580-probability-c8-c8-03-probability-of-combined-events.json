    {
      "id": "C8-03-Q2",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "The probability that Aisha passes her maths test is 0.8.\nThe probability that she passes her science test is 0.6.\nThe two events are independent.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the probability that Aisha passes both tests.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.48",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "0.8 × 0.6"
            },
            {
              "mark": "A1",
              "desc": "0.48"
            }
          ],
          "workingSteps": [
            "P(both) = 0.8 × 0.6 = 0.48"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the probability that Aisha passes exactly one test.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "0.44",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "P(M only) = 0.8 × 0.4 = 0.32"
            },
            {
              "mark": "M1",
              "desc": "P(S only) = 0.2 × 0.6 = 0.12"
            },
            {
              "mark": "M1",
              "desc": "P(exactly one) = 0.32 + 0.12"
            },
            {
              "mark": "A1",
              "desc": "0.44"
            }
          ],
          "workingSteps": [
            "P(maths only) = 0.8 × (1−0.6) = 0.8 × 0.4 = 0.32",
            "P(science only) = (1−0.8) × 0.6 = 0.2 × 0.6 = 0.12",
            "P(exactly one) = 0.32 + 0.12 = 0.44"
          ]
        }
      ]
    },
