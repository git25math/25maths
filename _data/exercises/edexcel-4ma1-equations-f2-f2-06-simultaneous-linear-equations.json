    {
      "id": "F2-06-Q2",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "medium",
      "context": "At a market stall, 3 sandwiches and 2 drinks cost £10.00.\n1 sandwich and 4 drinks cost £8.00.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Let $s$ be the price of a sandwich and $d$ be the price of a drink.\nWrite down two equations in $s$ and $d$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "3s + 2d = 10 and s + 4d = 8",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "3s + 2d = 10 oe" },
            { "mark": "B1", "desc": "s + 4d = 8 oe" }
          ],
          "workingSteps": [
            "3 sandwiches + 2 drinks = £10.00 → 3s + 2d = 10",
            "1 sandwich + 4 drinks = £8.00 → s + 4d = 8"
          ]
        },
        {
          "label": "b",
          "questionText": "Solve your equations to find the price of a sandwich and the price of a drink.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "sandwich = £2.40, drink = £1.40",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Multiplies eq 2 by 3: 3s + 12d = 24; subtracts eq 1" },
            { "mark": "A1", "desc": "d = 1.40" },
            { "mark": "A1", "desc": "s = 2.40" }
          ],
          "workingSteps": [
            "Multiply eq 2 by 3: 3s + 12d = 24",
            "Subtract eq 1: 10d = 14",
            "d = 1.40",
            "Substitute into eq 2: s + 4 × 1.40 = 8 → s + 5.60 = 8 → s = 2.40"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the total cost of 2 sandwiches and 3 drinks.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "9.00",
          "tolerance": 0.01,
          "unit": "£",
          "markScheme": [
            { "mark": "B1", "desc": "2 × 2.40 + 3 × 1.40 = 4.80 + 4.20 = £9.00 ft their values" }
          ],
          "workingSteps": [
            "2 × 2.40 = 4.80",
            "3 × 1.40 = 4.20",
            "Total = 4.80 + 4.20 = £9.00"
          ]
        }
      ]
    },
    {
