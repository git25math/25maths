        {
          "label": "c",
          "questionText": "Solve the simultaneous equations:\n$$2x + 3y = 12$$\n$$x + y = 5$$",
          "marks": 3,
          "commandWord": "find",
          "answerType": "coordinate",
          "correctAnswer": "(3, 2)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Multiplies eq 2 by 2 to get 2x + 2y = 10; subtracts from eq 1" },
            { "mark": "A1", "desc": "y = 2" },
            { "mark": "A1", "desc": "x = 3" }
          ],
          "workingSteps": [
            "Multiply eq 2 by 2: 2x + 2y = 10",
            "Subtract from eq 1: (2x + 3y) − (2x + 2y) = 12 − 10",
            "y = 2",
            "Substitute into eq 2: x + 2 = 5, x = 3"
          ]
        }
      ]
