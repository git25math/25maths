        {
          "label": "a",
          "questionText": "Solve the simultaneous equations:\n$$3x + 2y = 16$$\n$$5x - y = 18$$",
          "marks": 4,
          "commandWord": "find",
          "answerType": "coordinate",
          "correctAnswer": "(4, 2)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Multiplies eq 2 by 2: 10x − 2y = 36; adds to eq 1" },
            { "mark": "M1", "desc": "13x = 52" },
            { "mark": "A1", "desc": "x = 4" },
            { "mark": "A1", "desc": "y = 2" }
          ],
          "workingSteps": [
            "Multiply eq 2 by 2: 10x − 2y = 36",
            "Add to eq 1: (3x + 2y) + (10x − 2y) = 16 + 36",
            "13x = 52, x = 4",
            "Substitute into eq 2: 5 × 4 − y = 18 → 20 − y = 18 → y = 2"
          ]
        },
        {
          "label": "b",
          "questionText": "Show that your solution satisfies both original equations.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "show-that",
          "correctAnswer": "3(4) + 2(2) = 16 and 5(4) − 2 = 18",
          "markScheme": [
            { "mark": "B1", "desc": "Both: 3×4 + 2×2 = 16 ✓ and 5×4 − 2 = 18 ✓ shown" }
          ],
          "workingSteps": [
            "Eq 1: 3 × 4 + 2 × 2 = 12 + 4 = 16 ✓",
            "Eq 2: 5 × 4 − 2 = 20 − 2 = 18 ✓"
          ]
        }
      ]
    }
