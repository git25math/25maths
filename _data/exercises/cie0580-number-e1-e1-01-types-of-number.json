      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "Find the highest common factor (HCF) and lowest common multiple (LCM) of $36$ and $48$.",
      "answerType": "table-fill",
      "correctAnswer": ["12", "144"],
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Prime factor decomposition: $36 = 2^2 \\times 3^2$, $48 = 2^4 \\times 3$" },
        { "mark": "A1", "desc": "HCF $= 2^2 \\times 3 = 12$" },
        { "mark": "A1", "desc": "LCM $= 2^4 \\times 3^2 = 144$" }
      ],
      "workingSteps": [
        "$36 = 2^2 \\times 3^2$",
        "$48 = 2^4 \\times 3$",
        "HCF: lowest powers common to both: $2^2 \\times 3^1 = 12$",
        "LCM: highest powers: $2^4 \\times 3^2 = 16 \\times 9 = 144$"
      ],
      "explanation": "Use prime factorisation to find HCF (shared factors) and LCM (all factors)."
    },
    {
      "id": "E1-01-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "find",
      "difficulty": "medium",
      "questionText": "Write $180$ as a product of its prime factors.",
      "answerType": "expression",
      "correctAnswer": "$2^2 \\times 3^2 \\times 5$",
      "tolerance": null,
      "unit": null,
      "markScheme": [
        { "mark": "M1", "desc": "Systematic division by prime factors" },
        { "mark": "M1", "desc": "At least two correct prime factors identified" },
        { "mark": "A1", "desc": "$2^2 \\times 3^2 \\times 5$ cao" }
      ],
      "workingSteps": [
        "$180 \\div 2 = 90$",
        "$90 \\div 2 = 45$",
        "$45 \\div 3 = 15$",
        "$15 \\div 3 = 5$",
        "$5 \\div 5 = 1$",
        "$180 = 2^2 \\times 3^2 \\times 5$"
      ],
      "explanation": "Divide repeatedly by the smallest prime factor until you reach 1."
    },
