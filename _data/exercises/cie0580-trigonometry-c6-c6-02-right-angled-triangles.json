    {
      "id": "C6-02-Q1",
      "type": "short-answer",
      "totalMarks": 2,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "In a right-angled triangle, the hypotenuse is 10 cm and one angle is 30°.\nCalculate the length of the side opposite the 30° angle.",
      "answerType": "integer",
      "correctAnswer": "5",
      "tolerance": null,
      "unit": "cm",
      "markScheme": [
        { "mark": "M1", "desc": "10 × sin30 or 10 × 0.5" },
        { "mark": "A1", "desc": "5" }
      ],
      "workingSteps": [
        "opposite = hypotenuse × sin30°",
        "= 10 × 0.5 = 5 cm"
      ],
      "explanation": "sin = opposite / hypotenuse, so opposite = hyp × sin θ."
    },
    {
      "id": "C6-02-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "A ladder of length 5 m leans against a vertical wall.\nThe foot of the ladder is 2 m from the base of the wall.\nCalculate the angle the ladder makes with the ground.",
      "answerType": "numeric",
      "correctAnswer": "66.4",
      "tolerance": 0.1,
      "unit": "°",
      "markScheme": [
        { "mark": "M1", "desc": "cos θ = 2/5 or appropriate trig ratio" },
        { "mark": "M1", "desc": "cos⁻¹(0.4)" },
        { "mark": "A1", "desc": "66.4° or 66.42°" }
      ],
      "workingSteps": [
        "cos θ = adjacent / hypotenuse = 2 / 5 = 0.4",
        "θ = cos⁻¹(0.4) = 66.4°"
      ],
      "explanation": "Use cosine when you know the adjacent side and hypotenuse."
    },
    {
      "id": "C6-02-Q3",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "In a right-angled triangle, one angle is 40° and the side adjacent to this angle is 12 cm.\nCalculate the length of the opposite side.",
      "answerType": "numeric",
      "correctAnswer": "10.1",
      "tolerance": 0.1,
      "unit": "cm",
      "markScheme": [
        { "mark": "M1", "desc": "tan40 = opp/12 oe" },
        { "mark": "M1", "desc": "12 × tan40" },
        { "mark": "A1", "desc": "10.1 or 10.07" }
      ],
      "workingSteps": [
        "tan40° = opposite / 12",
        "opposite = 12 × tan40° = 12 × 0.8391 = 10.1 cm"
      ],
      "explanation": "Use tangent when you know the adjacent side and need the opposite."
    },
    {
      "id": "C6-02-Q4",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "medium",
      "context": "A ship sails 8 km due North from port P to point Q.\nIt then sails 6 km due East to point R.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Calculate the distance PR.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "integer",
          "correctAnswer": "10",
          "tolerance": null,
          "unit": "km",
          "markScheme": [
            { "mark": "M1", "desc": "8² + 6² soi" },
            { "mark": "M1", "desc": "√100" },
            { "mark": "A1", "desc": "10" }
          ],
          "workingSteps": [
            "PR² = 8² + 6² = 64 + 36 = 100",
            "PR = 10 km"
          ]
        },
        {
          "label": "b",
          "questionText": "Calculate the bearing of R from P.",
          "marks": 4,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "036.9",
          "tolerance": 0.1,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "tan θ = 6/8 or appropriate ratio" },
            { "mark": "A1", "desc": "θ = 36.9° or 36.87°" },
            { "mark": "M1", "desc": "Bearing = angle measured from North clockwise" },
            { "mark": "A1", "desc": "036.9° or 037°" }
          ],
          "workingSteps": [
            "tan θ = 6/8 = 0.75",
            "θ = tan⁻¹(0.75) = 36.87°",
            "Bearing of R from P = 036.9° (measured clockwise from North)"
          ]
        }
      ]
    },
    {
      "id": "C6-02-Q5",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "A right-angled triangle has sides 3 cm (opposite) and 4 cm (adjacent) to angle θ.\nCalculate angle θ.",
      "answerType": "numeric",
      "correctAnswer": "36.9",
      "tolerance": 0.1,
      "unit": "°",
      "markScheme": [
        { "mark": "M1", "desc": "tan θ = 3/4 oe" },
        { "mark": "M1", "desc": "tan⁻¹(0.75)" },
        { "mark": "A1", "desc": "36.9° or 36.87°" }
      ],
      "workingSteps": [
        "tan θ = opposite / adjacent = 3/4 = 0.75",
        "θ = tan⁻¹(0.75) = 36.9°"
      ],
      "explanation": "Use inverse tangent to find an angle from opposite and adjacent."
    }
  ]
