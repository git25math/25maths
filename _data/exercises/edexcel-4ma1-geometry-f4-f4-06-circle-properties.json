  "questions": [
    {
      "id": "F4-06-Q1",
      "type": "structured",
      "totalMarks": 5,
      "difficulty": "easy",
      "context": "A circle has centre O and radius 7 cm.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the circumference of the circle.\nGive your answer correct to 1 decimal place.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "44.0",
          "tolerance": 0.05,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "π × 2 × 7 or π × 14" },
            { "mark": "A1", "desc": "44.0 cm" }
          ],
          "workingSteps": [
            "Circumference = 2πr = 2 × π × 7 = 14π = 43.98... ≈ 44.0 cm"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the area of the circle.\nGive your answer correct to 1 decimal place.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "153.9",
          "tolerance": 0.1,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "π × 7²" },
            { "mark": "A1", "desc": "153.9 cm²" }
          ],
          "workingSteps": [
            "Area = πr² = π × 49 = 153.94... ≈ 153.9 cm²"
          ]
        },
        {
          "label": "c",
          "questionText": "A chord of the circle is 10 cm long.\nWork out the perpendicular distance from the centre O to the chord.",
          "marks": 1,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "4.90",
          "tolerance": 0.01,
          "unit": "cm",
          "markScheme": [
            { "mark": "B1", "desc": "√(7² − 5²) = √(49 − 25) = √24 = 4.90 (3sf)" }
          ],
          "workingSteps": [
            "The perpendicular from O bisects the chord, giving half-chord = 5 cm",
            "Distance² = 7² − 5² = 49 − 25 = 24",
            "Distance = √24 = 4.90 cm (3sf)"
          ]
        }
      ]
    },
    {
      "id": "F4-06-Q2",
      "type": "structured",
      "totalMarks": 7,
      "difficulty": "medium",
      "context": "O is the centre of a circle. A and B are points on the circumference. Angle AOB = 80°.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the angle ACB where C is on the major arc.\nGive a reason for your answer.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "40",
          "tolerance": null,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "Angle at centre = 2 × angle at circumference" },
            { "mark": "A1", "desc": "80 ÷ 2 = 40°" },
            { "mark": "B1", "desc": "Angle at centre is twice the angle at circumference (same arc)" }
          ],
          "workingSteps": [
            "Angle at centre = 2 × angle at circumference (same arc AB)",
            "Angle ACB = 80° ÷ 2 = 40°"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the arc length AB.\nGive your answer in terms of π. The radius is 9 cm.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "4π",
          "tolerance": null,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "(80/360) × 2π × 9 or (2/9)π × 9" },
            { "mark": "A1", "desc": "4π cm" }
          ],
          "workingSteps": [
            "Arc length = (angle/360) × 2πr",
            "= (80/360) × 2π × 9",
            "= (2/9) × 18π",
            "= 4π cm"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out the area of the sector AOB with radius 9 cm and angle 80°.\nGive your answer correct to 3 significant figures.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "56.5",
          "tolerance": 0.1,
          "unit": "cm²",
          "markScheme": [
            { "mark": "M1", "desc": "(80/360) × π × 9²" },
            { "mark": "A1", "desc": "56.5 cm² (3sf)" }
          ],
          "workingSteps": [
            "Area of sector = (80/360) × π × 81",
            "= (2/9) × 81π",
            "= 18π = 56.548... ≈ 56.5 cm²"
          ]
        }
      ]
    }
  ]
}
