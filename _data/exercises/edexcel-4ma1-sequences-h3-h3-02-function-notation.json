  "questions": [
    {
      "id": "H3-02-Q1",
      "type": "structured",
      "totalMarks": 10,
      "difficulty": "medium",
      "context": "$f(x) = 2x + 1$ and $g(x) = x^2 - 3$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out $fg(4)$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "27",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Works out g(4) = 16 − 3 = 13" },
            { "mark": "M1", "desc": "Substitutes their g(4) into f: f(13) = 2(13) + 1" },
            { "mark": "A1", "desc": "27 cao" }
          ],
          "workingSteps": [
            "g(4) = 4² − 3 = 16 − 3 = 13",
            "fg(4) = f(13) = 2(13) + 1 = 26 + 1 = 27"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out $gf(x)$, giving your answer in its simplest form.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "4x² + 4x − 2",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes f(x) = 2x + 1 into g: (2x+1)² − 3" },
            { "mark": "M1", "desc": "Expands (2x+1)² = 4x² + 4x + 1" },
            { "mark": "A1", "desc": "4x² + 4x − 2 cao" }
          ],
          "workingSteps": [
            "gf(x) = g(2x + 1) = (2x + 1)² − 3",
            "(2x + 1)² = 4x² + 4x + 1",
            "gf(x) = 4x² + 4x + 1 − 3 = 4x² + 4x − 2"
          ]
        },
        {
          "label": "c",
          "questionText": "Find $f^{-1}(x)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "(x − 1)/2",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Writes y = 2x + 1 and swaps x and y: x = 2y + 1" },
            { "mark": "A1", "desc": "f⁻¹(x) = (x − 1)/2 cao" }
          ],
          "workingSteps": [
            "Let y = 2x + 1",
            "Swap x and y: x = 2y + 1",
            "2y = x − 1",
            "y = (x − 1)/2",
            "f⁻¹(x) = (x − 1)/2"
          ]
        },
        {
          "label": "d",
          "questionText": "Work out $f^{-1}(9)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "4",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes x = 9 into their f⁻¹(x)" },
            { "mark": "A1", "desc": "4 cao" }
          ],
          "workingSteps": [
            "f⁻¹(9) = (9 − 1)/2 = 8/2 = 4",
            "Check: f(4) = 2(4) + 1 = 9 ✓"
          ]
        }
      ]
    },
    {
      "id": "H3-02-Q2",
      "type": "structured",
      "totalMarks": 10,
      "difficulty": "hard",
      "context": "$p(x) = \\dfrac{3x + 1}{x - 2}$, where $x \\neq 2$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out $p(5)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "\\frac{16}{3}",
          "tolerance": 0.01,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes x = 5: (15+1)/(5−2)" },
            { "mark": "A1", "desc": "16/3 or 5.33… cao" }
          ],
          "workingSteps": [
            "p(5) = (3×5 + 1)/(5 − 2) = 16/3"
          ]
        },
        {
          "label": "b",
          "questionText": "Find $p^{-1}(x)$.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "(2x + 1)/(3 − x)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Writes y = (3x+1)/(x−2) and rearranges: y(x−2) = 3x+1" },
            { "mark": "M1", "desc": "Expands and collects x terms: xy − 3x = 2y + 1 → x(y−3) = 2y+1" },
            { "mark": "A1", "desc": "x = (2y+1)/(y−3) seen" },
            { "mark": "A1", "desc": "p⁻¹(x) = (2x+1)/(x−3) cao" }
          ],
          "workingSteps": [
            "Let y = (3x + 1)/(x − 2)",
            "y(x − 2) = 3x + 1",
            "xy − 2y = 3x + 1",
            "xy − 3x = 2y + 1",
            "x(y − 3) = 2y + 1",
            "x = (2y + 1)/(y − 3)",
            "p⁻¹(x) = (2x + 1)/(x − 3)"
          ]
        },
        {
          "label": "c",
          "questionText": "Work out $p^{-1}(7)$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "3.75",
          "tolerance": 0.01,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes x = 7 into their p⁻¹(x): (14+1)/(7−3)" },
            { "mark": "A1", "desc": "15/4 or 3.75 cao" }
          ],
          "workingSteps": [
            "p⁻¹(7) = (2×7 + 1)/(7 − 3) = 15/4 = 3.75",
            "Check: p(3.75) = (11.25 + 1)/(3.75 − 2) = 12.25/1.75 = 7 ✓"
          ]
        },
        {
          "label": "d",
          "questionText": "Write down the value of $x$ for which $p^{-1}(x)$ is not defined.",
          "marks": 2,
          "commandWord": "write-down",
          "answerType": "integer",
          "correctAnswer": "3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "B1", "desc": "States denominator of p⁻¹(x) is x − 3" },
            { "mark": "B1", "desc": "x = 3 cao" }
          ],
          "workingSteps": [
            "p⁻¹(x) = (2x+1)/(x−3) is undefined when denominator = 0",
            "x − 3 = 0 → x = 3"
          ]
        }
      ]
    },
    {
      "id": "H3-02-Q3",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "$f(x) = x^2 + 4$ and $g(x) = 3x - 2$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out $f^{-1}(x)$, stating any restrictions on $x$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "√(x − 4), x ≥ 4",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Writes y = x² + 4, swaps: x = y² + 4 → y² = x − 4" },
            { "mark": "A1", "desc": "f⁻¹(x) = √(x − 4)" },
            { "mark": "A1", "desc": "States x ≥ 4 oe" }
          ],
          "workingSteps": [
            "Let y = x² + 4 (for x ≥ 0)",
            "Swap: x = y² + 4",
            "y² = x − 4",
            "y = √(x − 4)",
            "f⁻¹(x) = √(x − 4), defined for x ≥ 4"
          ]
        },
        {
          "label": "b",
          "questionText": "Solve $fg(x) = 53$.",
          "marks": 5,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "x = 3 or x = −5/3",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Forms fg(x): f(3x−2) = (3x−2)² + 4" },
            { "mark": "M1", "desc": "Sets (3x−2)² + 4 = 53 → (3x−2)² = 49" },
            { "mark": "M1", "desc": "Takes square root: 3x − 2 = ±7" },
            { "mark": "A1", "desc": "x = 3" },
            { "mark": "A1", "desc": "x = −5/3 oe cao" }
          ],
          "workingSteps": [
            "fg(x) = f(3x − 2) = (3x − 2)² + 4",
            "(3x − 2)² + 4 = 53",
            "(3x − 2)² = 49",
            "3x − 2 = ±7",
            "Case 1: 3x − 2 = 7 → 3x = 9 → x = 3",
            "Case 2: 3x − 2 = −7 → 3x = −5 → x = −5/3",
            "Check x=3: g(3)=7, f(7)=49+4=53 ✓",
            "Check x=−5/3: g(−5/3)=−7, f(−7)=49+4=53 ✓"
          ]
        }
      ]
    }
  ]
