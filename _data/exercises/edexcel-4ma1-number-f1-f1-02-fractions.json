          ],
          "workingSteps": [
            "$\\dfrac{3}{4} \\times 2.40 = 0.75 \\times 2.40 = \\$1.80$"
          ]
        },
        {
          "label": "c",
          "questionText": "The baker has $2$ kg of flour.\nHow many times can she make the recipe?",
