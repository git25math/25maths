        {
          "label": "b",
          "questionText": "Work out $2\\dfrac{1}{3} - 1\\dfrac{3}{4}$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "7/12",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Converts to improper fractions: $\\dfrac{7}{3} - \\dfrac{7}{4} = \\dfrac{28}{12} - \\dfrac{21}{12}$" },
            { "mark": "A1", "desc": "$\\dfrac{7}{12}$ cao" }
          ],
          "workingSteps": [
            "$2\\dfrac{1}{3} = \\dfrac{7}{3} = \\dfrac{28}{12}$",
            "$1\\dfrac{3}{4} = \\dfrac{7}{4} = \\dfrac{21}{12}$",
            "$\\dfrac{28}{12} - \\dfrac{21}{12} = \\dfrac{7}{12}$"
          ]
        }
      ]
