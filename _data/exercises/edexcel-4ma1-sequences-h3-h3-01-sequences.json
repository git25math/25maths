    {
      "id": "H3-01-Q1",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "medium",
      "context": "Here are the first five terms of a quadratic sequence.\n$$3, \\ 8, \\ 15, \\ 24, \\ 35$$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Show that the $n$th term of the sequence is $n^2 + 2n$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "show-that",
          "correctAnswer": "n² + 2n",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "First differences: 5, 7, 9, 11 (arithmetic); second differences: 2, 2, 2 → coefficient of n² is 2/2 = 1" },
            { "mark": "M1", "desc": "Subtracts n² from each term: 3−1=2, 8−4=4, 15−9=6, … → linear sequence 2n" },
            { "mark": "A1", "desc": "Concludes nth term = n² + 2n and verifies at least one term" }
          ],
          "workingSteps": [
            "First differences: 8−3=5, 15−8=7, 24−15=9, 35−24=11",
            "Second differences: 7−5=2, 9−7=2, 11−9=2 (constant = 2)",
            "Coefficient of n² = 2 ÷ 2 = 1",
            "Subtract n² from each term: 3−1=2, 8−4=4, 15−9=6, 24−16=8, 35−25=10",
            "Remainder sequence: 2, 4, 6, 8, 10 → nth term is 2n",
            "Full nth term: n² + 2n",
            "Check n=1: 1+2=3 ✓, n=3: 9+6=15 ✓, n=5: 25+10=35 ✓"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the 10th term of the sequence.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "120",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes n = 10 into n² + 2n" },
            { "mark": "A1", "desc": "120 cao" }
          ],
          "workingSteps": [
            "n = 10: 10² + 2(10) = 100 + 20 = 120"
          ]
        },
        {
          "label": "c",
          "questionText": "Is 288 a term in this sequence? Give a reason for your answer.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "explain",
          "correctAnswer": "Yes — n² + 2n = 288 gives n = 16 (a positive integer), so 288 is the 16th term.",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Sets n² + 2n = 288 → n² + 2n − 288 = 0" },
            { "mark": "M1", "desc": "Solves: (n + 18)(n − 16) = 0 or quadratic formula; selects positive root" },
            { "mark": "A1", "desc": "n = 16 (a positive integer), so 288 is a term cao" }
          ],
          "workingSteps": [
            "n² + 2n = 288",
            "n² + 2n − 288 = 0",
            "(n + 18)(n − 16) = 0",
            "n = −18 or n = 16",
            "n must be a positive integer, so n = 16",
            "288 is the 16th term of the sequence"
          ]
        }
      ]
    },
