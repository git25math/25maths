    {
      "id": "H3-01-Q3",
      "type": "structured",
      "totalMarks": 13,
      "difficulty": "hard",
      "context": "Here are the first five terms of a quadratic sequence.\n$$2, \\ 9, \\ 20, \\ 35, \\ 54$$",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the $n$th term of the sequence.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "2n² + n − 1",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "First differences: 7, 11, 15, 19; second differences: 4, 4, 4 → coefficient of n² is 4÷2 = 2" },
            { "mark": "M1", "desc": "Subtracts 2n² from each term: remainders 0, 1, 2, 3, 4 → linear part is n − 1" },
            { "mark": "A1", "desc": "Combines to give 2n² + n − 1" },
            { "mark": "A1", "desc": "Verifies: n=1 → 2+1−1=2 ✓, n=2 → 8+2−1=9 ✓, n=5 → 50+5−1=54 ✓" }
          ],
          "workingSteps": [
            "First differences: 9−2=7, 20−9=11, 35−20=15, 54−35=19",
            "Second differences: 11−7=4, 15−11=4, 19−15=4 (constant = 4)",
            "Coefficient of n² = 4 ÷ 2 = 2",
            "2n² values: 2, 8, 18, 32, 50",
            "Remainders: 2−2=0, 9−8=1, 20−18=2, 35−32=3, 54−50=4 → nth part = n−1",
            "nth term = 2n² + (n − 1) = 2n² + n − 1",
            "Check: n=1: 2+1−1=2 ✓, n=3: 18+3−1=20 ✓, n=5: 50+5−1=54 ✓"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the 20th term of the sequence.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "819",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Substitutes n = 20 into 2n² + n − 1" },
            { "mark": "A1", "desc": "819 cao" }
          ],
          "workingSteps": [
            "nth term = 2n² + n − 1",
            "n = 20: 2(400) + 20 − 1 = 800 + 19 = 819"
          ]
        },
        {
          "label": "c",
          "questionText": "Find the value of $n$ for which the $n$th term equals 299.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "12",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Sets 2n² + n − 1 = 299 → 2n² + n − 300 = 0" },
            { "mark": "M1", "desc": "Applies quadratic formula or factorises; discriminant = 1 + 2400 = 2401 = 49²" },
            { "mark": "A1", "desc": "n = (−1 + 49) ÷ 4 = 12; selects positive root" },
            { "mark": "A1", "desc": "n = 12 cao" }
          ],
          "workingSteps": [
            "2n² + n − 1 = 299",
            "2n² + n − 300 = 0",
            "Discriminant = 1² + 4(2)(300) = 1 + 2400 = 2401 = 49²",
            "n = (−1 ± 49) / (2 × 2) = (−1 ± 49) / 4",
            "n = 48/4 = 12 (taking positive root)",
            "Check: 2(144) + 12 − 1 = 288 + 11 = 299 ✓"
          ]
