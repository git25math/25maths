    {
      "id": "H1-05-Q2",
      "type": "structured",
      "totalMarks": 6,
      "difficulty": "hard",
      "context": "In a survey of 100 people:\n- 45 own a dog ($D$)\n- 30 own a cat ($C$)\n- 15 own both a dog and a cat\n- $x$ own neither",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Find the value of $x$.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "40",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "$n(D \\cup C) = 45 + 30 - 15 = 60$" },
            { "mark": "M1", "desc": "$x = 100 - 60$" },
            { "mark": "A1", "desc": "$x = 40$ cao" }
          ],
          "workingSteps": [
            "$n(D \\cup C) = n(D) + n(C) - n(D \\cap C) = 45 + 30 - 15 = 60$",
            "Neither $= 100 - 60 = 40$"
          ]
        },
        {
          "label": "b",
          "questionText": "A person is selected at random.\nWork out $P(D' \\cap C)$ — the probability they own a cat but not a dog.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "fraction",
          "correctAnswer": "3/20",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            { "mark": "M1", "desc": "Cat only: $30 - 15 = 15$" },
            { "mark": "M1", "desc": "$P = \\dfrac{15}{100}$" },
            { "mark": "A1", "desc": "$\\dfrac{3}{20}$ cao" }
          ],
          "workingSteps": [
            "Cat only (not dog): $30 - 15 = 15$",
            "$P(D' \\cap C) = \\dfrac{15}{100} = \\dfrac{3}{20}$"
          ]
        }
      ]
    }
