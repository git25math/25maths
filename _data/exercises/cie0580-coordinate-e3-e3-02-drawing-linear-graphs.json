      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "On the same grid, draw the graphs of $y = 2x - 1$ and $3x + 2y = 12$ for $0 \\leq x \\leq 5$.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Rearrange $3x + 2y = 12$ into the form $y = mx + c$.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "expression",
          "correctAnswer": "y = −3x/2 + 6",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "2y = 12 − 3x"
            },
            {
              "mark": "A1",
              "desc": "y = −3x/2 + 6 or y = 6 − 1.5x"
            }
          ],
          "workingSteps": [
            "3x + 2y = 12",
            "2y = −3x + 12",
            "y = −3x/2 + 6"
          ]
        },
        {
          "label": "b",
          "questionText": "Find the coordinates where the two lines intersect.",
          "marks": 4,
          "commandWord": "find",
          "answerType": "coordinate",
          "correctAnswer": "(2, 3)",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "2x − 1 = −3x/2 + 6"
            },
            {
              "mark": "M1",
              "desc": "4x − 2 = −3x + 12 → 7x = 14"
            },
            {
              "mark": "A1",
              "desc": "x = 2"
            },
            {
              "mark": "A1",
              "desc": "y = 2(2) − 1 = 3, so (2, 3)"
            }
          ],
          "workingSteps": [
            "2x − 1 = −1.5x + 6",
            "3.5x = 7",
            "x = 2, y = 3"
          ]
        },
        {
          "label": "c",
          "questionText": "Write down the area of the triangle formed by the two lines and the y-axis.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "7",
          "tolerance": null,
          "unit": null,
          "markScheme": [
            {
              "mark": "M1",
              "desc": "y-intercepts: −1 and 6, base = 7; height = x-coord of intersection = 2"
            },
            {
              "mark": "A1",
              "desc": "½ × 7 × 2 = 7"
            }
          ],
          "workingSteps": [
            "y-intercepts: (0,−1) and (0,6), base on y-axis = 7",
            "Height = 2 (x-coord of intersection)",
            "Area = ½ × 7 × 2 = 7"
          ]
        }
      ]
