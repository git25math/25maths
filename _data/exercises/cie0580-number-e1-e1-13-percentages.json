      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "A car is bought for $\\$12000$ and sold for $\\$9600$.\nCalculate the percentage loss.",
      "answerType": "integer",
      "correctAnswer": "20",
      "tolerance": null,
      "unit": "%",
      "markScheme": [
        { "mark": "M1", "desc": "Loss $= 12000 - 9600 = \\$2400$" },
        { "mark": "M1", "desc": "$\\dfrac{2400}{12000} \\times 100$" },
        { "mark": "A1", "desc": "$20\\%$ cao" }
      ],
      "workingSteps": [
        "Loss $= \\$12000 - \\$9600 = \\$2400$",
        "Percentage loss $= \\dfrac{2400}{12000} \\times 100 = 20\\%$"
      ],
      "explanation": "% loss = (loss ÷ original price) × 100."
    },
