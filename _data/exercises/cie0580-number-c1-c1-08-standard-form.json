            { "mark": "A1", "desc": "$1.83 \\times 10^3$ (3 sf)" }
          ],
          "workingSteps": [
            "$\\dfrac{1.67 \\times 10^{-27}}{9.11 \\times 10^{-31}}$",
            "$= \\dfrac{1.67}{9.11} \\times 10^{-27+31}$",
