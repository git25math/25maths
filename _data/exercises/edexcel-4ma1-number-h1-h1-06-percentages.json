      "type": "structured",
      "totalMarks": 7,
      "difficulty": "hard",
      "context": "An investment of $\\$10000$ earns $3.5\\%$ compound interest per year.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Work out the value of the investment after 5 years.\nGive your answer correct to the nearest dollar.",
          "marks": 3,
          "commandWord": "find",
          "answerType": "integer",
          "correctAnswer": "11877",
          "tolerance": 1,
          "unit": "$",
          "markScheme": [
            { "mark": "M1", "desc": "$10000 \\times 1.035^5$" },
            { "mark": "M1", "desc": "$1.035^5 = 1.18769...$" },
            { "mark": "A1", "desc": "$10000 \\times 1.18769 = \\$11876.9... \\approx \\$11877$" }
          ],
          "workingSteps": [
            "$V = 10000 \\times 1.035^5$",
            "$1.035^5 = 1.187686...$",
            "$V = 10000 \\times 1.187686 = \\$11876.86 \\approx \\$11877$"
          ]
        },
        {
          "label": "b",
          "questionText": "Work out the percentage increase over 5 years.\nGive your answer correct to 1 decimal place.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "18.8",
          "tolerance": 0.1,
          "unit": "%",
          "markScheme": [
            { "mark": "M1", "desc": "$\\dfrac{1877}{10000} \\times 100$ or $1.035^5 - 1$ as a percentage" },
