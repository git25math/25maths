          ],
          "workingSteps": [
            "Increase $= \\$11877 - \\$10000 = \\$1877$",
            "Percentage increase $= \\dfrac{1877}{10000} \\times 100 = 18.77...\\% \\approx 18.8\\%$"
          ]
        },
        {
          "label": "c",
          "questionText": "After how many complete years will the investment first exceed $\\$13000$?\nShow your working.",
