    {
      "_style": "SHORT-ANSWER — 直接计算型 (Paper 2 风格)",
      "_desc": "给条件，求一个值，只写答案",
      "id": "E6-02-Q1",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "In triangle PQR, PQ = 12 cm, angle QPR = 35° and angle PQR = 80°.\nCalculate QR.",
      "answerType": "numeric",
      "correctAnswer": "7.15",
      "tolerance": 0.01,
      "unit": "cm",
      "markScheme": [
        { "mark": "M2", "desc": "QR/sin35 = 12/sin(180-35-80) oe" },
        { "mark": "A1", "desc": "7.15 or 7.148..." }
      ],
      "workingSteps": [
        "Angle PRQ = 180 - 35 - 80 = 65°",
        "QR / sin35 = 12 / sin65",
        "QR = 12 × sin35 / sin65",
        "QR = 7.15 cm (3sf)"
      ],
      "explanation": "Use the sine rule with the angle opposite each side."
    },

    {
      "_style": "SHORT-ANSWER — 逆向求角型",
      "_desc": "给三边或两边一角，反向求角度",
      "id": "E6-02-Q2",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "In triangle ABC, AB = 9 cm, BC = 7 cm and angle BAC = 40°.\nCalculate angle BCA.",
      "answerType": "numeric",
      "correctAnswer": "55.4",
      "tolerance": 0.1,
      "unit": "°",
      "markScheme": [
        { "mark": "M2", "desc": "sinC/9 = sin40/7 oe" },
        { "mark": "A1", "desc": "55.4 or 55.38 to 55.39" }
      ],
      "workingSteps": [
        "sinC / 9 = sin40 / 7",
        "sinC = 9 × sin40 / 7 = 0.826...",
        "C = sin⁻¹(0.826) = 55.4°"
      ],
      "explanation": "Use the sine rule rearranged to find the unknown angle."
    },

    {
      "_style": "SHORT-ANSWER — 面积公式型",
      "_desc": "用 ½absinC 求面积，单步",
      "id": "E6-02-Q3",
      "type": "short-answer",
      "totalMarks": 2,
      "commandWord": "calculate",
      "difficulty": "easy",
      "questionText": "Calculate the area of triangle XYZ where XY = 10 cm, XZ = 6 cm and angle YXZ = 52°.",
      "answerType": "numeric",
      "correctAnswer": "23.6",
      "tolerance": 0.1,
      "unit": "cm²",
