        { "mark": "A1", "desc": "23.6 or 23.63..." }
      ],
      "workingSteps": [
        "Area = ½ × XY × XZ × sin(YXZ)",
        "Area = ½ × 10 × 6 × sin52°",
        "Area = 23.6 cm²"
      ],
      "explanation": "Apply the formula Area = ½absinC."
    },

    {
      "_style": "SHORT-ANSWER — 余弦定理求边型",
      "_desc": "三角形中已知两边及夹角，用余弦定理求第三边",
      "id": "E6-02-Q4",
      "type": "short-answer",
      "totalMarks": 3,
      "commandWord": "calculate",
      "difficulty": "medium",
      "questionText": "In triangle DEF, DE = 8 cm, EF = 11 cm and angle DEF = 64°.\nCalculate DF.",
      "answerType": "numeric",
      "correctAnswer": "10.2",
      "tolerance": 0.1,
      "unit": "cm",
      "markScheme": [
        { "mark": "M2", "desc": "DF² = 8² + 11² - 2(8)(11)cos64 oe" },
        { "mark": "A1", "desc": "10.2 or 10.17 to 10.18" }
      ],
      "workingSteps": [
        "DF² = DE² + EF² - 2(DE)(EF)cos(DEF)",
        "DF² = 64 + 121 - 176cos64°",
        "DF² = 185 - 77.2 = 107.8",
        "DF = √107.8 = 10.2 cm"
      ],
      "explanation": "Use the cosine rule a² = b² + c² - 2bc·cosA."
    },

    {
      "_style": "STRUCTURED — 实际情境多步骤 (Paper 4 经典风格)",
      "_desc": "真实场景（航海/测量），逐步引导，part 之间有依赖",
      "id": "E6-02-Q5",
      "type": "structured",
      "totalMarks": 10,
      "difficulty": "hard",
      "context": "A ship sails from port A on a bearing of 060° for 15 km to point B.\nIt then sails on a bearing of 150° for 20 km to point C.",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Show that angle ABC = 90°.",
          "marks": 1,
          "commandWord": "show",
          "answerType": "show-that",
          "correctAnswer": "90",
          "markScheme": [
            { "mark": "B1", "desc": "150 - 60 = 90 or angles on parallel lines oe" }
          ],
          "workingSteps": [
            "Bearing from A = 060°, bearing from B = 150°",
            "Angle ABC = 150° - 60° = 90°"
          ]
        },
        {
          "label": "b",
          "questionText": "Calculate the distance AC.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "25",
          "tolerance": 0,
          "unit": "km",
          "markScheme": [
            { "mark": "M1", "desc": "Recognising right angle and using Pythagoras or cosine rule" },
            { "mark": "M1", "desc": "AC² = 15² + 20²" },
            { "mark": "A1", "desc": "25" }
          ],
          "workingSteps": [
            "Since angle ABC = 90°, use Pythagoras",
            "AC² = AB² + BC² = 15² + 20² = 225 + 400 = 625",
            "AC = √625 = 25 km"
          ]
        },
        {
          "label": "c",
          "questionText": "Calculate the bearing of C from A.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "113",
          "tolerance": 0.1,
          "unit": "°",
          "markScheme": [
            { "mark": "M1", "desc": "tan(BAC) = 20/15 oe" },
            { "mark": "A1", "desc": "angle BAC = 53.1° or 53.13..." },
            { "mark": "A1", "desc": "Bearing = 060 + 53.1 = 113° (to nearest degree)" }
          ],
          "workingSteps": [
            "tan(BAC) = BC / AB = 20 / 15",
            "angle BAC = tan⁻¹(20/15) = 53.1°",
            "Bearing of C from A = 060° + 53.1° = 113.1° ≈ 113°"
          ]
        },
        {
          "label": "d",
          "questionText": "Calculate the area of triangle ABC.",
          "marks": 3,
          "commandWord": "calculate",
          "answerType": "numeric",
          "correctAnswer": "150",
          "tolerance": 0,
          "unit": "km²",
          "markScheme": [
            { "mark": "M1", "desc": "½ × 15 × 20 oe (or ½ × base × height using right angle)" },
            { "mark": "A1", "desc": "150" },
            { "mark": "B1", "desc": "Correct unit km²" }
          ],
          "workingSteps": [
            "Area = ½ × AB × BC × sin(ABC)",
            "Area = ½ × 15 × 20 × sin90°",
            "Area = ½ × 15 × 20 = 150 km²"
          ]
        }
      ]
    },

    {
      "_style": "STRUCTURED — 几何证明型 (show that + hence)",
      "_desc": "先证一个中间结论，再用它解后续部分",
      "id": "E6-02-Q6",
      "type": "structured",
      "totalMarks": 8,
      "difficulty": "hard",
      "context": "In the diagram, triangle PQR has PQ = (x + 3) cm, QR = (2x - 1) cm, angle PQR = 60° and the area of triangle PQR is 10√3 cm².",
      "diagram": null,
      "parts": [
        {
          "label": "a",
          "questionText": "Show that $2x^2 + 5x - 43 = 0$.",
          "marks": 3,
          "commandWord": "show",
          "answerType": "show-that",
          "correctAnswer": "2x² + 5x - 43 = 0",
          "markScheme": [
            { "mark": "M1", "desc": "½ × (x+3) × (2x-1) × sin60 = 10√3" },
            { "mark": "M1", "desc": "Correct expansion of (x+3)(2x-1)" },
            { "mark": "A1", "desc": "2x² + 5x - 43 = 0 with no errors in working" }
          ],
          "workingSteps": [
            "Area = ½ × PQ × QR × sin60°",
            "10√3 = ½ × (x+3)(2x-1) × (√3/2)",
            "10√3 = (√3/4)(x+3)(2x-1)",
            "40 = (x+3)(2x-1)",
            "40 = 2x² + 5x - 3",
            "2x² + 5x - 43 = 0"
          ]
        },
        {
          "label": "b",
          "questionText": "Solve $2x^2 + 5x - 43 = 0$, giving your answers correct to 2 decimal places.",
          "marks": 3,
          "commandWord": "solve",
          "answerType": "numeric",
          "correctAnswer": "3.40",
          "tolerance": 0.005,
          "markScheme": [
            { "mark": "M1", "desc": "Correct substitution into quadratic formula" },
            { "mark": "A1", "desc": "x = 3.40 (2dp)" },
            { "mark": "A1", "desc": "x = -6.40 (2dp) — may be rejected with reason" }
          ],
          "workingSteps": [
            "x = (-5 ± √(25 + 344)) / 4",
            "x = (-5 ± √369) / 4",
            "x = (-5 + 19.21) / 4 = 3.40",
            "or x = (-5 - 19.21) / 4 = -6.40 (rejected, length must be positive)"
          ]
        },
        {
          "label": "c",
          "questionText": "Hence find the length of PR.",
          "marks": 2,
          "commandWord": "find",
          "answerType": "numeric",
          "correctAnswer": "5.89",
          "tolerance": 0.05,
          "unit": "cm",
          "markScheme": [
            { "mark": "M1", "desc": "Cosine rule with their x: PR² = (x+3)² + (2x-1)² - 2(x+3)(2x-1)cos60" },
            { "mark": "A1", "desc": "5.89 or 5.9 (ft their x)" }
          ],
          "workingSteps": [
            "x = 3.40, so PQ = 6.40, QR = 5.80",
            "PR² = 6.40² + 5.80² - 2(6.40)(5.80)cos60°",
            "PR² = 40.96 + 33.64 - 37.12 = 37.48",
            "PR = 6.12 cm"
          ]
        }
      ]
    },

